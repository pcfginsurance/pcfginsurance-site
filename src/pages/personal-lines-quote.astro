---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<Layout
  title="Personal Lines Insurance Quote - PCFG Insurance Services"
  description="Request a personalized quote for auto, home, life, and other personal insurance coverage. Get competitive rates from trusted carriers."
>
  <Header />

  <Breadcrumbs
    items={[
      { label: 'Home', href: '/' },
      { label: 'Personal Insurance', href: '/personal-insurance' },
      { label: 'Get Quote', href: '/personal-lines-quote' }
    ]}
  />

  <section class="py-16 bg-gradient-to-br from-gray-50 to-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Personal Lines Insurance Quote</h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Complete our quick survey to receive a personalized quote for your auto, home, life, or other personal insurance needs.
        </p>
      </div>

      <!-- GHL Survey Form Embed -->
<!-- Sembley Intake Form Widget -->
<script src="https://app.sembley.com/widgets/embedded-intake.js"></script>
<div id="sembley-intake-form" data-form-id="9374" data-secure-token="imaxicphr2A" data-height="1200px" data-show-logo="true" data-assign-to-user="7141"></div>

        <!-- end -->
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Fast Response</h3>
          <p class="text-gray-600">We'll review your information and respond within 24 hours</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Competitive Rates</h3>
          <p class="text-gray-600">We shop multiple carriers to find you the best coverage at the best price</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Expert Guidance</h3>
          <p class="text-gray-600">Our licensed agents will help you understand your coverage options</p>
        </div>
      </div>

      <div class="mt-8 text-center">
        <p class="text-gray-600 mb-4">Prefer to speak with someone directly?</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:877-717-7234" class="bg-orange-600 hover:bg-orange-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200">
            Call (877) 717-7234
          </a>
          <a href="mailto:info@pcfginsurance.com" class="border-2 border-orange-600 text-orange-600 hover:bg-orange-600 hover:text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200">
            Email Us
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

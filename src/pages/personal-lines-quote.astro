---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<Layout
  title="Personal Lines Insurance Quote - PCFG Insurance Services"
  description="Request a personalized quote for auto, home, life, and other personal insurance coverage. Get competitive rates from trusted carriers."
>
  <Header />

  <Breadcrumbs
    items={[
      { label: 'Home', href: '/' },
      { label: 'Personal Insurance', href: '/personal-insurance' },
      { label: 'Get Quote', href: '/personal-lines-quote' }
    ]}
  />

  <section class="py-16 bg-gradient-to-br from-gray-50 to-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Personal Lines Insurance Quote</h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Complete the form below to receive a personalized quote for your auto, home, life, or other personal insurance needs.
        </p>
      </div>

      <div class="bg-white rounded-lg shadow-xl overflow-hidden">
        <div class="bg-orange-600 px-8 py-6">
          <h2 class="text-2xl font-semibold text-white">Request Your Quote</h2>
          <p class="text-orange-100 mt-2">We'll respond within 24 hours with your personalized quote</p>
        </div>

        <form id="personal-lines-quote-form" class="p-8 space-y-6">
          <div id="form-message" role="alert" aria-live="polite" class="hidden"></div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="first_name" class="block text-sm font-medium text-gray-700 mb-2">
                First Name <span class="text-red-600">*</span>
              </label>
              <input
                type="text"
                id="first_name"
                name="first_name"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-orange-500 focus:border-transparent"
              />
            </div>

            <div>
              <label for="last_name" class="block text-sm font-medium text-gray-700 mb-2">
                Last Name <span class="text-red-600">*</span>
              </label>
              <input
                type="text"
                id="last_name"
                name="last_name"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-orange-500 focus:border-transparent"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
                Email Address <span class="text-red-600">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-orange-500 focus:border-transparent"
              />
            </div>

            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
                Phone Number <span class="text-red-600">*</span>
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                pattern="[0-9]{10}"
                placeholder="1234567890"
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-orange-500 focus:border-transparent"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="city" class="block text-sm font-medium text-gray-700 mb-2">
                City <span class="text-red-600">*</span>
              </label>
              <input
                type="text"
                id="city"
                name="city"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-orange-500 focus:border-transparent"
              />
            </div>

            <div>
              <label for="state" class="block text-sm font-medium text-gray-700 mb-2">
                State <span class="text-red-600">*</span>
              </label>
              <select
                id="state"
                name="state"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-orange-500 focus:border-transparent"
              >
                <option value="">Select State</option>
                <option value="NY">New York</option>
                <option value="NJ">New Jersey</option>
                <option value="CT">Connecticut</option>
                <option value="PA">Pennsylvania</option>
                <option value="MA">Massachusetts</option>
              </select>
            </div>
          </div>

          <div>
            <label for="insurance_types" class="block text-sm font-medium text-gray-700 mb-3">
              Insurance Type(s) Needed <span class="text-red-600">*</span>
            </label>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              <label class="flex items-center space-x-3 p-3 border border-gray-300 rounded-md hover:bg-gray-50 cursor-pointer">
                <input type="checkbox" name="insurance_types" value="Auto Insurance" class="w-4 h-4 text-orange-600 rounded focus:ring-orange-500" />
                <span class="text-gray-700">Auto Insurance</span>
              </label>
              <label class="flex items-center space-x-3 p-3 border border-gray-300 rounded-md hover:bg-gray-50 cursor-pointer">
                <input type="checkbox" name="insurance_types" value="Homeowners Insurance" class="w-4 h-4 text-orange-600 rounded focus:ring-orange-500" />
                <span class="text-gray-700">Homeowners Insurance</span>
              </label>
              <label class="flex items-center space-x-3 p-3 border border-gray-300 rounded-md hover:bg-gray-50 cursor-pointer">
                <input type="checkbox" name="insurance_types" value="Life Insurance" class="w-4 h-4 text-orange-600 rounded focus:ring-orange-500" />
                <span class="text-gray-700">Life Insurance</span>
              </label>
              <label class="flex items-center space-x-3 p-3 border border-gray-300 rounded-md hover:bg-gray-50 cursor-pointer">
                <input type="checkbox" name="insurance_types" value="Umbrella Insurance" class="w-4 h-4 text-orange-600 rounded focus:ring-orange-500" />
                <span class="text-gray-700">Umbrella Insurance</span>
              </label>
              <label class="flex items-center space-x-3 p-3 border border-gray-300 rounded-md hover:bg-gray-50 cursor-pointer">
                <input type="checkbox" name="insurance_types" value="Renters Insurance" class="w-4 h-4 text-orange-600 rounded focus:ring-orange-500" />
                <span class="text-gray-700">Renters Insurance</span>
              </label>
              <label class="flex items-center space-x-3 p-3 border border-gray-300 rounded-md hover:bg-gray-50 cursor-pointer">
                <input type="checkbox" name="insurance_types" value="Condo Insurance" class="w-4 h-4 text-orange-600 rounded focus:ring-orange-500" />
                <span class="text-gray-700">Condo Insurance</span>
              </label>
              <label class="flex items-center space-x-3 p-3 border border-gray-300 rounded-md hover:bg-gray-50 cursor-pointer">
                <input type="checkbox" name="insurance_types" value="Motorcycle Insurance" class="w-4 h-4 text-orange-600 rounded focus:ring-orange-500" />
                <span class="text-gray-700">Motorcycle Insurance</span>
              </label>
              <label class="flex items-center space-x-3 p-3 border border-gray-300 rounded-md hover:bg-gray-50 cursor-pointer">
                <input type="checkbox" name="insurance_types" value="Boat Insurance" class="w-4 h-4 text-orange-600 rounded focus:ring-orange-500" />
                <span class="text-gray-700">Boat Insurance</span>
              </label>
              <label class="flex items-center space-x-3 p-3 border border-gray-300 rounded-md hover:bg-gray-50 cursor-pointer">
                <input type="checkbox" name="insurance_types" value="RV Insurance" class="w-4 h-4 text-orange-600 rounded focus:ring-orange-500" />
                <span class="text-gray-700">RV Insurance</span>
              </label>
            </div>
          </div>

          <div>
            <label for="current_carrier" class="block text-sm font-medium text-gray-700 mb-2">
              Current Insurance Carrier (if applicable)
            </label>
            <input
              type="text"
              id="current_carrier"
              name="current_carrier"
              placeholder="e.g., State Farm, Geico, etc."
              class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-orange-500 focus:border-transparent"
            />
          </div>

          <div>
            <label for="coverage_start_date" class="block text-sm font-medium text-gray-700 mb-2">
              Desired Coverage Start Date
            </label>
            <input
              type="date"
              id="coverage_start_date"
              name="coverage_start_date"
              class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-orange-500 focus:border-transparent"
            />
          </div>

          <div>
            <label for="additional_info" class="block text-sm font-medium text-gray-700 mb-2">
              Additional Information or Questions
            </label>
            <textarea
              id="additional_info"
              name="additional_info"
              rows="4"
              placeholder="Tell us more about your insurance needs..."
              class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-orange-500 focus:border-transparent"
            ></textarea>
          </div>

          <div class="bg-gray-50 p-4 rounded-md">
            <label class="flex items-start space-x-3">
              <input
                type="checkbox"
                id="consent"
                name="consent"
                required
                class="w-5 h-5 text-orange-600 rounded focus:ring-orange-500 mt-1"
              />
              <span class="text-sm text-gray-700">
                I consent to being contacted by PCFG Insurance Services regarding my quote request via phone, email, or text message. <span class="text-red-600">*</span>
              </span>
            </label>
          </div>

          <div class="flex flex-col sm:flex-row gap-4 pt-4">
            <button
              type="submit"
              class="flex-1 bg-orange-600 hover:bg-orange-700 text-white font-semibold py-3 px-6 rounded-md transition-colors duration-200"
            >
              Request Quote
            </button>
            <button
              type="reset"
              class="border-2 border-gray-300 hover:bg-gray-50 text-gray-700 font-semibold py-3 px-6 rounded-md transition-colors duration-200"
            >
              Clear Form
            </button>
          </div>
        </form>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Fast Response</h3>
          <p class="text-gray-600">We'll review your information and respond within 24 hours</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Competitive Rates</h3>
          <p class="text-gray-600">We shop multiple carriers to find you the best coverage at the best price</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Expert Guidance</h3>
          <p class="text-gray-600">Our licensed agents will help you understand your coverage options</p>
        </div>
      </div>

      <div class="mt-8 text-center">
        <p class="text-gray-600 mb-4">Prefer to speak with someone directly?</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:877-717-7234" class="bg-orange-600 hover:bg-orange-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200">
            Call (877) 717-7234
          </a>
          <a href="mailto:info@pcfginsurance.com" class="border-2 border-orange-600 text-orange-600 hover:bg-orange-600 hover:text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200">
            Email Us
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
  const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const supabase = createClient(supabaseUrl, supabaseAnonKey);

  const form = document.getElementById('personal-lines-quote-form') as HTMLFormElement;
  const messageDiv = document.getElementById('form-message') as HTMLDivElement;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = submitButton.textContent;
      submitButton.disabled = true;
      submitButton.textContent = 'Submitting...';

      messageDiv.className = 'hidden';

      const formData = new FormData(form);

      const insuranceTypes = formData.getAll('insurance_types');
      if (insuranceTypes.length === 0) {
        showMessage('Please select at least one insurance type.', 'error');
        submitButton.disabled = false;
        submitButton.textContent = originalText;
        return;
      }

      const data = {
        first_name: formData.get('first_name') as string,
        last_name: formData.get('last_name') as string,
        email: formData.get('email') as string,
        phone: formData.get('phone') as string,
        city: formData.get('city') as string,
        state: formData.get('state') as string,
        insurance_types: insuranceTypes.join(', '),
        current_carrier: formData.get('current_carrier') as string || null,
        coverage_start_date: formData.get('coverage_start_date') as string || null,
        additional_info: formData.get('additional_info') as string || null,
        form_type: 'Personal Lines Quote',
        submitted_at: new Date().toISOString()
      };

      try {
        const { error } = await supabase
          .from('lead_submissions')
          .insert([{
            name: `${data.first_name} ${data.last_name}`,
            email: data.email,
            phone: data.phone,
            city: data.city,
            state: data.state,
            insurance_type: data.insurance_types,
            message: `Current Carrier: ${data.current_carrier || 'N/A'}\nCoverage Start Date: ${data.coverage_start_date || 'N/A'}\n\nAdditional Info:\n${data.additional_info || 'None provided'}`
          }]);

        if (error) throw error;

        showMessage('Thank you! Your quote request has been submitted. We\'ll contact you within 24 hours.', 'success');
        form.reset();

        setTimeout(() => {
          window.location.href = '/thank-you.html';
        }, 2000);
      } catch (error) {
        console.error('Submission error:', error);
        showMessage('There was an error submitting your request. Please try again or call us at (877) 717-7234.', 'error');
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = originalText;
      }
    });
  }

  function showMessage(message: string, type: 'success' | 'error') {
    messageDiv.textContent = message;
    messageDiv.className = type === 'success'
      ? 'p-4 rounded-md bg-green-50 border border-green-200 text-green-800'
      : 'p-4 rounded-md bg-red-50 border border-red-200 text-red-800';
  }
</script>

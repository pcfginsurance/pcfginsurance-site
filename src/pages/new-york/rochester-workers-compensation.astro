---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "InsuranceAgency",
  "name": "PCFG Insurance Services",
  "image": "https://pcfginsurance.com/logo.png",
  "description": "Workers' compensation insurance for businesses in Rochester, NY and throughout Monroe County. Veteran-owned agency serving Western New York since 2018.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Parish",
    "addressRegion": "NY",
    "addressCountry": "US"
  },
  "areaServed": {
    "@type": "City",
    "name": "Rochester",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Rochester",
      "addressRegion": "NY"
    }
  },
  "telephone": "877-717-7234",
  "priceRange": "$$"
};
---

<Layout 
  title="Workers' Compensation Insurance Rochester NY | PCFG Insurance" 
  description="Get competitive workers' compensation insurance quotes for your Rochester, NY business. Expert coverage for Western New York employers in manufacturing, healthcare, technology, and more. Licensed in Monroe County. Free quote from veteran-owned agency." 
  ogImage="https://images.pexels.com/photos/5668858/pexels-photo-5668858.jpeg?auto=compress&cs=tinysrgb&w=1200&h=630" 
  ogType="article"
>
  <Header />
  
  <!-- JSON-LD Schema for Local Business -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  
  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-br from-navy-50 to-white">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Text -->
        <div>
          <div class="inline-block bg-orange-100 text-orange-800 px-4 py-2 rounded-full text-sm font-semibold mb-4">
            Rochester & Monroe County
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
            Workers' Compensation Insurance in Rochester, NY
          </h1>
          <p class="text-xl text-gray-600 mb-4">
            Protect your Rochester employees and business with comprehensive workers' compensation coverage. PCFG Insurance specializes in <strong>Western New York employers</strong> across optics, imaging, manufacturing, healthcare, and more.
          </p>
          <p class="text-lg text-gray-600 mb-6">
            Serving the Flower City, we understand the unique needs of Monroe County businesses—from optics innovation to healthcare excellence. Get competitive rates from a <a href="/the-team" class="text-navy-600 hover:underline">veteran-owned agency</a> that knows Western NY.
          </p>
          <div class="bg-blue-50 border-l-4 border-blue-400 p-4 mb-6">
            <p class="text-sm text-gray-700">
              <strong>Rochester Fast Fact:</strong> New York requires workers' compensation insurance for businesses with 1 or more employees. Penalties for non-compliance include fines up to $2,000 per 10-day period plus stop-work orders.
            </p>
          </div>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#quote-form" class="bg-navy-600 hover:bg-navy-700 text-white px-8 py-3 rounded-md font-semibold text-center transition-colors duration-200">Get Rochester Quote</a>
            <a href="tel:877-717-7234" class="border-2 border-navy-600 text-navy-600 hover:bg-navy-600 hover:text-white px-8 py-3 rounded-md font-semibold text-center transition-colors duration-200">Call (877) 717-7234</a>
          </div>
        </div>

        <!-- Form -->
        <div id="quote-form">
          <div class="bg-white p-6 md:p-8 rounded-lg shadow-xl">
            <h3 class="text-2xl font-semibold text-gray-900 mb-2">Get Your Rochester Workers' Comp Quote</h3>
            <p class="text-gray-600 mb-6">Fast quotes for Western New York businesses</p>
            <div class="w-full" style="min-height: 900px;">
              <iframe
      src="https://api.leadconnectorhq.com/widget/form/M0PWOXapIeQLm41fmLc1"
      style="width:100%;height:900px;border:none;border-radius:4px"
      id="inline-M0PWOXapIeQLm41fmLc1" 
      data-layout="{'id':'INLINE'}"
      data-trigger-type="alwaysShow"
      data-trigger-value=""
      data-activation-type="alwaysActivated"
      data-activation-value=""
      data-deactivation-type="neverDeactivate"
      data-deactivation-value=""
      data-form-name="Workers Comp - Website"
      data-height="935"
      data-layout-iframe-id="inline-M0PWOXapIeQLm41fmLc1"
      data-form-id="M0PWOXapIeQLm41fmLc1"
      title="Workers Comp - Rochester NY"

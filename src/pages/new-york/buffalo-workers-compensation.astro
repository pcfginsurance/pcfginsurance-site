---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "InsuranceAgency",
  "name": "PCFG Insurance Services",
  "image": "https://pcfginsurance.com/logo.png",
  "description": "Workers' compensation insurance for businesses in Buffalo, NY and throughout Erie County. Veteran-owned agency serving Western New York since 2018.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Parish",
    "addressRegion": "NY",
    "addressCountry": "US"
  },
  "areaServed": {
    "@type": "City",
    "name": "Buffalo",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Buffalo",
      "addressRegion": "NY"
    }
  },
  "telephone": "877-717-7234",
  "priceRange": "$$"
};
---

<Layout 
  title="Workers' Compensation Insurance Buffalo NY | PCFG Insurance" 
  description="Get competitive workers' compensation insurance quotes for your Buffalo, NY business. Expert coverage for Western New York employers in manufacturing, healthcare, hospitality, and more. Licensed in Erie County. Free quote from veteran-owned agency." 
  ogImage="https://images.pexels.com/photos/5668858/pexels-photo-5668858.jpeg?auto=compress&cs=tinysrgb&w=1200&h=630" 
  ogType="article"
>
  <Header />
  
  <!-- JSON-LD Schema for Local Business -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  
  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-br from-navy-50 to-white">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Text -->
        <div>
          <div class="inline-block bg-orange-100 text-orange-800 px-4 py-2 rounded-full text-sm font-semibold mb-4">
            Buffalo & Erie County
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
            Workers' Compensation Insurance in Buffalo, NY
          </h1>
          <p class="text-xl text-gray-600 mb-4">
            Protect your Buffalo employees and business with comprehensive workers' compensation coverage. PCFG Insurance specializes in <strong>Western New York employers</strong> across manufacturing, healthcare, hospitality, construction, and more.
          </p>
          <p class="text-lg text-gray-600 mb-6">
            Serving the City of Good Neighbors, we understand the unique needs of Erie County businesses—from lakefront weather challenges to Buffalo's resurgent economy. Get competitive rates from a <a href="/the-team" class="text-navy-600 hover:underline">veteran-owned agency</a> that knows Western NY.
          </p>
          <div class="bg-blue-50 border-l-4 border-blue-400 p-4 mb-6">
            <p class="text-sm text-gray-700">
              <strong>Buffalo Fast Fact:</strong> New York requires workers' compensation insurance for businesses with 1 or more employees. Penalties for non-compliance include fines up to $2,000 per 10-day period plus stop-work orders.
            </p>
          </div>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#quote-form" class="bg-navy-600 hover:bg-navy-700 text-white px-8 py-3 rounded-md font-semibold text-center transition-colors duration-200">Get Buffalo Quote</a>

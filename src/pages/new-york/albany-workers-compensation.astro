---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "InsuranceAgency",
  "name": "PCFG Insurance Services",
  "image": "https://pcfginsurance.com/logo.png",
  "description": "Workers' compensation insurance for businesses in Albany, NY and throughout Albany County. Veteran-owned agency serving Capital Region since 2018.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Parish",
    "addressRegion": "NY",
    "addressCountry": "US"
  },
  "areaServed": {
    "@type": "City",
    "name": "Albany",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Albany",
      "addressRegion": "NY"
    }
  },
  "telephone": "877-717-7234",
  "priceRange": "$$"
};
---

<Layout 
  title="Workers' Compensation Insurance Albany NY | PCFG Insurance" 
  description="Get competitive workers' compensation insurance quotes for your Albany, NY business. Expert coverage for Capital Region employers in government, tech, healthcare, and more. Licensed in Albany County. Free quote from veteran-owned agency." 
  ogImage="https://images.pexels.com/photos/5668858/pexels-photo-5668858.jpeg?auto=compress&cs=tinysrgb&w=1200&h=630" 
  ogType="article"
>
  <Header />
  
  <!-- JSON-LD Schema for Local Business -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  
  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-br from-navy-50 to-white">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Text -->
        <div>
          <div class="inline-block bg-orange-100 text-orange-800 px-4 py-2 rounded-full text-sm font-semibold mb-4">
            Albany & Capital Region
          </div>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
            Workers' Compensation Insurance in Albany, NY
          </h1>
          <p class="text-xl text-gray-600 mb-4">
            Protect your Albany employees and business with comprehensive workers' compensation coverage. PCFG Insurance specializes in <strong>Capital Region employers</strong> across government contractors, technology, healthcare, professional services, and more.
          </p>
          <p class="text-lg text-gray-600 mb-6">
            Serving New York's capital, we understand the unique needs of Albany County businesses—from state contract requirements to the diverse Capital Region economy. Get competitive rates from a <a href="/the-team" class="text-navy-600 hover:underline">veteran-owned agency</a> that knows Upstate NY.
          </p>
          <div class="bg-blue-50 border-l-4 border-blue-400 p-4 mb-6">
            <p class="text-sm text-gray-700">
              <strong>Albany Fast Fact:</strong> New York requires workers' compensation insurance for businesses with 1 or more employees. Penalties for non-compliance include fines up to $2,000 per 10-day period plus stop-work orders.
            </p>
          </div>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#quote-form" class="bg-navy-600 hover:bg-navy-700 text-white px-8 py-3 rounded-md font-semibold text-center transition-colors duration-200">Get Albany Quote</a>
            <a href="tel:877-717-7234" class="border-2 border-navy-600 text-navy-600 hover:bg-navy-600 hover:text-white px-8 py-3 rounded-md font-semibold text-center transition-colors duration-200">Call (877) 717-7234</a>
          </div>
        </div>

        <!-- Form -->
        <div id="quote-form">
          <div class="bg-white p-6 md:p-8 rounded-lg shadow-xl">
            <h3 class="text-2xl font-semibold text-gray-900 mb-2">Get Your Albany Workers' Comp Quote</h3>
            <p class="text-gray-600 mb-6">Fast quotes for Capital Region businesses</p>
            <div class="w-full" style="min-height: 900px;">
              <iframe
      src="https://api.leadconnectorhq.com/widget/form/M0PWOXapIeQLm41fmLc1"
      style="width:100%;height:900px;border:none;border-radius:4px"
      id="inline-M0PWOXapIeQLm41fmLc1" 
      data-layout="{'id':'INLINE'}"
      data-trigger-type="alwaysShow"
      data-trigger-value=""
      data-activation-type="alwaysActivated"
      data-activation-value=""
      data-deactivation-type="neverDeactivate"
      data-deactivation-value=""
      data-form-name="Workers Comp - Website"
      data-height="935"
      data-layout-iframe-id="inline-M0PWOXapIeQLm41fmLc1"
      data-form-id="M0PWOXapIeQLm41fmLc1"
      title="Workers Comp - Albany NY"

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Farm Owners Insurance - Hobby & Small Farms | PCFG Insurance" description="Specialized insurance for hobby farms, small farms, and gentleman farms across 15 states. Protect your property, animals, equipment, and liability exposure.">
  <Header />

<!-- Hero Section -->
<section class="py-20 bg-gradient-to-br from-navy-50 to-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left Column -->
      <div>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          Farm Owners Insurance
        </h1>
        <p class="text-xl text-gray-600 mb-8">
          Specialized insurance coverage for hobby farms, small farms, and gentleman farms. Protect your rural property, animals, equipment, and structures with comprehensive farm owners insurance designed for non-commercial operations.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#quote-form"
            class="bg-navy-600 hover:bg-navy-700 text-white px-8 py-3 rounded-md font-semibold text-center transition-colors duration-200">
            Get Free Quote
          </a>
        </div>
      </div>

      <!-- Right Column (Form) -->
      <div id="quote-form" class="bg-white p-8 rounded-lg shadow-xl">
        <h3 class="text-2xl font-semibold text-gray-900 mb-6 text-center">
          Get Your Farm Insurance Quote
        </h3>
        <div class="w-full" style="min-height: 900px;">
          <iframe
            src="https://link.spartan-crm.com/widget/form/xOVCI4Wvy7sIPBsjTZ1i"
            style="width: 100%; border: none; overflow: hidden; height: 900px; min-height: 900px;"
            id="inline-farm-owners-form"
            data-layout="{'id':'INLINE'}"
            data-trigger-type="alwaysShow"
            data-form-name="Farm Owners Insurance - Website"
            data-height="900"
            title="Farm Owners Insurance - Website"
            scrolling="no"
            allow="payment">
          </iframe>
          <script src="https://link.spartan-crm.com/js/form_embed.js" type="text/javascript"></script>
        </div>
      </div>
    </div>
  </div>
</section>

  <!-- Licensed States Banner -->
  <section class="py-12 bg-navy-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-xl font-bold text-white mb-4">Farm Insurance Available In:</h2>
        <div class="flex flex-wrap justify-center gap-3">
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Alabama</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Arizona</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Florida</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Georgia</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Indiana</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Maryland</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Maine</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">New Jersey</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">New York</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">North Carolina</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Ohio</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Pennsylvania</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Tennessee</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Texas</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Virginia</span>
        </div>
      </div>
    </div>
  </section>

  <!-- What is Farm Owners Insurance -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">What is Farm Owners Insurance?</h2>
          <p class="text-lg text-gray-600 mb-6">
            Farm owners insurance is a specialized policy designed for hobby farms, small farms, and rural properties that aren't primarily used for commercial agriculture. It combines property, liability, and agricultural-specific coverages into one comprehensive package.
          </p>
          <div class="mb-6">
            <h3 class="text-xl font-semibold text-gray-900 mb-3">What's Covered:</h3>
            <ul class="space-y-2 text-gray-600">
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Dwelling and other structures (barns, stables, sheds)
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Personal property and farm equipment
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Livestock and animals
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Liability protection for farm activities
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Farm machinery and tools
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Loss of use and additional living expenses
              </li>
            </ul>
          </div>
          <a href="#quote-form" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200">
            Get Farm Insurance Quote
          </a>
        </div>
        <div class="bg-gray-100 p-8 rounded-lg">
          <div class="w-16 h-16 bg-navy-600 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
          </div>
          <h4 class="text-xl font-semibold text-gray-900 mb-4">More Than Homeowners Insurance</h4>
          <div class="bg-white p-4 rounded border-l-4 border-yellow-400 mb-4">
            <p class="text-sm text-yellow-700">
              <strong>Important:</strong> Standard homeowners policies typically exclude farm-related activities, animals, and structures. Farm insurance is essential for proper protection.
            </p>
          </div>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start">
              <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
              Covers agricultural structures
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
              Includes livestock protection
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
              Protects farm equipment and machinery
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
              Broader liability coverage
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Types of Properties -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Perfect for These Types of Properties</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Farm owners insurance is designed for non-commercial rural properties and hobby farms.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Hobby Farms</h3>
          <p class="text-sm text-gray-600">
            Small-scale farming operations for personal enjoyment and supplemental income, not primary livelihood.
          </p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Gentleman Farms</h3>
          <p class="text-sm text-gray-600">
            Rural estates with acreage, animals, and farm structures maintained for lifestyle purposes.
          </p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Rural Properties</h3>
          <p class="text-sm text-gray-600">
            Large acreage properties with outbuildings, fencing, and land used for recreational purposes.
          </p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Equestrian Properties</h3>
          <p class="text-sm text-gray-600">
            Properties with horses, stables, riding arenas, and related equine facilities for personal use.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Coverage Details -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Comprehensive Farm Protection</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Our farm owners policies provide extensive coverage tailored to your rural lifestyle.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Property Coverage -->
        <div class="bg-white p-8 rounded-lg shadow-lg">
          <div class="flex items-start mb-4">
            <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Property Coverage</h3>
              <p class="text-gray-600 mb-4">
                Protects your home, barns, stables, and other farm structures from covered perils.
              </p>
              <ul class="text-sm text-gray-600 space-y-2">
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Main dwelling and attached structures
                </li>
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Barns, stables, and outbuildings
                </li>
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Storage sheds and equipment buildings
                </li>
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Fences, gates, and infrastructure
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Liability Coverage -->
        <div class="bg-white p-8 rounded-lg shadow-lg">
          <div class="flex items-start mb-4">
            <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
              <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Liability Protection</h3>
              <p class="text-gray-600 mb-4">
                Covers legal responsibility for injuries or property damage on your farm.
              </p>
              <ul class="text-sm text-gray-600 space-y-2">
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Bodily injury to visitors
                </li>
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Property damage claims
                </li>
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Animal-related incidents
                </li>
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Legal defense costs
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Equipment Coverage -->
        <div class="bg-white p-8 rounded-lg shadow-lg">
          <div class="flex items-start mb-4">
            <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
              <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Farm Equipment & Machinery</h3>
              <p class="text-gray-600 mb-4">
                Covers tractors, mowers, tools, and equipment used on your property.
              </p>
              <ul class="text-sm text-gray-600 space-y-2">
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Tractors and utility vehicles
                </li>
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Lawn and field equipment

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CommercialQuoteForm from '../components/CommercialQuoteForm.astro';
---

<Layout title="Commercial Insurance Quote - PCFG Insurance Services" description="Get a comprehensive commercial insurance quote with our interactive form. Detailed coverage options for general liability, workers' comp, commercial auto, cyber liability, and more.">
  <Header />
  
  <!-- Hero Section -->
  <section class="py-12 bg-gradient-to-br from-navy-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Commercial Insurance Quote</h1>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Get a comprehensive quote tailored to your business needs. Our detailed form ensures we understand your unique risks and coverage requirements.
        </p>
      </div>
    </div>
  </section>
  
  <!-- Quote Form Section -->
  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <CommercialQuoteForm />
    </div>
  </section>
  
  <!-- Why Choose Our Quote Process -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Why Our Quote Process is Different</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          We take the time to understand your business to provide accurate, competitive quotes.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-12 h-12 bg-navy-600 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Comprehensive Assessment</h3>
          <p class="text-gray-600">Our detailed form captures all aspects of your business to ensure proper coverage.</p>
        </div>
        
        <div class="text-center">
          <div class="w-12 h-12 bg-navy-600 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Fast Response</h3>
          <p class="text-gray-600">Receive your detailed quote within 24 hours of submission.</p>
        </div>
        
        <div class="text-center">
          <div class="w-12 h-12 bg-navy-600 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Expert Review</h3>
          <p class="text-gray-600">Our experienced agents personally review every quote for accuracy and completeness.</p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Contact CTA -->
  <section class="py-16 bg-navy-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-white mb-4">Need Help with Your Quote?</h2>
      <p class="text-lg text-navy-100 mb-6 max-w-2xl mx-auto">
        Our insurance experts are here to help. Call us directly or schedule a consultation to discuss your coverage needs.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:877-717-7234" class="bg-white text-navy-600 hover:bg-gray-100 px-6 py-3 rounded-md font-semibold transition-colors duration-200">
          Call (877) 717-7234
        </a>
        <a href="/contact" class="border-2 border-white text-white hover:bg-white hover:text-navy-600 px-6 py-3 rounded-md font-semibold transition-colors duration-200">
          Schedule Consultation
        </a>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Check for URL parameters from lead forms
    const urlParams = new URLSearchParams(window.location.search);
    const businessName = urlParams.get('business-name');
    const email = urlParams.get('email');
    const phone = urlParams.get('phone');
    const insuranceType = urlParams.get('insurance-type');
    const name = urlParams.get('name');
    
    // If we have parameters, pre-fill the form
    if (businessName && email) {
      // Find form fields and pre-fill them
      const businessNameField = document.getElementById('business-name');
      const emailField = document.querySelector('input[type="email"]');
      const phoneField = document.querySelector('input[type="tel"]');
      
      if (businessNameField) businessNameField.value = businessName;
      if (emailField) emailField.value = email;
      if (phoneField) phoneField.value = phone;
      
      // If we have a name, try to split it into first and last name
      if (name) {
        const nameParts = name.split(' ');
        if (nameParts.length >= 2) {
          const firstName = nameParts[0];
          const lastName = nameParts.slice(1).join(' ');
          
          const firstNameField = document.getElementById('first-name');
          const lastNameField = document.getElementById('last-name');
          
          if (firstNameField) firstNameField.value = firstName;
          if (lastNameField) lastNameField.value = lastName;
        }
      }
      
      // If we have an insurance type, select it in the form
      if (insuranceType) {
        const insuranceTypeCheckboxes = document.querySelectorAll('input[name="insurance-types"]');
        insuranceTypeCheckboxes.forEach(checkbox => {
          if (checkbox.value === insuranceType) {
            checkbox.checked = true;
            // Trigger change event to update conditional sections
            const event = new Event('change');
            checkbox.dispatchEvent(event);
          }
        });
      }
    }
  });
</script>
---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AccessibilityStatement from '../components/AccessibilityStatement.astro';
import AccessibilityToolbar from '../components/AccessibilityToolbar.astro';
---

<Layout title="Accessibility Statement - PCFG Insurance Services" description="PCFG Insurance Services accessibility statement and commitment to digital inclusion. Learn about our accessibility features and how to request assistance.">
  <Header />
  <AccessibilityToolbar />
  
  <main id="main-content">
    <!-- Hero Section -->
    <section class="py-20 bg-gradient-to-br from-primary-50 to-white" role="banner">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">Accessibility Statement</h1>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto max-w-none">
            Our commitment to making our website accessible to all users, including those with disabilities.
          </p>
        </div>
      </div>
    </section>
    
    <!-- Accessibility Statement Content -->
    <section class="py-20" role="main">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <AccessibilityStatement />
      </div>
    </section>
    
    <!-- Accessibility Tools Demo -->
    <section class="py-20 bg-gray-50" role="region" aria-labelledby="tools-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 id="tools-heading" class="text-3xl font-bold text-gray-900 mb-4">Accessibility Tools</h2>
          <p class="text-xl text-gray-600 max-w-none">
            Use the accessibility button in the bottom right corner to access these features:
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-white p-6 rounded-lg shadow-lg">
            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 100 4m0-4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 100 4m0-4v2m0-6V4"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Text Size Control</h3>
            <p class="text-gray-600">Increase or decrease text size from 80% to 150% for comfortable reading.</p>
          </div>
          
          <div class="bg-white p-6 rounded-lg shadow-lg">
            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h4a2 2 0 002-2V9a2 2 0 00-2-2H7a2 2 0 00-2 2v6a2 2 0 002 2z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">High Contrast Mode</h3>
            <p class="text-gray-600">Toggle high contrast colors for better visibility and reduced eye strain.</p>
          </div>
          
          <div class="bg-white p-6 rounded-lg shadow-lg">
            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Dyslexia-Friendly Font</h3>
            <p class="text-gray-600">Switch to fonts and spacing optimized for users with dyslexia.</p>
          </div>
          
          <div class="bg-white p-6 rounded-lg shadow-lg">
            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Reading Guide</h3>
            <p class="text-gray-600">Visual reading guide that follows your mouse to help focus on current line.</p>
          </div>
          
          <div class="bg-white p-6 rounded-lg shadow-lg">
            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Keyboard Navigation</h3>
            <p class="text-gray-600">Full keyboard support with visible focus indicators and skip links.</p>
          </div>
          
          <div class="bg-white p-6 rounded-lg shadow-lg">
            <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Screen Reader Support</h3>
            <p class="text-gray-600">Optimized for NVDA, JAWS, and VoiceOver screen readers with proper ARIA labels.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
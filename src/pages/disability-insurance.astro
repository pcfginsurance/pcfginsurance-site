<script>
  document.addEventListener('DOMContentLoaded', function() {
    const calculateBtn = document.getElementById('calculate-disability-btn') as HTMLButtonElement;
    if (calculateBtn) {
      calculateBtn.addEventListener('click', calculateDisabilityBenefit);
    }
  });

  function calculateDisabilityBenefit() {
    const annualIncome = parseFloat((document.getElementById('annual-income') as HTMLInputElement)?.value || "0");
    const benefitPercentage = parseFloat((document.getElementById('benefit-percentage') as HTMLSelectElement)?.value || "0.6");
    const disabilityMonths = parseInt((document.getElementById('disability-months') as HTMLInputElement)?.value || "12");

    if (annualIncome > 0 && disabilityMonths > 0) {
      const monthlyIncome = annualIncome / 12;
      const monthlyBenefit = monthlyIncome * benefitPercentage;
      const totalBenefit = monthlyBenefit * disabilityMonths;

      document.getElementById('monthly-benefit')!.textContent =
        new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 })
        .format(monthlyBenefit);

      document.getElementById('months-display')!.textContent = disabilityMonths.toString();

      document.getElementById('total-benefit')!.textContent =
        new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 })
        .format(totalBenefit);

      document.getElementById('disability-calculation-result')!.classList.remove('hidden');
    } else {
      alert('Please enter your annual income and months of disability.');
    }
  }
</script>

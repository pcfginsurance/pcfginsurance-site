---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Life Insurance & Financial Solutions - PCFG Insurance Services" description="Comprehensive life insurance, annuities, infinite banking, and ancillary health products including critical illness, cancer insurance, and disability coverage for individuals and businesses.">
  <Header />
  
  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-br from-navy-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">Life Insurance & Financial Solutions</h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Comprehensive life insurance, financial planning, and health protection solutions to secure your family's future and protect against life's unexpected challenges.
        </p>
      </div>
      
      <!-- Quick Quote CTA -->
      <div class="max-w-2xl mx-auto bg-white p-8 rounded-lg shadow-lg">
        <h2 class="text-2xl font-bold text-gray-900 mb-6 text-center">Get Your Life Insurance Quote</h2>
        <form id="quick-quote-form" class="space-y-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Full Name *</label>
              <input type="text" id="name" name="name" required class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent">
            </div>
            
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address *</label>
              <input type="email" id="email" name="email" required class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent">
            </div>
            
            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone Number *</label>
              <input type="tel" id="phone" name="phone" required class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent">
            </div>
            
            <div>
              <label for="coverage-type" class="block text-sm font-medium text-gray-700 mb-1">Type of Coverage *</label>
              <select id="coverage-type" name="coverage-type" required class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent">
                <option value="">Select Coverage Type</option>
                <option value="term-life">Term Life Insurance</option>
                <option value="permanent-life">Permanent Life Insurance</option>
                <option value="not-sure">Not Sure - Need Guidance</option>
              </select>
            </div>
          </div>
          
          <button type="submit" class="w-full bg-navy-600 hover:bg-navy-700 text-white font-semibold py-3 px-4 rounded-md transition-colors duration-200">
            Get Detailed Quote
          </button>
        </form>
      </div>
    </div>
  </section>
  
  <!-- Life Insurance Types -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Term Life Insurance -->
      <div id="term-life" class="mb-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-3xl font-bold text-gray-900 mb-6">Term Life Insurance</h2>
            <p class="text-lg text-gray-600 mb-6">
              Affordable, temporary life insurance protection for a specific period. Perfect for covering mortgages, income replacement, and protecting your family during critical earning years.
            </p>
            <div class="mb-6">
              <h3 class="text-xl font-semibold text-gray-900 mb-3">Term Options:</h3>
              <ul class="space-y-3 text-gray-600">
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span><strong>10-Year Term:</strong> Short-term protection with lowest premiums</span>
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span><strong>20-Year Term:</strong> Most popular option for families with children</span>
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span><strong>30-Year Term:</strong> Extended protection through retirement years</span>
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span><strong>Return of Premium:</strong> Get your premiums back if you outlive the term</span>
                </li>
              </ul>
            </div>
            <a href="/life-insurance-quote" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200">
              Get Term Life Quote
            </a>
          </div>
          <div class="bg-gray-100 p-8 rounded-lg">
            <div class="w-16 h-16 bg-navy-600 rounded-lg flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
              </svg>
            </div>
            <h4 class="text-xl font-semibold text-gray-900 mb-4">Life Insurance Calculator</h4>
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Annual Income</label>
                <input type="number" id="annual-income" class="w-full px-3 py-2 border border-gray-300 rounded-md" placeholder="$50,000">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Years of Coverage</label>
                <select id="coverage-years" class="w-full px-3 py-2 border border-gray-300 rounded-md">
                  <option value="10">10 years</option>
                  <option value="15">15 years</option>
                  <option value="20" selected>20 years</option>
                  <option value="25">25 years</option>
                  <option value="30">30 years</option>
                </select>
              </div>
              <button type="button" onclick="calculateLifeInsurance()" class="w-full bg-navy-600 hover:bg-navy-700 text-white px-4 py-2 rounded-md font-medium transition-colors duration-200">
                Calculate Needed Coverage
              </button>
              <div id="calculation-result" class="hidden p-4 bg-white rounded border-l-4 border-navy-600">
                <p class="text-sm text-gray-600">Recommended coverage: <span id="recommended-amount" class="font-semibold text-navy-600"></span></p>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Permanent Life Insurance -->
      <div id="permanent-life" class="mb-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="bg-gray-100 p-8 rounded-lg order-2 lg:order-1">
            <div class="w-16 h-16 bg-navy-600 rounded-lg flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
            </div>
            <h4 class="text-xl font-semibold text-gray-900 mb-4">Cash Value Benefits</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• Tax-deferred cash value growth</li>
              <li>• Policy loans available</li>
              <li>• Flexible premium payments</li>
              <li>• Dividend potential (whole life)</li>
              <li>• Investment options (universal life)</li>
              <li>• Estate planning benefits</li>
            </ul>
            <div class="mt-6 p-4 bg-white rounded border-l-4 border-navy-600">
              <p class="text-sm text-gray-600">
                <strong>Living Benefits:</strong> Access cash value for emergencies, opportunities, or retirement income.
              </p>
            </div>
          </div>
          <div class="order-1 lg:order-2">
            <h2 class="text-3xl font-bold text-gray-900 mb-6">Permanent Life Insurance</h2>
            <p class="text-lg text-gray-600 mb-6">
              Lifelong protection with cash value accumulation. Build wealth while protecting your family with policies that combine insurance and investment features.
            </p>
            <div class="mb-6">
              <h3 class="text-xl font-semibold text-gray-900 mb-3">Permanent Options:</h3>
              <div class="space-y-4">
                <div class="border-l-4 border-navy-600 pl-4">
                  <h4 class="font-semibold text-gray-900">Whole Life Insurance</h4>
                  <p class="text-gray-600">Fixed premiums, guaranteed cash value growth, potential dividends</p>
                </div>
                <div class="border-l-4 border-navy-600 pl-4">
                  <h4 class="font-semibold text-gray-900">Universal Life Insurance</h4>
                  <p class="text-gray-600">Flexible premiums, adjustable death benefits, market-based returns</p>
                </div>
                <div class="border-l-4 border-navy-600 pl-4">
                  <h4 class="font-semibold text-gray-900">Variable Life Insurance</h4>
                  <p class="text-gray-600">Investment control, higher growth potential, market risk</p>
                </div>
                <div class="border-l-4 border-navy-600 pl-4">
                  <h4 class="font-semibold text-gray-900">Indexed Universal Life</h4>
                  <p class="text-gray-600">Market upside with downside protection, flexible features</p>
                </div>
              </div>
            </div>
            <a href="/life-insurance-quote" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200">
              Get Permanent Life Quote
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Ancillary Health Products -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Ancillary Health Protection Products</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Supplemental insurance products that provide additional financial protection for specific health events and conditions not fully covered by traditional health insurance.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        
        <!-- Critical Illness Insurance -->
        <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-16 h-16 bg-red-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Critical Illness Insurance</h3>
          <p class="text-gray-600 mb-6">
            Lump-sum cash benefit upon diagnosis of covered critical illnesses like heart attack, stroke, cancer, or kidney failure.
          </p>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-3">Covered Conditions:</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• Heart attack and coronary artery disease</li>
              <li>• Stroke and paralysis</li>
              <li>• Cancer (various types and stages)</li>
              <li>• Kidney failure requiring dialysis</li>
              <li>• Major organ transplants</li>
              <li>• Alzheimer's disease and dementia</li>
              <li>• Multiple sclerosis</li>
              <li>• Parkinson's disease</li>
            </ul>
          </div>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-3">Key Benefits:</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• Lump-sum cash payment</li>
              <li>• Use funds for any purpose</li>
              <li>• Covers treatment costs and living expenses</li>
              <li>• No network restrictions</li>
              <li>• Portable coverage</li>
            </ul>
          </div>
          
          <a href="/contact" class="bg-red-600 hover:bg-red-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200 w-full block text-center">
            Get Critical Illness Quote
          </a>
        </div>
        
        <!-- Cancer Insurance -->
        <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-16 h-16 bg-purple-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Cancer Insurance</h3>
          <p class="text-gray-600 mb-6">
            Specialized coverage designed specifically for cancer diagnosis and treatment, providing cash benefits for various cancer-related expenses.
          </p>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-3">Coverage Benefits:</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• Initial diagnosis benefit</li>
              <li>• Chemotherapy and radiation benefits</li>
              <li>• Surgery and hospitalization</li>
              <li>• Prescription drug coverage</li>
              <li>• Transportation and lodging</li>
              <li>• Experimental treatment coverage</li>
              <li>• Wellness and screening benefits</li>
              <li>• Family member benefits</li>
            </ul>
          </div>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-3">Plan Features:</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• No waiting period for accidents</li>
              <li>• Covers all types of cancer</li>
              <li>• Renewable for life</li>
              <li>• Worldwide coverage</li>
              <li>• Direct payment to providers</li>
            </ul>
          </div>
          
          <a href="/contact" class="bg-purple-600 hover:bg-purple-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200 w-full block text-center">
            Get Cancer Insurance Quote
          </a>
        </div>
        
        <!-- Disability Insurance -->
        <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-16 h-16 bg-blue-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Disability Insurance</h3>
          <p class="text-gray-600 mb-6">
            Income protection when you can't work due to illness or injury. Replace a portion of your income to maintain your lifestyle and financial obligations.
          </p>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-3">Coverage Types:</h4>
            <div class="space-y-4">
              <div class="border-l-4 border-blue-600 pl-4">
                <h5 class="font-semibold text-gray-900">Short-Term Disability</h5>
                <p class="text-gray-600">3-12 months of income replacement</p>
              </div>
              <div class="border-l-4 border-blue-600 pl-4">
                <h5 class="font-semibold text-gray-900">Long-Term Disability</h5>
                <p class="text-gray-600">Extended coverage until retirement age</p>
              </div>
            </div>
          </div>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-3">Key Features:</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• Own occupation coverage</li>
              <li>• Partial disability benefits</li>
              <li>• Cost of living adjustments</li>
              <li>• Future increase options</li>
              <li>• Residual benefits</li>
              <li>• Rehabilitation benefits</li>
            </ul>
          </div>
          
          <a href="/contact" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200 w-full block text-center">
            Get Disability Quote
          </a>
        </div>
        
        <!-- Accident Insurance -->
        <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-16 h-16 bg-orange-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Accident Insurance</h3>
          <p class="text-gray-600 mb-6">
            Cash benefits for covered accidents, helping with out-of-pocket expenses, deductibles, and other costs not covered by health insurance.
          </p>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-3">Covered Events:</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• Emergency room treatment</li>
              <li>• Fractures and dislocations</li>
              <li>• Burns and lacerations</li>
              <li>• Concussions and head injuries</li>
              <li>• Ambulance services</li>
              <li>• Hospital confinement</li>
              <li>• Surgery and anesthesia</li>
              <li>• Physical therapy</li>
            </ul>
          </div>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-3">Benefits:</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• Fixed cash payments</li>
              <li>• No deductibles or copays</li>
              <li>• Use funds for any purpose</li>
              <li>• 24/7 worldwide coverage</li>
              <li>• Family coverage available</li>
            </ul>
          </div>
          
          <a href="/contact" class="bg-orange-600 hover:bg-orange-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200 w-full block text-center">
            Get Accident Insurance Quote
          </a>
        </div>
        
        <!-- Hospital Indemnity -->
        <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-16 h-16 bg-green-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Hospital Indemnity</h3>
          <p class="text-gray-600 mb-6">
            Daily cash benefits for hospital stays, helping cover deductibles, copays, and other expenses while you focus on recovery.
          </p>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-3">Coverage Benefits:</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• Daily hospital confinement benefit</li>
              <li>• ICU daily benefit (higher amount)</li>
              <li>• Outpatient surgery benefit</li>
              <li>• Emergency room benefit</li>
              <li>• Ambulance benefit</li>
              <li>• Diagnostic testing benefit</li>
              <li>• Physician visit benefit</li>
              <li>• Prescription drug benefit</li>
            </ul>
          </div>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-3">Plan Options:</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• Individual and family coverage</li>
              <li>• Various benefit amounts</li>
              <li>• No waiting periods for accidents</li>
              <li>• Guaranteed renewable</li>
              <li>• Worldwide coverage</li>
            </ul>
          </div>
          
          <a href="/contact" class="bg-green-600 hover:bg-green-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200 w-full block text-center">
            Get Hospital Indemnity Quote
          </a>
        </div>
        
        <!-- Dental & Vision -->
        <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-16 h-16 bg-indigo-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Individual Dental & Vision</h3>
          <p class="text-gray-600 mb-6">
            Affordable individual and family dental and vision coverage to supplement your health insurance or provide standalone protection.
          </p>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-3">Dental Coverage:</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• Preventive care (cleanings, exams)</li>
              <li>• Basic procedures (fillings, extractions)</li>
              <li>• Major procedures (crowns, bridges)</li>
              <li>• Orthodontic coverage options</li>
              <li>• No waiting periods on preventive</li>
              <li>• Large provider networks</li>
            </ul>
          </div>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-3">Vision Coverage:</h4>

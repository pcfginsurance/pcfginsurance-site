<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Quick quote form handler
    const quickQuoteForm = document.getElementById('quick-quote-form') as HTMLFormElement;
    
    if (quickQuoteForm) {
      quickQuoteForm.addEventListener('submit', function(e) {
        e.preventDefault();
        
        const formData = new FormData(quickQuoteForm);
        const data = Object.fromEntries(formData);
        
        // Store the data in localStorage to pre-populate the detailed form
        localStorage.setItem('lifeInsuranceQuickQuote', JSON.stringify(data));
        
        // Redirect to the detailed quote form
        window.location.href = '/life-insurance-quote';
      });
    }
  });

  function calculateLifeInsurance() {
    const annualIncome = parseFloat((document.getElementById('annual-income') as HTMLInputElement)?.value || "0");
    const coverageYears = parseInt((document.getElementById('coverage-years') as HTMLInputElement)?.value || "10");
    
    if (annualIncome > 0) {
      // Rule of thumb: 10-12 times annual income, adjusted for years of coverage needed
      const multiplier = coverageYears <= 15 ? 8 : coverageYears <= 25 ? 10 : 12;
      const recommendedAmount = annualIncome * multiplier;
      
      document.getElementById('recommended-amount').textContent = 
        new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 })
        .format(recommendedAmount);
      
      document.getElementById('calculation-result').classList.remove('hidden');
    } else {
      alert('Please enter your annual income to calculate coverage needs.');
    }
  }
</script>
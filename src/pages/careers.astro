---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Careers - PCFG Insurance Services" description="Join our team at PCFG Insurance Services. Explore current job openings and learn about our company culture, benefits, and growth opportunities." ogImage="https://images.pexels.com/photos/3184292/pexels-photo-3184292.jpeg?auto=compress&cs=tinysrgb&w=1200&h=630" ogType="website">
  <Header />
  
  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-br from-navy-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">Join Our Team</h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Build your career with a growing insurance agency that values integrity, service, and excellence. Explore opportunities across our 15 licensed states.
        </p>
      </div>
    </div>
  </section>
  
  <!-- Why Work With Us -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Why Work With PCFG Insurance?</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          We're building something special, and we're looking for talented individuals to join us on this journey.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Growth Opportunities</h3>
          <p class="text-gray-600">Expand your skills and advance your career with our growing agency across 15 states.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Supportive Culture</h3>
          <p class="text-gray-600">Work in a collaborative environment where your contributions are valued and recognized.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Competitive Benefits</h3>
          <p class="text-gray-600">Enjoy comprehensive benefits including health insurance, retirement plans, and professional development.</p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Current Openings -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Current Openings</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Explore our current job opportunities and find the perfect fit for your skills and career goals.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Insurance Sales Producer -->
        <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="flex justify-between items-start mb-4">
            <h3 class="text-2xl font-semibold text-gray-900">Insurance Sales Producer</h3>
            <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded">Full-Time</span>
          </div>
          <div class="mb-4">
            <span class="text-gray-600 flex items-center">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              Remote (Multiple States)
            </span>
          </div>
          <p class="text-gray-600 mb-6">
            We're seeking motivated insurance sales professionals to join our growing team. In this role, you'll develop new business opportunities and build relationships with clients across multiple states.
          </p>
          <div class="mb-6">
            <h4 class="font-semibold text-gray-900 mb-2">Key Responsibilities:</h4>
            <ul class="list-disc list-inside text-gray-600 space-y-1">
              <li>Generate and qualify new business leads</li>
              <li>Conduct needs analyses for prospective clients</li>
              <li>Develop and present insurance proposals</li>
              <li>Build and maintain client relationships</li>
              <li>Meet or exceed sales goals</li>
            </ul>
          </div>
          <div class="mb-6">
            <h4 class="font-semibold text-gray-900 mb-2">Requirements:</h4>
            <ul class="list-disc list-inside text-gray-600 space-y-1">
              <li>Property & Casualty license (or ability to obtain)</li>
              <li>1+ years of insurance sales experience preferred</li>
              <li>Strong communication and relationship-building skills</li>
              <li>Self-motivated with a proven track record of success</li>
              <li>Ability to work independently and as part of a team</li>
            </ul>
          </div>
          <a href="#application-form" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-2 rounded-md font-medium transition-colors duration-200 inline-block">
            Apply Now
          </a>
        </div>
        
        <!-- Life & Health Insurance Rep -->
        <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="flex justify-between items-start mb-4">
            <h3 class="text-2xl font-semibold text-gray-900">Life & Health Insurance Rep</h3>
            <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded">Full-Time</span>
          </div>
          <div class="mb-4">
            <span class="text-gray-600 flex items-center">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              Remote (Multiple States)
            </span>
          </div>
          <p class="text-gray-600 mb-6">
            Join our team as a Life & Health Insurance Representative to help clients secure their financial future and protect their health. You'll provide expert guidance on life insurance, health plans, and related products.
          </p>
          <div class="mb-6">
            <h4 class="font-semibold text-gray-900 mb-2">Key Responsibilities:</h4>
            <ul class="list-disc list-inside text-gray-600 space-y-1">
              <li>Consult with clients on life and health insurance needs</li>
              <li>Conduct thorough needs analyses and financial reviews</li>
              <li>Present appropriate insurance solutions</li>
              <li>Guide clients through application and underwriting</li>
              <li>Provide ongoing service and policy reviews</li>
            </ul>
          </div>
          <div class="mb-6">
            <h4 class="font-semibold text-gray-900 mb-2">Requirements:</h4>
            <ul class="list-disc list-inside text-gray-600 space-y-1">
              <li>Life & Health insurance license (or ability to obtain)</li>
              <li>2+ years of life/health insurance sales experience preferred</li>
              <li>Strong understanding of insurance products and underwriting</li>
              <li>Excellent communication and interpersonal skills</li>
              <li>Commitment to ethical sales practices and client service</li>
            </ul>
          </div>
          <a href="#application-form" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-2 rounded-md font-medium transition-colors duration-200 inline-block">
            Apply Now
          </a>
        </div>
        
        <!-- Commercial Lines Account Manager -->
        <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="flex justify-between items-start mb-4">
            <h3 class="text-2xl font-semibold text-gray-900">Commercial Lines Account Manager</h3>
            <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded">Full-Time</span>
          </div>
          <div class="mb-4">
            <span class="text-gray-600 flex items-center">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              Remote (Multiple States)
            </span>
          </div>
          <p class="text-gray-600 mb-6">
            We're looking for an experienced Commercial Lines Account Manager to handle a book of business and provide exceptional service to our commercial clients.
          </p>
          <div class="mb-6">
            <h4 class="font-semibold text-gray-900 mb-2">Key Responsibilities:</h4>
            <ul class="list-disc list-inside text-gray-600 space-y-1">
              <li>Manage a book of commercial insurance clients</li>
              <li>Process renewals, endorsements, and policy changes</li>
              <li>Conduct coverage reviews and make recommendations</li>
              <li>Assist with claims reporting and resolution</li>
              <li>Maintain client relationships and provide exceptional service</li>
            </ul>
          </div>
          <div class="mb-6">
            <h4 class="font-semibold text-gray-900 mb-2">Requirements:</h4>
            <ul class="list-disc list-inside text-gray-600 space-y-1">
              <li>Active Property & Casualty license</li>
              <li>3+ years of commercial lines experience</li>
              <li>Strong knowledge of commercial insurance products</li>
              <li>Experience with agency management systems</li>
              <li>Excellent communication and organizational skills</li>
            </ul>
          </div>
          <a href="#application-form" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-2 rounded-md font-medium transition-colors duration-200 inline-block">
            Apply Now
          </a>
        </div>
        
        <!-- Employee Benefits Rep -->
        <div class="bg-white p-8 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="flex justify-between items-start mb-4">
            <h3 class="text-2xl font-semibold text-gray-900">Employee Benefits Rep</h3>
            <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded">Full-Time</span>
          </div>
          <div class="mb-4">
            <span class="text-gray-600 flex items-center">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              Remote (Multiple States)
            </span>
          </div>
          <p class="text-gray-600 mb-6">
            We're seeking an experienced Employee Benefits Representative to help businesses design and implement comprehensive benefits packages for their employees. You'll be a key advisor in helping companies attract and retain talent.
          </p>
          <div class="mb-6">
            <h4 class="font-semibold text-gray-900 mb-2">Key Responsibilities:</h4>
            <ul class="list-disc list-inside text-gray-600 space-y-1">
              <li>Consult with businesses on employee benefits strategies</li>
              <li>Design custom benefits packages (health, dental, vision, life)</li>
              <li>Analyze client needs and recommend appropriate solutions</li>
              <li>Coordinate with carriers for quotes and plan implementation</li>
              <li>Provide ongoing service and annual plan reviews</li>
            </ul>
          </div>
          <div class="mb-6">
            <h4 class="font-semibold text-gray-900 mb-2">Requirements:</h4>
            <ul class="list-disc list-inside text-gray-600 space-y-1">
              <li>Life & Health insurance license</li>
              <li>3+ years of employee benefits experience</li>
              <li>Strong knowledge of group health plans and ACA requirements</li>
              <li>Experience with benefits administration platforms</li>
              <li>Excellent presentation and communication skills</li>
            </ul>
          </div>
          <a href="#application-form" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-2 rounded-md font-medium transition-colors duration-200 inline-block">
            Apply Now
          </a>
        </div>
      </div>
      
      <!-- No Openings Message (Hidden by default) -->
      <div id="no-openings" class="hidden bg-white p-8 rounded-lg shadow-lg text-center">
        <svg class="w-16 h-16 text-navy-600 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <h3 class="text-2xl font-semibold text-gray-900 mb-4">No Current Openings</h3>
        <p class="text-gray-600 mb-6">
          We don't have any open positions at the moment, but we're always looking for talented individuals to join our team. Submit your resume for future consideration.
        </p>
        <a href="#application-form" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-2 rounded-md font-medium transition-colors duration-200 inline-block">
          Submit Your Resume
        </a>
      </div>
    </div>
  </section>

  <!-- Application Form Section -->
  <section id="application-form" class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Submit Your Application</h2>
        <p class="text-xl text-gray-600">
          Please fill out the form below to apply for a position with PCFG Insurance Services.
        </p>
      </div>
      <div class="bg-gray-50 p-4 rounded-xl shadow-inner">
        <iframe class="airtable-embed" src="https://airtable.com/embed/appraT71zGRnhgNmH/pagbJbleP4SkiopEh/form" frameborder="0" width="100%" height="533" style="background: transparent; border: 1px solid #ccc;"></iframe>
      </div>
    </div>
  </section>
  
  <!-- Benefits Section -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Employee Benefits</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          We believe in taking care of our team members with competitive benefits and a supportive work environment.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Health & Wellness</h3>
          <ul class="text-gray-600 space-y-2">
            <li>• Health insurance (accessible, agent paid)</li>
            <li>• Dental and vision coverage (accessible, agent paid)</li>
            <li>• Life insurance</li>
            <li>• Disability insurance</li>
            <li>• Wellness program</li>
          </ul>
        </div>
        
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Financial Benefits</h3>
          <ul class="text-gray-600 space-y-2">
            <li>• Competitive compensation</li>
            <li>• Performance bonuses</li>
            <li>• Commission opportunities</li>
            <li>• Profit sharing</li>
          </ul>
        </div>
        
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Work-Life Balance</h3>
          <ul class="text-gray-600 space-y-2">
            <li>• Flexible work schedules</li>
            <li>• Remote work options</li>
            <li>• Paid time off</li>
            <li>• Paid holidays</li>
            <li>• Parental leave</li>
          </ul>
        </div>
        
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Professional Development</h3>
          <ul class="text-gray-600 space-y-2">
            <li>• Continuing education</li>
            <li>• License renewal assistance</li>
            <li>• Industry certifications</li>
            <li>• Mentorship program</li>
            <li>• Career advancement opportunities</li>
          </ul>
        </div>
        
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Team Building</h3>
          <ul class="text-gray-600 space-y-2">
            <li>• Company events</li>
            <li>• Team celebrations</li>
            <li>• Recognition programs</li>
            <li>• Community service opportunities</li>
            <li>• Collaborative work environment</li>
          </ul>
        </div>
        
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Additional Perks</h3>
          <ul class="text-gray-600 space-y-2">
            <li>• Employee discounts on insurance</li>
            <li>• Modern technology and tools</li>
            <li>• Casual dress code</li>
            <li>• Referral bonuses</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Our Culture -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Our Culture</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          At PCFG Insurance Services, we foster a culture of collaboration, integrity, and excellence.
        </p>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-6">What Makes Us Different</h3>
          <div class="space-y-4">
            <div class="flex items-start">
              <div class="flex-shrink-0">
                <svg class="w-5 h-5 text-navy-600 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <div class="ml-3">
                <h4 class="text-lg font-medium text-gray-900">Veteran-Owned</h4>
                <p class="text-gray-600">Our military values of service, integrity, and excellence guide everything we do.</p>
              </div>
            </div>
            <div class="flex items-start">
              <div class="flex-shrink-0">

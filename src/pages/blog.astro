---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Insurance Blog - PCFG Insurance Services" description="Expert insights on business insurance, risk management, and employee benefits. Stay informed with the latest insurance news and tips from PCFG Insurance Services.">
  <Header />
  
  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-br from-navy-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">Insurance Insights & Tips</h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Stay informed with expert advice on business insurance, risk management, and protecting what matters most.
        </p>
      </div>
    </div>
  </section>
  
  <!-- Featured Article -->
  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-lg shadow-lg overflow-hidden">
        <div class="md:flex">
          <div class="md:w-1/2">
            <img src="https://images.pexels.com/photos/3184465/pexels-photo-3184465.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Business insurance planning" class="w-full h-64 md:h-full object-cover" loading="lazy" width="800" height="600">
          </div>
          <div class="md:w-1/2 p-8">
            <div class="text-sm text-navy-600 font-semibold mb-2">FEATURED ARTICLE</div>
            <h2 class="text-2xl font-bold text-gray-900 mb-4">The Complete Guide to Workers' Compensation for Small Businesses</h2>
            <p class="text-gray-600 mb-6">
              Understanding workers' compensation requirements, costs, and benefits is crucial for every business owner. Learn how to protect your employees and your business with the right coverage.
            </p>
            <div class="flex items-center text-sm text-gray-500 mb-4">
              <span>January 15, 2024</span>
              <span class="mx-2">•</span>
              <span>8 min read</span>
            </div>
            <a href="#" class="text-navy-600 hover:text-navy-700 font-semibold">Read Full Article →</a>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Blog Posts Grid -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        
        <!-- Blog Post 1 -->
        <article class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-200">
          <img src="https://images.pexels.com/photos/3184292/pexels-photo-3184292.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Cyber security" class="w-full h-48 object-cover">
          <div class="p-6">
            <div class="text-sm text-navy-600 font-semibold mb-2">CYBER SECURITY</div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Why Every Small Business Needs Cyber Liability Insurance</h3>
            <p class="text-gray-600 mb-4">
              Cyber attacks on small businesses are increasing. Learn how cyber liability insurance can protect your business from data breaches and cyber threats.
            </p>
            <div class="flex items-center justify-between text-sm text-gray-500">
              <span>January 10, 2024</span>
              <span>5 min read</span>
            </div>
          </div>
        </article>
        
        <!-- Blog Post 2 -->
        <article class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-200">
          <img src="https://images.pexels.com/photos/3184339/pexels-photo-3184339.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Employee benefits" class="w-full h-48 object-cover">
          <div class="p-6">
            <div class="text-sm text-navy-600 font-semibold mb-2">EMPLOYEE BENEFITS</div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">How to Design Employee Benefits That Attract Top Talent</h3>
            <p class="text-gray-600 mb-4">
              Competitive employee benefits are essential for attracting and retaining quality employees. Discover what benefits matter most to today's workforce.
            </p>
            <div class="flex items-center justify-between text-sm text-gray-500">
              <span>January 5, 2024</span>
              <span>6 min read</span>
            </div>
          </div>
        </article>
        
        <!-- Blog Post 3 -->
        <article class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-200">
          <img src="https://images.pexels.com/photos/3184360/pexels-photo-3184360.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Construction safety" class="w-full h-48 object-cover">
          <div class="p-6">
            <div class="text-sm text-navy-600 font-semibold mb-2">CONSTRUCTION</div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Construction Insurance: Essential Coverage for Contractors</h3>
            <p class="text-gray-600 mb-4">
              Construction projects involve unique risks. Learn about the essential insurance coverages every contractor needs to protect their business.
            </p>
            <div class="flex items-center justify-between text-sm text-gray-500">
              <span>December 28, 2023</span>
              <span>7 min read</span>
            </div>
          </div>
        </article>
        
        <!-- Blog Post 4 -->
        <article class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-200">
          <img src="https://images.pexels.com/photos/3184418/pexels-photo-3184418.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Business liability" class="w-full h-48 object-cover">
          <div class="p-6">
            <div class="text-sm text-navy-600 font-semibold mb-2">LIABILITY</div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Understanding General Liability Insurance: What's Covered and What's Not</h3>
            <p class="text-gray-600 mb-4">
              General liability insurance is fundamental for most businesses, but understanding what's covered can be confusing. Get the facts here.
            </p>
            <div class="flex items-center justify-between text-sm text-gray-500">
              <span>December 20, 2023</span>
              <span>5 min read</span>
            </div>
          </div>
        </article>
        
        <!-- Blog Post 5 -->
        <article class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-200">
          <img src="https://images.pexels.com/photos/3184454/pexels-photo-3184454.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Risk management" class="w-full h-48 object-cover">
          <div class="p-6">
            <div class="text-sm text-navy-600 font-semibold mb-2">RISK MANAGEMENT</div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">5 Risk Management Strategies Every Business Owner Should Know</h3>
            <p class="text-gray-600 mb-4">
              Effective risk management goes beyond insurance. Discover proactive strategies to identify, assess, and mitigate business risks.
            </p>
            <div class="flex items-center justify-between text-sm text-gray-500">
              <span>December 15, 2023</span>
              <span>8 min read</span>
            </div>
          </div>
        </article>
        
        <!-- Blog Post 6 -->
        <article class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-200">
          <img src="https://images.pexels.com/photos/3184291/pexels-photo-3184291.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Commercial auto" class="w-full h-48 object-cover">
          <div class="p-6">
            <div class="text-sm text-navy-600 font-semibold mb-2">COMMERCIAL AUTO</div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Commercial Auto Insurance: Protecting Your Business Fleet</h3>
            <p class="text-gray-600 mb-4">
              Whether you have one vehicle or a large fleet, commercial auto insurance is essential. Learn about coverage options and cost-saving strategies.
            </p>
            <div class="flex items-center justify-between text-sm text-gray-500">
              <span>December 10, 2023</span>
              <span>6 min read</span>
            </div>
          </div>
        </article>
        
        <!-- Blog Post 7 -->
        <article class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-200">
          <img src="https://images.pexels.com/photos/3184287/pexels-photo-3184287.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Professional liability" class="w-full h-48 object-cover">
          <div class="p-6">
            <div class="text-sm text-navy-600 font-semibold mb-2">PROFESSIONAL LIABILITY</div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Professional Liability Insurance: Do You Need It?</h3>
            <p class="text-gray-600 mb-4">
              Professional liability insurance protects against claims of errors and omissions. Find out if your business needs this important coverage.
            </p>
            <div class="flex items-center justify-between text-sm text-gray-500">
              <span>December 5, 2023</span>
              <span>4 min read</span>
            </div>
          </div>
        </article>
        
        <!-- Blog Post 8 -->
        <article class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-200">
          <img src="https://images.pexels.com/photos/3184317/pexels-photo-3184317.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Business interruption" class="w-full h-48 object-cover">
          <div class="p-6">
            <div class="text-sm text-navy-600 font-semibold mb-2">BUSINESS CONTINUITY</div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Business Interruption Insurance: Protecting Your Revenue</h3>
            <p class="text-gray-600 mb-4">
              When disaster strikes, business interruption insurance can help replace lost income. Learn how this coverage works and why it's important.
            </p>
            <div class="flex items-center justify-between text-sm text-gray-500">
              <span>November 30, 2023</span>
              <span>7 min read</span>
            </div>
          </div>
        </article>
        
        <!-- Blog Post 9 -->
        <article class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-200">
          <img src="https://images.pexels.com/photos/3184325/pexels-photo-3184325.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Insurance claims" class="w-full h-48 object-cover">
          <div class="p-6">
            <div class="text-sm text-navy-600 font-semibold mb-2">CLAIMS</div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">How to File an Insurance Claim: A Step-by-Step Guide</h3>
            <p class="text-gray-600 mb-4">
              Filing an insurance claim can be stressful. Our step-by-step guide helps you navigate the process and get the best outcome.
            </p>
            <div class="flex items-center justify-between text-sm text-gray-500">
              <span>November 25, 2023</span>
              <span>5 min read</span>
            </div>
          </div>
        </article>
      </div>
      
      <!-- Load More Button -->
      <div class="text-center mt-12">
        <button class="bg-navy-600 hover:bg-navy-700 text-white px-8 py-3 rounded-md font-semibold transition-colors duration-200">
          Load More Articles
        </button>
      </div>
    </div>
  </section>
  
  <!-- Newsletter Signup -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-navy-600 rounded-lg p-8 text-center">
        <h2 class="text-3xl font-bold text-white mb-4">Stay Informed</h2>
        <p class="text-xl text-navy-100 mb-8 max-w-2xl mx-auto">
          Subscribe to our newsletter for the latest insurance insights, industry news, and risk management tips.
        </p>
        <form class="max-w-md mx-auto flex gap-4">
          <input type="email" placeholder="Enter your email" class="flex-1 px-4 py-3 rounded-md focus:outline-none focus:ring-2 focus:ring-white">
          <button type="submit" class="bg-white text-navy-600 hover:bg-gray-100 px-6 py-3 rounded-md font-semibold transition-colors duration-200">
            Subscribe
          </button>
        </form>
      </div>
    </div>
  </section>
  
  <!-- Categories -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Browse by Category</h2>
        <p class="text-xl text-gray-600">Find articles on the topics that matter most to your business</p>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
        <a href="#" class="bg-white p-4 rounded-lg shadow hover:shadow-md transition-shadow duration-200 text-center">
          <div class="text-navy-600 font-semibold">Workers' Comp</div>
          <div class="text-sm text-gray-500">12 articles</div>
        </a>
        <a href="#" class="bg-white p-4 rounded-lg shadow hover:shadow-md transition-shadow duration-200 text-center">
          <div class="text-navy-600 font-semibold">Cyber Security</div>
          <div class="text-sm text-gray-500">8 articles</div>
        </a>
        <a href="#" class="bg-white p-4 rounded-lg shadow hover:shadow-md transition-shadow duration-200 text-center">
          <div class="text-navy-600 font-semibold">Employee Benefits</div>
          <div class="text-sm text-gray-500">15 articles</div>
        </a>
        <a href="#" class="bg-white p-4 rounded-lg shadow hover:shadow-md transition-shadow duration-200 text-center">
          <div class="text-navy-600 font-semibold">Risk Management</div>
          <div class="text-sm text-gray-500">10 articles</div>
        </a>
        <a href="#" class="bg-white p-4 rounded-lg shadow hover:shadow-md transition-shadow duration-200 text-center">
          <div class="text-navy-600 font-semibold">Claims</div>
          <div class="text-sm text-gray-500">6 articles</div>
        </a>
        <a href="#" class="bg-white p-4 rounded-lg shadow hover:shadow-md transition-shadow duration-200 text-center">
          <div class="text-navy-600 font-semibold">Industry News</div>
          <div class="text-sm text-gray-500">20 articles</div>
        </a>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>
---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<Layout
  title="Auto Insurance - PCFG Insurance Services"
  description="Comprehensive auto insurance coverage in New York. Get competitive rates on liability, collision, comprehensive, and more. Protect your vehicle and your family."
>
  <Header />

  <Breadcrumbs
    items={[
      { label: 'Home', href: '/' },
      { label: 'Personal Insurance', href: '/personal-insurance' },
      { label: 'Auto Insurance', href: '/auto-insurance' }
    ]}
  />

  <section class="py-16 bg-gradient-to-br from-blue-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">Auto Insurance</h1>
          <p class="text-xl text-gray-600 mb-8">
            Comprehensive auto insurance coverage to protect you, your family, and your vehicles on New York roads. From required liability to full coverage protection.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/personal-lines-quote" class="bg-orange-600 hover:bg-orange-700 text-white px-8 py-3 rounded-md font-semibold transition-colors duration-200 text-center no-underline">
              Get Auto Quote
            </a>
            <a href="tel:877-717-7234" class="border-2 border-orange-600 text-orange-600 hover:bg-orange-600 hover:text-white px-8 py-3 rounded-md font-semibold transition-colors duration-200 text-center no-underline">
              Call (877) 717-7234
            </a>
          </div>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-xl overflow-visible">
  <h3 class="text-2xl font-semibold text-gray-900 mb-4">Get Your Free Quote</h3>
  <div class="relative w-full" style="min-height: 900px;">
    <iframe
    src="https://api.leadconnectorhq.com/widget/form/Nd4xbEAv44OueWqwrE2T"
    style="width:100%;min-height:950px;border:none;border-radius:4px"
    id="inline-Nd4xbEAv44OueWqwrE2T" 
    data-layout="{'id':'INLINE'}"
    data-trigger-type="alwaysShow"
    data-trigger-value=""
    data-activation-type="alwaysActivated"
    data-activation-value=""
    data-deactivation-type="neverDeactivate"
    data-deactivation-value=""
    data-form-name="Auto Insurance Quote - Website"
    data-height="772"
    data-layout-iframe-id="inline-Nd4xbEAv44OueWqwrE2T"
    data-form-id="Nd4xbEAv44OueWqwrE2T"
    title="Auto Insurance Quote - Website"
        >
</iframe>
<script src="https://link.msgsndr.com/js/form_embed.js"></script>
  </div>
</div>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Auto Insurance Coverage Options</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Customize your auto insurance policy with the coverage options that fit your needs and budget.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white p-6 rounded-lg shadow-lg border-t-4 border-orange-600">
          <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Liability Coverage</h3>
          <p class="text-gray-600 mb-4">
            Required by New York state law. Covers bodily injury and property damage you cause to others in an accident.
          </p>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>• Bodily injury liability</li>
            <li>• Property damage liability</li>
            <li>• Legal defense costs</li>
            <li>• NY minimum: 25/50/10</li>
          </ul>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-lg border-t-4 border-blue-600">
          <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Collision Coverage</h3>
          <p class="text-gray-600 mb-4">
            Pays for damage to your vehicle from collisions with other vehicles or objects, regardless of fault.
          </p>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>• Vehicle collision repairs</li>
            <li>• Single-vehicle accidents</li>
            <li>• Hit and run protection</li>
            <li>• Deductible options available</li>
          </ul>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-lg border-t-4 border-green-600">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.618 5.984A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Comprehensive Coverage</h3>
          <p class="text-gray-600 mb-4">
            Protects your vehicle from non-collision events like theft, vandalism, fire, weather, and animal strikes.
          </p>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>• Theft and vandalism</li>
            <li>• Weather damage (hail, flood)</li>
            <li>• Fire and explosion</li>
            <li>• Falling objects and animal hits</li>
          </ul>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-lg border-t-4 border-purple-600">
          <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Uninsured/Underinsured Motorist</h3>
          <p class="text-gray-600 mb-4">
            Protects you when the at-fault driver has no insurance or insufficient coverage to pay for your damages.
          </p>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>• Bodily injury protection</li>
            <li>• Property damage coverage</li>
            <li>• Hit-and-run accidents</li>
            <li>• Highly recommended in NY</li>
          </ul>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-lg border-t-4 border-red-600">
          <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Personal Injury Protection (PIP)</h3>
          <p class="text-gray-600 mb-4">
            Required in New York. Covers medical expenses and lost wages for you and passengers, regardless of fault.
          </p>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>• Medical expenses</li>
            <li>• Lost wages coverage</li>
            <li>• Rehabilitation costs</li>
            <li>• Essential services</li>
          </ul>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-lg border-t-4 border-yellow-600">
          <div class="w-12 h-12 bg-yellow-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Rental Reimbursement & Roadside</h3>
          <p class="text-gray-600 mb-4">
            Additional coverage for rental car costs while your vehicle is being repaired and emergency roadside assistance.
          </p>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>• Rental car reimbursement</li>
            <li>• Towing services</li>
            <li>• Battery jump-start</li>
            <li>• Flat tire changes</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Ways to Save on Auto Insurance</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Take advantage of these discounts to reduce your auto insurance premiums
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <div class="w-16 h-16 bg-orange-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3a4 4 0 118 0v4m-4 8a2 2 0 11-4 0 2 2 0 014 0zm6 0a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Multi-Car Discount</h3>
          <p class="text-gray-600">Save by insuring multiple vehicles on the same policy</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Bundle & Save</h3>
          <p class="text-gray-600">Combine auto and home insurance for significant savings</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Safe Driver</h3>
          <p class="text-gray-600">Maintain a clean driving record for lower premiums</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Good Student</h3>
          <p class="text-gray-600">Students with good grades qualify for discounts</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Anti-Theft Devices</h3>
          <p class="text-gray-600">Vehicle security systems can reduce premiums</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <div class="w-16 h-16 bg-yellow-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Defensive Driving</h3>
          <p class="text-gray-600">Complete an approved course for premium reduction</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <div class="w-16 h-16 bg-indigo-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Pay in Full</h3>
          <p class="text-gray-600">Save by paying your annual premium upfront</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <div class="w-16 h-16 bg-pink-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Low Mileage</h3>
          <p class="text-gray-600">Drive less than average? You may qualify for savings</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">New York Auto Insurance Requirements</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Understanding minimum coverage requirements in New York State
        </p>
      </div>

      <div class="bg-white rounded-lg shadow-xl p-8 md:p-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
          <div class="text-center p-6 bg-orange-50 rounded-lg">
            <div class="text-4xl font-bold text-orange-600 mb-2">$25,000</div>
            <p class="text-gray-700 font-medium">Bodily Injury per Person</p>
          </div>
          <div class="text-center p-6 bg-orange-50 rounded-lg">
            <div class="text-4xl font-bold text-orange-600 mb-2">$50,000</div>
            <p class="text-gray-700 font-medium">Bodily Injury per Accident</p>
          </div>
          <div class="text-center p-6 bg-orange-50 rounded-lg">
            <div class="text-4xl font-bold text-orange-600 mb-2">$10,000</div>
            <p class="text-gray-700 font-medium">Property Damage per Accident</p>
          </div>
        </div>

        <div class="bg-blue-50 border-l-4 border-blue-600 p-6 rounded">
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Additional Required Coverage in NY</h3>
          <ul class="space-y-2 text-gray-700">
            <li class="flex items-start">
              <svg class="w-5 h-5 text-blue-600 mr-2 mt-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span><strong>Personal Injury Protection (PIP):</strong> $50,000 minimum coverage for medical expenses and lost wages</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-blue-600 mr-2 mt-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
              </svg>
              <span><strong>Uninsured Motorist Coverage:</strong> Same limits as liability coverage to protect against uninsured drivers</span>
            </li>
          </ul>
        </div>

        <div class="mt-8 p-6 bg-yellow-50 border-l-4 border-yellow-600 rounded">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">We Recommend Higher Limits</h3>
          <p class="text-gray-700">
            While these are the minimum requirements, we strongly recommend higher liability limits (100/300/100 or higher) to adequately protect your assets. The difference in premium is often minimal compared to the additional protection.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-gradient-to-br from-orange-600 to-orange-700 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to Get Your Auto Insurance Quote?</h2>
      <p class="text-xl text-orange-100 mb-8 max-w-2xl mx-auto">
        Let us help you find the right auto insurance coverage at a competitive price. Get started today!
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/personal-lines-quote" class="bg-white text-orange-600 hover:bg-gray-100 px-8 py-3 rounded-md font-semibold transition-colors duration-200">
          Get Your Free Quote
        </a>
        <a href="tel:877-717-7234" class="border-2 border-white text-white hover:bg-white hover:text-orange-600 px-8 py-3 rounded-md font-semibold transition-colors duration-200">
          Call (877) 717-7234
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

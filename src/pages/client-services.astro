---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Client Services - PCFG Insurance Services" description="Access your policy information, request certificates, make service changes, and report claims. Comprehensive client services for PCFG Insurance policyholders.">
  <Header />
  
  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-br from-navy-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">Client Services</h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Access your policy information, request certificates, make service changes, and report claims. We're here to help with all your insurance needs.
        </p>
      </div>
    </div>
  </section>
  
  <!-- Quick Access Links -->
  <section class="py-12 bg-navy-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <a href="https://www6.nowcerts.com/Login.aspx?AgencyId=bd4cf416-6b8c-4c9b-8a76-d54654fbaf81&ShowAgencyLogo=true" target="_blank" rel="noopener noreferrer" class="bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200 text-center">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Client Portal</h3>
          <p class="text-gray-600 text-sm">Access your policies, documents, and account information</p>
        </a>
        
        <a href="https://seppay.com/s/al?a=V18tksWZD3qgVTD1z2TO%2BA" target="_blank" rel="noopener noreferrer" class="bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200 text-center">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Make Payment</h3>
          <p class="text-gray-600 text-sm">Pay your insurance premiums online securely</p>
        </a>
        
        <a href="#certificate-request" class="bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200 text-center">
          <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Request Certificate</h3>
          <p class="text-gray-600 text-sm">Get certificates of insurance for contracts</p>
        </a>
        
        <a href="#report-claim" class="bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200 text-center">
          <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Report Claim</h3>
          <p class="text-gray-600 text-sm">Report an insurance claim quickly and easily</p>
        </a>
      </div>
    </div>
  </section>
  
  <!-- Certificate Request Form -->
  <section id="certificate-request" class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Request Certificate of Insurance</h2>
          <p class="text-xl text-gray-600">
            Need a certificate of insurance for a contract or project? Complete the form below and we'll process your request promptly.
          </p>
        </div>
        
        <div class="bg-white p-8 rounded-lg shadow-lg">
          <div style="min-height: 1140px;">
            <iframe
              src="https://link.spartan-crm.com/widget/form/LRFfMj0cHcGKAYAz65Q8"
              style="width:100%;height:100%;border:none;border-radius:4px"
              id="inline-LRFfMj0cHcGKAYAz65Q8" 
              data-layout="{'id':'INLINE'}"
              data-trigger-type="alwaysShow"
              data-trigger-value=""
              data-activation-type="alwaysActivated"
              data-activation-value=""
              data-deactivation-type="neverDeactivate"
              data-deactivation-value=""
              data-form-name="Certificate of Insurance Request"
              data-height="1140"
              data-layout-iframe-id="inline-LRFfMj0cHcGKAYAz65Q8"
              data-form-id="LRFfMj0cHcGKAYAz65Q8"
              title="Certificate of Insurance Request"
            >
            </iframe>
            <script src="https://link.spartan-crm.com/js/form_embed.js"></script>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Service Request Form -->
  <section id="service-request" class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Policy Service Request</h2>
          <p class="text-xl text-gray-600">
            Need to make changes to your policy? Submit a service request and we'll take care of it for you.
          </p>
        </div>
        
        <div class="bg-white p-8 rounded-lg shadow-lg" style="min-height: 716px;">
          <iframe
            src="https://link.spartan-crm.com/widget/form/Hkv5xXE2yDvLbsGovl49"
            style="width:100%;height:100%;border:none;border-radius:3px"
            id="inline-Hkv5xXE2yDvLbsGovl49" 
            data-layout="{'id':'INLINE'}"
            data-trigger-type="alwaysShow"
            data-trigger-value=""
            data-activation-type="alwaysActivated"
            data-activation-value=""
            data-deactivation-type="neverDeactivate"
            data-deactivation-value=""
            data-form-name="Policy Service Request"
            data-height="716"
            data-layout-iframe-id="inline-Hkv5xXE2yDvLbsGovl49"
            data-form-id="Hkv5xXE2yDvLbsGovl49"
            title="Policy Service Request"
          >
          </iframe>
          <script src="https://link.spartan-crm.com/js/form_embed.js"></script>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Claim Report Form -->
  <section id="report-claim" class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Report an Insurance Claim</h2>
          <p class="text-xl text-gray-600">
            Report a claim as soon as possible after an incident. The sooner you report, the faster we can help resolve your claim.
          </p>
        </div>
        
        <div class="bg-red-50 border border-red-200 p-6 rounded-lg mb-8">
          <div class="flex items-start">
            <svg class="w-6 h-6 text-red-600 mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
            </svg>
            <div>
              <h3 class="text-lg font-semibold text-red-800 mb-2">Emergency Claims</h3>
              <p class="text-red-700">
                For urgent claims requiring immediate attention, please call us directly at <strong>(877) 717-7234</strong> before completing this form.
              </p>
            </div>
          </div>
        </div>
        
        <div class="bg-white p-8 rounded-lg shadow-lg">
          <form id="claim-report-form" class="space-y-6" name="claim-report" data-netlify="true" data-netlify-recaptcha="true">
            <input type="hidden" name="form-name" value="claim-report" />
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="claim-policy-number" class="block text-sm font-medium text-gray-700 mb-1">Policy Number *</label>
                <input type="text" id="claim-policy-number" name="policy-number" required class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent">
              </div>
              <div>
                <label for="claim-insured-name" class="block text-sm font-medium text-gray-700 mb-1">Insured Name *</label>
                <input type="text" id="claim-insured-name" name="insured-name" required class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent">
              </div>
            </div>
            
            <div>
              <label for="claim-type" class="block text-sm font-medium text-gray-700 mb-1">Type of Claim *</label>
              <select id="claim-type" name="claim-type" required class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent">
                <option value="">Select Claim Type</option>
                <option value="auto-accident">Auto Accident</option>
                <option value="property-damage">Property Damage</option>
                <option value="theft">Theft</option>
                <option value="fire">Fire</option>
                <option value="water-damage">Water Damage</option>
                <option value="vandalism">Vandalism</option>
                <option value="liability">Liability Claim</option>
                <option value="workers-comp">Workers' Compensation</option>
                <option value="cyber-incident">Cyber Incident</option>
                <option value="other">Other</option>
              </select>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="loss-date" class="block text-sm font-medium text-gray-700 mb-1">Date of Loss *</label>
                <input type="date" id="loss-date" name="loss-date" required class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent">
              </div>
              <div>
                <label for="loss-time" class="block text-sm font-medium text-gray-700 mb-1">Time of Loss</label>
                <input type="time" id="loss-time" name="loss-time" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent">
              </div>
            </div>
            
            <div>
              <label for="loss-location" class="block text-sm font-medium text-gray-700 mb-1">Location of Loss *</label>
              <input type="text" id="loss-location" name="loss-location" required class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent" placeholder="Address where the loss occurred">
            </div>
            
            <div>
              <label for="loss-description" class="block text-sm font-medium text-gray-700 mb-1">Description of Loss *</label>
              <textarea id="loss-description" name="loss-description" required rows="4" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent" placeholder="Please provide a detailed description of what happened..."></textarea>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Were there any injuries?</label>
                <div class="flex space-x-4">
                  <label class="flex items-center">
                    <input type="radio" name="injuries" value="true" class="text-navy-600 focus:ring-navy-500">
                    <span class="ml-2 text-sm text-gray-700">Yes</span>
                  </label>
                  <label class="flex items-center">
                    <input type="radio" name="injuries" value="false" checked class="text-navy-600 focus:ring-navy-500">
                    <span class="ml-2 text-sm text-gray-700">No</span>
                  </label>
                </div>
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Police report filed?</label>
                <div class="flex space-x-4">
                  <label class="flex items-center">
                    <input type="radio" name="police-report" value="true" class="text-navy-600 focus:ring-navy-500">
                    <span class="ml-2 text-sm text-gray-700">Yes</span>
                  </label>
                  <label class="flex items-center">
                    <input type="radio" name="police-report" value="false" checked class="text-navy-600 focus:ring-navy-500">
                    <span class="ml-2 text-sm text-gray-700">No</span>
                  </label>
                </div>
              </div>
              
              <div>
                <label for="contact-phone" class="block text-sm font-medium text-gray-700 mb-1">Contact Phone *</label>
                <input type="tel" id="contact-phone" name="contact-phone" required class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent">
              </div>
            </div>
            
            <div data-netlify-recaptcha="true"></div>
            
            <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white font-semibold py-3 px-4 rounded-md transition-colors duration-200">
              Submit Claim Report
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Contact Information -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Need Immediate Assistance?</h2>
        <p class="text-xl text-gray-600">Our team is here to help with all your insurance needs</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Call Us</h3>
          <p class="text-gray-600 mb-4">Speak directly with our insurance experts</p>
          <a href="tel:877-717-7234" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-2 rounded-md font-medium transition-colors duration-200">
            (877) 717-7234
          </a>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Email Us</h3>
          <p class="text-gray-600 mb-4">Send us your questions or requests</p>
          <a href="mailto:info@pcfginsurance.com" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-2 rounded-md font-medium transition-colors duration-200">
            info@pcfginsurance.com
          </a>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Business Hours</h3>
          <p class="text-gray-600">
            Monday - Friday: 8:00 AM - 5:00 PM<br>
            Saturday: By Appointment<br>
            Sunday: Closed
          </p>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>

<script>

  document.addEventListener('DOMContentLoaded', function() {
    // Certificate Request Form
    // Certificate request form is now handled by external iframe
    
    // Service Request Form
    // Service request form is now handled by external iframe
    
    // Claim Report Form
    const claimForm = document.getElementById('claim-report-form');
    if (claimForm) {
      claimForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const formData = new FormData(claimForm);
        const data = Object.fromEntries(formData);
        
        console.log('Submitting claim report:', data);
        
        try {
          if (window.submitToSupabase) {
            await window.submitToSupabase(data, 'claim_report');
            console.log('Claim report submitted successfully');
          }
          
          alert('Claim report submitted successfully! We will assign an adjuster and contact you within 24 hours to begin processing your claim.');
          claimForm.reset();
        } catch (error) {
          console.error('Claim report submission failed:', error);
          alert('There was an error submitting your claim report. Please try again or contact us directly at (877) 717-7234.');
        }
      });
    }
    
    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function(e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          target.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });
        }
      });
    });
  });
</script>
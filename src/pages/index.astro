---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import QuoteForm from '../components/QuoteForm.astro';
import Card from '../components/Card.astro';
import Button from '../components/Button.astro';
import ServiceCard from '../components/ServiceCard.astro';
import LocalSEO from '../components/LocalSEO.astro';
import NAPConsistency from '../components/NAPConsistency.astro';
import LocalServiceAreas from '../components/LocalServiceAreas.astro';
import LocalBusinessReviews from '../components/LocalBusinessReviews.astro';
---

<Layout title="PCFG Insurance Services - Parish NY | Insurance Agency Serving 15 States" description="Veteran-owned insurance agency in Parish, NY serving businesses and families across 15 states. Workers' compensation, commercial auto, general liability, employee benefits. Licensed in NY, PA, FL, TX and more. Call (877) 717-7234.">
  <LocalSEO pageName="Home" />
  <Header />
  
  <!-- Hero Section with Background Image -->
  <section class="py-16 md:py-20 relative overflow-hidden">
    <img
      src="https://images.pexels.com/photos/3760067/pexels-photo-3760067.jpeg?auto=compress&cs=tinysrgb&w=1920&h=1080&dpr=1"
      srcset="
        https://images.pexels.com/photos/3760067/pexels-photo-3760067.jpeg?auto=compress&cs=tinysrgb&w=640&h=360&dpr=1 640w,
        https://images.pexels.com/photos/3760067/pexels-photo-3760067.jpeg?auto=compress&cs=tinysrgb&w=1280&h=720&dpr=1 1280w,
        https://images.pexels.com/photos/3760067/pexels-photo-3760067.jpeg?auto=compress&cs=tinysrgb&w=1920&h=1080&dpr=1 1920w
      "
      sizes="100vw"
      alt="Professional insurance services"
      class="absolute inset-0 w-full h-full object-cover z-0"
      loading="eager"
      fetchpriority="high"
      width="1920"
      height="1080"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-primary-50 to-white opacity-90 z-0"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="relative z-10">
          <h1 id="hero-title" class="text-3xl md:text-5xl font-bold text-neutral-dark mb-6 font-heading">
            PCFG Insurance Services - Parish NY | Insurance Agency Serving 15 States
          </h1>
          <h2 id="hero-subtitle" class="text-xl md:text-2xl text-neutral-dark mb-8 font-normal">
            Protecting What Matters Most to Your Business and Family - Comprehensive Insurance Solutions Across 15 States
          </h2>
          <p id="local-message" class="text-lg text-neutral-dark mb-6 opacity-90">
            Serving businesses and families across 15 states from our Central New York location.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <Button 
              text="Get Free Quote"
              href="/contact" 
              variant="primary" 
              size="lg" 
              fullWidth={true}
            />
            <Button 
              text="View Services" 
              href="/services" 
              variant="outline" 
              size="lg" 
              fullWidth={true}
            />
          </div>
          
          <!-- Location Detection Status -->
          <div id="location-status" class="mt-4 text-sm text-gray-600 hidden">
            <div class="flex items-center">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <span id="location-text">Detecting your location for personalized content...</span>
            </div>
          </div>
        </div>
        <div class="lg:pl-8 relative z-10">
          <QuoteForm />
        </div>
      </div>
    </div>
  </section>
  
  <!-- Trust Badges -->
  <section class="py-12 bg-neutral-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <h2 class="text-2xl font-semibold text-neutral-dark mb-4 font-heading">Trusted Insurance Agency - Veteran-Owned Since 2018</h2>
        <p class="text-neutral-dark">Veteran-owned and operated with over 5 years of experience</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 items-center justify-items-center opacity-60">
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="text-center">
            <div class="text-2xl font-bold text-primary">500+</div>
            <div class="text-sm text-neutral-dark">Happy Clients</div>
          </div>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="text-center">
            <div class="text-2xl font-bold text-primary">15</div>
            <div class="text-sm text-neutral-dark">Licensed States</div>
          </div>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="text-center">
            <div class="text-2xl font-bold text-primary">5.0★</div>
            <div class="text-sm text-neutral-dark">Google Rating</div>
          </div>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="text-center">
            <div class="text-2xl font-bold text-primary">Expert</div>
            <div class="text-sm text-neutral-dark">Support</div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Licensed States Section -->
  <section class="py-16 md:py-20" role="region" aria-labelledby="service-areas-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 md:mb-12">
        <h2 id="service-areas-heading" class="text-2xl md:text-3xl font-bold text-neutral-dark mb-4 font-heading">Licensed Insurance Agency Serving Syracuse, Rochester, Buffalo, Albany and 11 More States</h2>
        <p class="text-lg md:text-xl text-neutral-dark max-w-3xl mx-auto max-w-none">
          From our Central New York location, we bring our expertise and personalized service to businesses and families throughout Syracuse, Rochester, Buffalo, Albany, and 14 additional states.
        </p>
      </div>
      
      <div class="bg-white rounded-lg shadow-lg p-6 md:p-8">
        <LocalServiceAreas variant="grid" />
        
        <div class="mt-6 text-center">
          <p class="text-neutral-dark max-w-none">
            No matter where your business is located in Central New York or our other licensed states, we're here to provide the same level of excellence and personalized service.
          </p>
        </div>
      </div>
    </div>
  </section>
  </main>
  
  <!-- Google Reviews Section -->
  <section class="py-16 md:py-20 bg-neutral-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <LocalBusinessReviews variant="widget" />
    </div>
  </section>
  
  <!-- Services Overview -->
  <section class="py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 md:mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-neutral-dark mb-4 font-heading">Business Insurance Services - Workers' Comp, Commercial Auto, General Liability</h2>
        <p class="text-lg md:text-xl text-neutral-dark max-w-3xl mx-auto">
          From commercial coverage to employee benefits, we provide the protection your business needs to thrive.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <ServiceCard
          title="Workers' Compensation"
          description="Protect your employees and your business with comprehensive workers' comp coverage."
          icon="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
          href="/services#workers-comp"
        />
        
        <ServiceCard
          title="Commercial Auto"
          description="Keep your fleet protected with tailored commercial vehicle insurance solutions."
          icon="M8 7V3a4 4 0 118 0v4m-4 8a2 2 0 11-4 0 2 2 0 014 0zm6 0a2 2 0 11-4 0 2 2 0 014 0z"
          href="/services#commercial-auto"
        />
        
        <ServiceCard
          title="General Liability"
          description="Essential protection against third-party claims and lawsuits for your business."
          icon="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
          href="/services#general-liability"
        />
        
        <ServiceCard
          title="Employee Benefits"
          description="Comprehensive health, dental, vision, and voluntary benefits for your team."
          icon="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
          href="/services#employee-benefits"
        />
        
        <ServiceCard
          title="Cyber Liability"
          description="Protect your business from cyber threats and data breaches in the digital age."
          icon="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
          href="/services#cyber-liability"
        />
        
        <ServiceCard
          title="Business Owner's Policy"
          description="Bundled coverage combining general liability and property insurance for small businesses."
          icon="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z"
          href="/services#bop"
        />
      </div>
    </div>
  </section>
  
  <!-- Why Choose Us -->
  <section class="py-16 md:py-20 bg-neutral-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 md:mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-neutral-dark mb-4 font-heading">Why Choose PCFG Insurance?</h2>
        <p class="text-lg md:text-xl text-neutral-dark">Experience the difference of working with a veteran-owned agency that puts your needs first.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <Card
          title="Fast Response"
          body="Quick quotes and rapid claim processing to keep your business moving forward."
          icon="M13 10V3L4 14h7v7l9-11h-7z"
        />
        
        <Card
          title="Personal Service"
          body="Dedicated agents who understand your business and provide personalized attention."
          icon="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
        />
        
        <Card
          title="Proven Expertise"
          body="Over 5 years of experience helping businesses protect what matters most across 15 states."
          icon="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"
        />
      </div>
    </div>
  </section>
  
  <!-- CTA Section -->
  <section class="py-16 md:py-20 bg-primary-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 font-heading">Ready to Protect Your Business?</h2>
      <p class="text-lg md:text-xl text-primary-light mb-8 max-w-2xl mx-auto">
        Get a free, no-obligation quote today and discover how we can help safeguard your business and family across all our licensed states.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button 
          text="Get Free Quote" 
          href="/contact" 
          variant="secondary" 
          size="lg"
        />
        <Button 
          text="Call (877) 717-7234" 
          href="tel:877-717-7234" 
          variant="outline" 
          size="lg"
          icon="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
          iconPosition="left"
        />
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>
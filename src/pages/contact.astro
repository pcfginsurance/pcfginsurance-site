---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact PCFG Insurance Services - Get Your Free Quote" description="Contact PCFG Insurance Services for your free insurance quote. Licensed in 15 states. Call (877) 717-7234 or email info@pcfginsurance.com.">
  <Header />
  
  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-br from-primary-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-neutral-dark mb-6 font-heading">Contact Us</h1>
        <p class="text-xl text-neutral-dark max-w-3xl mx-auto">
          Ready to protect what matters most? Get your free quote today or speak with one of our insurance experts. We're licensed to serve you across 15 states.
        </p>
      </div>
    </div>
  </section>
  
  <!-- Licensed States Banner -->
  <section class="py-12 bg-primary-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-2xl font-bold text-white mb-4 font-heading">Licensed to Serve You In:</h2>
        <div class="flex flex-wrap justify-center gap-4">
          <span class="bg-white text-primary-dark px-3 py-1 rounded-full text-sm font-medium">Alabama</span>
          <span class="bg-white text-primary-dark px-3 py-1 rounded-full text-sm font-medium">Arizona</span>
          <span class="bg-white text-primary-dark px-3 py-1 rounded-full text-sm font-medium">Florida</span>
          <span class="bg-white text-primary-dark px-3 py-1 rounded-full text-sm font-medium">Georgia</span>
          <span class="bg-white text-primary-dark px-3 py-1 rounded-full text-sm font-medium">Indiana</span>
          <span class="bg-white text-primary-dark px-3 py-1 rounded-full text-sm font-medium">Maryland</span>
          <span class="bg-white text-primary-dark px-3 py-1 rounded-full text-sm font-medium">Maine</span>
          <span class="bg-white text-primary-dark px-3 py-1 rounded-full text-sm font-medium">New Jersey</span>
          <span class="bg-white text-primary-dark px-3 py-1 rounded-full text-sm font-medium">New York</span>
          <span class="bg-white text-primary-dark px-3 py-1 rounded-full text-sm font-medium">North Carolina</span>
          <span class="bg-white text-primary-dark px-3 py-1 rounded-full text-sm font-medium">Ohio</span>
          <span class="bg-white text-primary-dark px-3 py-1 rounded-full text-sm font-medium">Pennsylvania</span>
          <span class="bg-white text-primary-dark px-3 py-1 rounded-full text-sm font-medium">Tennessee</span>
          <span class="bg-white text-primary-dark px-3 py-1 rounded-full text-sm font-medium">Texas</span>
          <span class="bg-white text-primary-dark px-3 py-1 rounded-full text-sm font-medium">Virginia</span>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Contact Section -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        
        <!-- Contact Form -->
        <div class="bg-white p-8 rounded-lg shadow-lg">
          <h2 class="text-2xl font-bold text-neutral-dark mb-6 font-heading">Get Your Free Quote</h2>
          <form id="contact-form" class="space-y-6" name="contact" data-netlify="true" data-netlify-recaptcha="true">
            <input type="hidden" name="form-name" value="contact" />
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="first-name" class="block text-sm font-medium text-neutral-dark mb-1">First Name *</label>
                <input type="text" id="first-name" name="first-name" required class="w-full px-3 py-2 border border-neutral-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
              </div>
              <div>
                <label for="last-name" class="block text-sm font-medium text-neutral-dark mb-1">Last Name *</label>
                <input type="text" id="last-name" name="last-name" required class="w-full px-3 py-2 border border-neutral-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
              </div>
            </div>
            
            <div>
              <label for="email" class="block text-sm font-medium text-neutral-dark mb-1">Email Address *</label>
              <input type="email" id="email" name="email" required class="w-full px-3 py-2 border border-neutral-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
            </div>
            
            <div>
              <label for="phone" class="block text-sm font-medium text-neutral-dark mb-1">Phone Number *</label>
              <input type="tel" id="phone" name="phone" required class="w-full px-3 py-2 border border-neutral-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
            </div>
            
            <div>
              <label for="state" class="block text-sm font-medium text-neutral-dark mb-1">State *</label>
              <select id="state" name="state" required class="w-full px-3 py-2 border border-neutral-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                <option value="">Select Your State</option>
                <option value="AL">Alabama</option>
                <option value="AZ">Arizona</option>
                <option value="FL">Florida</option>
                <option value="GA">Georgia</option>
                <option value="IN">Indiana</option>
                <option value="MD">Maryland</option>
                <option value="ME">Maine</option>
                <option value="NJ">New Jersey</option>
                <option value="NY">New York</option>
                <option value="NC">North Carolina</option>
                <option value="OH">Ohio</option>
                <option value="PA">Pennsylvania</option>
                <option value="TN">Tennessee</option>
                <option value="TX">Texas</option>
                <option value="VA">Virginia</option>
              </select>
            </div>
            
            <div>
              <label for="company" class="block text-sm font-medium text-neutral-dark mb-1">Company Name</label>
              <input type="text" id="company" name="company" class="w-full px-3 py-2 border border-neutral-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
            </div>
            
            <div>
              <label for="insurance-type" class="block text-sm font-medium text-neutral-dark mb-1">Type of Insurance Needed *</label>
              <select id="insurance-type" name="insurance-type" required class="w-full px-3 py-2 border border-neutral-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                <option value="">Select Insurance Type</option>
                <optgroup label="Business Insurance">
                  <option value="workers-comp">Workers' Compensation</option>
                  <option value="commercial-auto">Commercial Auto</option>
                  <option value="general-liability">General Liability</option>
                  <option value="bop">Business Owner's Policy</option>
                  <option value="cyber-liability">Cyber Liability</option>
                  <option value="professional-liability">Professional Liability</option>
                </optgroup>
                <optgroup label="Personal Insurance">
                  <option value="auto-insurance">Auto Insurance</option>
                  <option value="home-insurance">Homeowners Insurance</option>
                  <option value="renters-insurance">Renters Insurance</option>
                  <option value="condo-insurance">Condo Insurance</option>
                  <option value="life-insurance">Life Insurance</option>
                  <option value="umbrella-insurance">Umbrella Insurance</option>
                  <option value="motorcycle-insurance">Motorcycle Insurance</option>
                  <option value="boat-insurance">Boat Insurance</option>
                  <option value="rv-insurance">RV Insurance</option>
                </optgroup>
                <optgroup label="Employee Benefits">
                  <option value="group-health">Group Health Insurance</option>
                  <option value="dental-vision">Dental & Vision</option>
                  <option value="group-life">Group Life Insurance</option>
                  <option value="disability">Disability Insurance</option>
                  <option value="voluntary-benefits">Voluntary Benefits</option>
                  <option value="retirement-plans">Retirement Plans</option>
                  <option value="annuities">Annuities</option>
                </optgroup>
                <option value="other">Other</option>
              </select>
            </div>
            
            <div>
              <label for="industry" class="block text-sm font-medium text-neutral-dark mb-1">Industry</label>
              <select id="industry" name="industry" class="w-full px-3 py-2 border border-neutral-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                <option value="">Select Your Industry</option>
                <option value="construction">Construction</option>
                <option value="hvac">HVAC</option>
                <option value="transportation">Transportation</option>
                <option value="agriculture">Agriculture</option>
                <option value="healthcare">Healthcare</option>
                <option value="manufacturing">Manufacturing</option>
                <option value="retail">Retail</option>
                <option value="professional-services">Professional Services</option>
                <option value="small-business">Small Business</option>
                <option value="other">Other</option>
              </select>
            </div>
            
            <div>
              <label for="message" class="block text-sm font-medium text-neutral-dark mb-1">Additional Details</label>
              <textarea id="message" name="message" rows="4" class="w-full px-3 py-2 border border-neutral-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="Tell us about your business, current coverage, or specific insurance needs..."></textarea>
            </div>
            
            <div>
              <label for="preferred-contact" class="block text-sm font-medium text-neutral-dark mb-1">Preferred Contact Method</label>
              <div class="flex space-x-4">
                <label class="flex items-center">
                  <input type="radio" name="preferred-contact" value="phone" class="text-primary focus:ring-primary">
                  <span class="ml-2 text-sm text-neutral-dark">Phone</span>
                </label>
                <label class="flex items-center">
                  <input type="radio" name="preferred-contact" value="email" class="text-primary focus:ring-primary">
                  <span class="ml-2 text-sm text-neutral-dark">Email</span>
                </label>
                <label class="flex items-center">
                  <input type="radio" name="preferred-contact" value="either" checked class="text-primary focus:ring-primary">
                  <span class="ml-2 text-sm text-neutral-dark">Either</span>
                </label>
              </div>
            </div>
            
            <div data-netlify-recaptcha="true"></div>
            
            <button type="submit" class="w-full bg-primary hover:bg-primary-dark text-white font-semibold py-3 px-4 rounded-lg transition-colors duration-200">
              Get My Free Quote
            </button>
          </form>
        </div>
        
        <!-- Contact Information -->
        <div class="space-y-8">
          <!-- Contact Details -->
          <div class="bg-neutral-light p-8 rounded-lg">
            <h3 class="text-xl font-semibold text-neutral-dark mb-6 font-heading">Get In Touch</h3>
            <div class="space-y-4">
              <div class="flex items-start">
                <svg class="w-6 h-6 text-primary mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
                <div>
                  <p class="font-medium text-neutral-dark">Phone</p>
                  <p class="text-neutral-dark">(877) 717-7234</p>
                </div>
              </div>
              
              <div class="flex items-start">
                <svg class="w-6 h-6 text-primary mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 002 2z"></path>
                </svg>
                <div>
                  <p class="font-medium text-neutral-dark">Email</p>
                  <p class="text-neutral-dark">info@pcfginsurance.com</p>
                </div>
              </div>
              
              <div class="flex items-start">
                <svg class="w-6 h-6 text-primary mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <div>
                  <p class="font-medium text-neutral-dark">Mailing Address</p>
                  <p class="text-neutral-dark">PO Box 609<br>Parish, NY 13131</p>
                </div>
              </div>
              
              <div class="flex items-start">
                <svg class="w-6 h-6 text-primary mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div>
                  <p class="font-medium text-neutral-dark">Business Hours</p>
                  <p class="text-neutral-dark">Monday - Friday: 8:00 AM - 5:00 PM<br>Saturday: By Appointment<br>Sunday: Closed</p>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Quick Response Promise -->
          <div class="bg-primary-dark p-8 rounded-lg text-white">
            <h3 class="text-xl font-semibold mb-4 font-heading">Our Promise to You</h3>
            <div class="space-y-3">
              <div class="flex items-center">
                <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Response within 24 hours</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Free, no-obligation quotes</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Personalized service</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Competitive rates</span>
              </div>
            </div>
          </div>
          
          <!-- Emergency Contact -->
          <div class="bg-red-50 border border-red-200 p-6 rounded-lg">
            <h3 class="text-lg font-semibold text-red-800 mb-2 font-heading">Need to Report a Claim?</h3>
            <p class="text-red-700 mb-3">For urgent claim reporting:</p>
            <a href="tel:877-717-7234" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg font-medium transition-colors duration-200">
              Call (877) 717-7234
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Map Section -->
  <section class="py-20 bg-neutral-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-neutral-dark mb-4 font-heading">Our Location</h2>
        <p class="text-xl text-neutral-dark">Serving businesses and families across 15 states from our headquarters in New York</p>
      </div>
      
      <!-- Google Maps Embed -->
      <div class="bg-white p-4 rounded-lg shadow-lg">
        <div class="aspect-w-16 aspect-h-9">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2943.123456789!2d-76.123456!3d43.123456!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sParish%2C%20NY%2013131!5e0!3m2!1sen!2sus!4v1234567890"
            width="100%" 
            height="400" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="rounded-lg">
          </iframe>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>

<script>

  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('contact-form');
    
    if (form) {
      form.addEventListener('submit', async function(e) {
        // Don't prevent default for Netlify forms - let them submit naturally
        // We'll submit to Supabase as backup/analytics
        
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);
        
        console.log('Submitting contact form data:', data);
        
        try {
          // Send data to Supabase
          if (window.submitToSupabase) {
            await window.submitToSupabase(data, 'contact_form');
            console.log('Supabase submission successful');
          }
        } catch (error) {
          console.error('Form submission failed:', error);
          console.warn('Supabase submission failed, but Netlify will handle the form:', error);
        }
      });
    }
  });
</script>
---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LocalSEO from '../components/LocalSEO.astro';
import NAPConsistency from '../components/NAPConsistency.astro';
import LocalServiceAreas from '../components/LocalServiceAreas.astro';
---

<Layout title="Contact PCFG Insurance - Parish NY | (877) 717-7234 | Free Insurance Quotes" description="Contact PCFG Insurance Services in Parish, NY for your free insurance quote. Licensed insurance agency serving 15 states. Call (877) 717-7234 or email info@pcfginsurance.com. Fast response guaranteed.">
  <LocalSEO pageName="Contact Us" pageDescription="Contact our Parish, NY insurance agency for free quotes and expert service" />
  <Header />
  
  <main id="main-content">
  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-br from-primary-50 to-white" role="banner">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 id="contact-hero-title" class="text-4xl md:text-5xl font-bold text-neutral-dark mb-6 font-heading">Contact PCFG Insurance Services - Free Insurance Quotes</h1>
        <p id="contact-hero-subtitle" class="text-xl text-neutral-dark max-w-3xl mx-auto max-w-none">
          Ready to protect what matters most? Get your free quote today or speak with one of our insurance experts. We're licensed to serve you across 15 states.
        </p>
      </div>
    </div>
  </section>
  
  <!-- Licensed States Banner -->
  <section class="py-12 bg-primary-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <LocalServiceAreas variant="banner" />
    </div>
  </section>
  
  <!-- Contact Section -->
  <section class="py-20" role="main" aria-labelledby="contact-form-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        
        <!-- Contact Form -->
        <div class="bg-white p-8 rounded-lg shadow-lg">
          <h2 id="contact-form-heading" class="text-2xl font-bold text-neutral-dark mb-6 font-heading">Get Your Free Insurance Quote - All Coverage Types</h2>
          <form id="contact-form" class="space-y-6" name="contact" data-netlify="true" data-netlify-recaptcha="true">
            <input type="hidden" name="form-name" value="contact" />
            <input type="hidden" id="contact-user-location-state" name="user-location-state" value="" />
            <input type="hidden" id="contact-user-location-city" name="user-location-city" value="" />
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label for="first-name" class="block text-sm font-medium text-neutral-dark mb-1">First Name *</label>
                <input type="text" id="first-name" name="first-name" required aria-describedby="first-name-help" class="w-full px-3 py-2 border border-neutral-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                <div id="first-name-help" class="sr-only">Enter your first name</div>
              </div>
              <div>
                <label for="last-name" class="block text-sm font-medium text-neutral-dark mb-1">Last Name *</label>
                <input type="text" id="last-name" name="last-name" required aria-describedby="last-name-help" class="w-full px-3 py-2 border border-neutral-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                <div id="last-name-help" class="sr-only">Enter your last name</div>
              </div>
            </div>
            
            <div>
              <label for="email" class="block text-sm font-medium text-neutral-dark mb-1">Email Address *</label>
              <input type="email" id="email" name="email" required aria-describedby="email-help" class="w-full px-3 py-2 border border-neutral-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
              <div id="email-help" class="sr-only">Enter your email address for quote delivery</div>
            </div>
            
            <div>
              <label for="phone" class="block text-sm font-medium text-neutral-dark mb-1">Phone Number *</label>
              <input type="tel" id="phone" name="phone" required aria-describedby="phone-help" class="w-full px-3 py-2 border border-neutral-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
              <div id="phone-help" class="sr-only">Enter your phone number for contact</div>
            </div>
            
            <div>
              <label for="state" class="block text-sm font-medium text-neutral-dark mb-1">State *</label>
              <select id="state" name="state" required class="w-full px-3 py-2 border border-neutral-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                <option value="">Select Your State</option>
                <option value="AL">Alabama</option>
                <option value="AZ">Arizona</option>
                <option value="FL">Florida</option>
                <option value="GA">Georgia</option>
                <option value="IN">Indiana</option>
                <option value="MD">Maryland</option>
                <option value="ME">Maine</option>
                <option value="NJ">New Jersey</option>
                <option value="NY">New York</option>
                <option value="NC">North Carolina</option>
                <option value="OH">Ohio</option>
                <option value="PA">Pennsylvania</option>
                <option value="TN">Tennessee</option>
                <option value="TX">Texas</option>
                <option value="VA">Virginia</option>
              </select>
            </div>
            
            <div>
              <label for="company" class="block text-sm font-medium text-neutral-dark mb-1">Company Name</label>
              <input type="text" id="company" name="company" class="w-full px-3 py-2 border border-neutral-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
            </div>
            
            <div>
              <label for="insurance-type" class="block text-sm font-medium text-neutral-dark mb-1">Type of Insurance Needed *</label>
              <select id="insurance-type" name="insurance-type" required class="w-full px-3 py-2 border border-neutral-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                <option value="">Select Insurance Type</option>
                <optgroup label="Business Insurance">
                  <option value="workers-comp">Workers' Compensation</option>
                  <option value="commercial-auto">Commercial Auto</option>
                  <option value="general-liability">General Liability</option>
                  <option value="bop">Business Owner's Policy</option>
                  <option value="cyber-liability">Cyber Liability</option>
                  <option value="professional-liability">Professional Liability</option>
                </optgroup>
                <optgroup label="Personal Insurance">
                  <option value="auto-insurance">Auto Insurance</option>
                  <option value="home-insurance">Homeowners Insurance</option>
                  <option value="renters-insurance">Renters Insurance</option>
                  <option value="condo-insurance">Condo Insurance</option>
                  <option value="life-insurance">Life Insurance</option>
                  <option value="umbrella-insurance">Umbrella Insurance</option>
                  <option value="motorcycle-insurance">Motorcycle Insurance</option>
                  <option value="boat-insurance">Boat Insurance</option>
                  <option value="rv-insurance">RV Insurance</option>
                </optgroup>
                <optgroup label="Employee Benefits">
                  <option value="group-health">Group Health Insurance</option>
                  <option value="dental-vision">Dental & Vision</option>
                  <option value="group-life">Group Life Insurance</option>
                  <option value="disability">Disability Insurance</option>
                  <option value="voluntary-benefits">Voluntary Benefits</option>
                  <option value="retirement-plans">Retirement Plans</option>
                  <option value="annuities">Annuities</option>
                </optgroup>
                <option value="other">Other</option>
              </select>
            </div>
            
            <div>
              <label for="industry" class="block text-sm font-medium text-neutral-dark mb-1">Industry</label>
              <select id="industry" name="industry" class="w-full px-3 py-2 border border-neutral-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                <option value="">Select Your Industry</option>
                <option value="construction">Construction</option>
                <option value="hvac">HVAC</option>
                <option value="transportation">Transportation</option>
                <option value="agriculture">Agriculture</option>
                <option value="healthcare">Healthcare</option>
                <option value="manufacturing">Manufacturing</option>
                <option value="retail">Retail</option>
                <option value="professional-services">Professional Services</option>
                <option value="small-business">Small Business</option>
                <option value="other">Other</option>
              </select>
            </div>
            
            <div>
              <label for="message" class="block text-sm font-medium text-neutral-dark mb-1">Additional Details</label>
              <textarea id="message" name="message" rows="4" aria-describedby="message-help" class="w-full px-3 py-2 border border-neutral-400 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="Tell us about your business, current coverage, or specific insurance needs..."></textarea>
              <div id="message-help" class="sr-only">Provide additional details about your insurance needs</div>
            </div>
            
            <div>
              <fieldset>
                <legend class="block text-sm font-medium text-neutral-dark mb-2">Preferred Contact Method</legend>
                <div class="flex space-x-4" role="radiogroup" aria-labelledby="contact-method-legend">
                <label class="flex items-center">
                  <input type="radio" name="preferred-contact" value="phone" class="text-primary focus:ring-primary">
                  <span class="ml-2 text-sm text-neutral-dark">Phone</span>
                </label>
                <label class="flex items-center">
                  <input type="radio" name="preferred-contact" value="email" class="text-primary focus:ring-primary">
                  <span class="ml-2 text-sm text-neutral-dark">Email</span>
                </label>
                <label class="flex items-center">
                  <input type="radio" name="preferred-contact" value="either" checked class="text-primary focus:ring-primary">
                  <span class="ml-2 text-sm text-neutral-dark">Either</span>
                </label>
                </div>
              </fieldset>
            </div>
            
            <div data-netlify-recaptcha="true"></div>
            
            <button type="submit" class="w-full bg-primary hover:bg-primary-dark text-white font-semibold py-3 px-4 rounded-lg transition-colors duration-200">
              Get My Free Quote
            </button>
            
            <div class="text-xs text-gray-600 text-center mt-2">
              <p>We respect your privacy and will never share your information. Response within 24 hours guaranteed.</p>
            </div>
          </form>
        </div>
  </main>
        
        <!-- Contact Information -->
        <div class="space-y-8">
          <!-- Contact Details -->
          <div class="bg-neutral-light p-8 rounded-lg">
            <h3 class="text-xl font-semibold text-neutral-dark mb-6 font-heading">Get In Touch</h3>
            <NAPConsistency variant="contact" showEmail={true} showHours={true} showAddress={true} />
          </div>
          
          <!-- Quick Response Promise -->
          <div class="bg-primary-dark p-8 rounded-lg text-white">
            <h3 class="text-xl font-semibold mb-4 font-heading">Our Promise to You</h3>
            <div class="space-y-3">
              <div class="flex items-center">
                <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Response within 24 hours</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Free, no-obligation quotes</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Personalized service</span>
              </div>
              <div class="flex items-center">
                <svg class="w-5 h-5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Competitive rates</span>
              </div>
            </div>
          </div>
          
          <!-- Emergency Contact -->
          <div class="bg-red-50 border border-red-200 p-6 rounded-lg">
            <h3 class="text-lg font-semibold text-red-800 mb-2 font-heading">Need to Report a Claim?</h3>
            <p class="text-red-700 mb-3">For urgent claim reporting:</p>
            <a href="tel:877-717-7234" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg font-medium transition-colors duration-200">
              Call (877) 717-7234
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Map Section -->
  <section class="py-20 bg-neutral-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-neutral-dark mb-4 font-heading">Serving Central New York</h2>
        <p class="text-xl text-neutral-dark">Proudly serving Syracuse, Rochester, Buffalo, Albany, Utica, and all of Central/Western/Upstate New York plus 14 additional states</p>
      </div>
      
      <!-- Google Maps Embed -->
      <div class="bg-white p-4 rounded-lg shadow-lg">
        <div class="aspect-w-16 aspect-h-9">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d186859.0!2d-76.1474!3d43.0481!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89d9f30a42d60baf%3A0x8746f37623b154c4!2sSyracuse%2C%20NY!5e0!3m2!1sen!2sus!4v1234567890"
            width="100%" 
            height="400" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="rounded-lg"
            title="PCFG Insurance Services - Serving Syracuse and Central New York">
          </iframe>
        </div>
        <div class="mt-4 text-center">
          <p class="text-gray-600">
            <strong>PCFG Insurance Services</strong> - Serving Syracuse, Rochester, Buffalo, Albany and all of Central New York<br>
            Plus 14 additional states with comprehensive insurance solutions
          </p>
        </div>
      </div>
    </div>
  </section>
  
  <Footer />
</Layout>

<script>

  document.addEventListener('DOMContentLoaded', function() {
    // Initialize location-aware contact page
    initializeLocationAwareContact();
    
    const form = document.getElementById('contact-form');
    
    if (form) {
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);
        
        console.log('Submitting contact form data:', data);
        
        try {
          // Send data to Supabase
          if (window.submitToSupabase) {
            await window.submitToSupabase(data, 'contact_form');
            console.log('Supabase submission successful');
          }
          
          // Show success message
          alert('Thank you for your interest! We will contact you within 24 hours with your free quote.');
          
          // Reset form
          form.reset();
        } catch (error) {
          console.error('Form submission failed:', error);
          console.error('Error details:', error.message);
          alert('There was an error submitting your form. Please try again or contact us directly at (877) 717-7234.');
        }
      });
    }
  });
  
  /**
   * Initialize location-aware contact page content
   */
  async function initializeLocationAwareContact() {
    try {
      // Import location utilities if not already available
      if (!window.locationUtils) {
        const module = await import('/src/utils/location-detection.js');
        window.locationUtils = module;
      }
      
      // Get user location content
      const locationContent = await window.locationUtils.getUserLocationContent();
      
      if (locationContent && locationContent.state !== 'Multiple States') {
        // Update contact page hero content
        const heroTitle = document.getElementById('contact-hero-title');
        const heroSubtitle = document.getElementById('contact-hero-subtitle');
        const formHeading = document.getElementById('contact-form-heading');
        
        if (heroTitle) {
          heroTitle.textContent = `Contact PCFG Insurance - ${locationContent.state} Insurance Services`;
        }
        
        if (heroSubtitle) {
          heroSubtitle.textContent = `Ready to protect what matters most in ${locationContent.city || locationContent.state}? Get your free quote today from our licensed insurance experts.`;
        }
        
        if (formHeading) {
          formHeading.textContent = `Get Your Free ${locationContent.state} Insurance Quote`;
        }
        
        // Store location data in hidden fields
        const stateField = document.getElementById('contact-user-location-state');
        const cityField = document.getElementById('contact-user-location-city');
        
        if (stateField) stateField.value = locationContent.state;
        if (cityField) cityField.value = locationContent.city || '';
        
        // Pre-select state in dropdown if it matches
        const stateSelect = document.getElementById('state');
        if (stateSelect && locationContent.state) {
          const stateCode = getStateCodeFromName(locationContent.state);
          if (stateCode) {
            stateSelect.value = stateCode;
          }
        }
        
        console.log('Contact page personalized for:', locationContent);
      }
    } catch (error) {
      console.error('Failed to initialize location-aware contact page:', error);
    }
  }
  
  /**
   * Convert state name to state code for form pre-selection
   */
  function getStateCodeFromName(stateName) {
    const stateMap = {
      'Alabama': 'AL', 'Arizona': 'AZ', 'Florida': 'FL', 'Georgia': 'GA',
      'Indiana': 'IN', 'Maryland': 'MD', 'Maine': 'ME', 'New Jersey': 'NJ',
      'New York': 'NY', 'North Carolina': 'NC', 'Ohio': 'OH', 'Pennsylvania': 'PA',
      'Tennessee': 'TN', 'Texas': 'TX', 'Virginia': 'VA'
    };
    
    return stateMap[stateName] || '';
  }
</script>
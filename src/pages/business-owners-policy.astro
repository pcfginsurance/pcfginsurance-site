<script>

  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('bop-form');
    
    if (form) {
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);
        
        console.log('Submitting BOP lead data:', data);
        
        try {
          // Send data to Supabase
          if (window.submitToSupabase) {
            await window.submitToSupabase(data, 'bop_lead');
            console.log('Supabase submission successful');
          }
          
          // Show success message
          alert('Thank you for your interest! We will contact you within 24 hours with your Business Owner\'s Policy quote.');
          
          // Pre-populate commercial quote form with BOP data
          const params = new URLSearchParams({
            'name': `${data['first-name']} ${data['last-name']}`,
            'business-name': data['business-name'],
            'email': data['email'],
            'phone': data['phone'],
            'insurance-type': 'bop'
          });
          
          // Redirect to commercial quote form with pre-populated data
          window.location.href = `/commercial-quote?${params.toString()}`;
        } catch (error) {
          console.error('Form submission failed:', error);
          alert('There was an error submitting your form. Please try again or contact us directly at (877) 717-7234.');
        }
      });
    }
    
    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          target.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });
        }
      });
    });
  });
</script>
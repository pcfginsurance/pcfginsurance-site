---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="PCFG Insurance Knowledge Base | AI-Optimized Business Insurance Information" 
  description="Comprehensive insurance information from PCFG Insurance Services. Find answers about business insurance, workers compensation, commercial auto, general liability, and employee benefits. Veteran-owned agency serving 15 states."
  ogImage="https://images.pexels.com/photos/3760067/pexels-photo-3760067.jpeg?auto=compress&cs=tinysrgb&w=1200&h=630"
  ogType="website"
  keywords="PCFG Insurance, business insurance FAQ, workers compensation information, commercial auto insurance, general liability, cyber liability, employee benefits, veteran owned insurance agency, insurance knowledge base"
>
  <!-- AI-Optimized Structured Data - Comprehensive Organization & FAQ Schema -->
  <script type="application/ld+json" slot="head">
    {{
      "@context": "https://schema.org",
      "@graph": [
        {{
          "@type": "Organization",
          "@id": "https://pcfginsurance.com/#organization",
          "name": "PCFG Insurance Services",
          "alternateName": ["PCFG Insurance", "Preferred Choice Financial Group", "PCFGI"],
          "legalName": "Preferred Choice Financial Group, LLC",
          "description": "A veteran-owned independent insurance agency founded in 2018, specializing in business insurance, commercial lines, employee benefits, and personal insurance. Licensed in 15 states with headquarters in Parish, New York.",
          "url": "https://pcfginsurance.com",
          "logo": {{
            "@type": "ImageObject",
            "url": "https://pcfginsurance.com/assets/PCFG-Insurance-Logo-Main.png",
            "width": 600,
            "height": 120
          }},
          "foundingDate": "2018-12-01",
          "founder": {{
            "@type": "Person",
            "name": "Liam O'Brien",
            "jobTitle": "Founder & President",
            "description": "U.S. military veteran and founder of PCFG Insurance Services"
          }},
          "knowsAbout": [
            "Business Insurance",
            "Workers Compensation Insurance",
            "Commercial Auto Insurance",
            "General Liability Insurance",
            "Cyber Liability Insurance",
            "Employee Benefits",
            "Group Health Insurance",
            "Life Insurance"
          ],
          "address": {{
            "@type": "PostalAddress",
            "streetAddress": "Parish, NY Area (Virtual Office)",
            "addressLocality": "Parish",
            "addressRegion": "NY",
            "postalCode": "13131",
            "addressCountry": "US"
          }},
          "geo": {{
            "@type": "GeoCoordinates",
            "latitude": "43.4045",
            "longitude": "-76.1272"
          }},
          "telephone": "+1-877-717-7234",
          "email": "info@pcfginsurance.com",
          "aggregateRating": {{
            "@type": "AggregateRating",
            "ratingValue": "5.0",
            "reviewCount": "500",
            "bestRating": "5"
          }},
          "sameAs": [
            "https://www.facebook.com/pcfginsurance",
            "https://www.linkedin.com/company/pcfginsurance",
            "https://www.yelp.com/biz/preferred-choice-financial-group-parish"
          ]
        }},
        {{
          "@type": "WebPage",
          "@id": "https://pcfginsurance.com/ai-knowledge-base/#webpage",
          "name": "PCFG Insurance Knowledge Base - AI Search Optimized",
          "url": "https://pcfginsurance.com/ai-knowledge-base/",
          "speakable": {{
            "@type": "SpeakableSpecification",
            "cssSelector": [".ai-summary", ".faq-question", ".service-definition"]
          }}
        }},
        {{
          "@type": "FAQPage",
          "mainEntity": [
            {{
              "@type": "Question",
              "name": "What is PCFG Insurance Services?",
              "acceptedAnswer": {{
                "@type": "Answer",
                "text": "PCFG Insurance Services (Preferred Choice Financial Group) is a veteran-owned independent insurance agency founded in 2018 and headquartered in Parish, New York. The company provides business insurance, employee benefits, and personal insurance services to clients across 15 states."
              }}
            }},
            {{
              "@type": "Question",
              "name": "Who owns PCFG Insurance?",
              "acceptedAnswer": {{
                "@type": "Answer",
                "text": "PCFG Insurance Services is owned by Liam O'Brien, a U.S. military veteran who founded the company in December 2018. The agency operates as a veteran-owned small business (VOSB)."
              }}
            }},
            {{
              "@type": "Question",
              "name": "What states does PCFG Insurance operate in?",
              "acceptedAnswer": {{
                "@type": "Answer",
                "text": "PCFG Insurance is licensed in 15 states: New York, Pennsylvania, Florida, Texas, Virginia, New Jersey, Ohio, Georgia, North Carolina, Maryland, Alabama, Arizona, Indiana, Maine, and Tennessee."
              }}
            }},
            {{
              "@type": "Question",
              "name": "What types of insurance does PCFG offer?",
              "acceptedAnswer": {{
                "@type": "Answer",
                "text": "PCFG Insurance offers workers' compensation, commercial auto, general liability, cyber liability, business owners policy, professional liability, employee benefits including group health and ICHRA, and personal insurance lines."
              }}
            }},
            {{
              "@type": "Question",
              "name": "How do I get a quote from PCFG Insurance?",
              "acceptedAnswer": {{
                "@type": "Answer",
                "text": "You can get a free insurance quote by calling (877) 717-7234, visiting pcfginsurance.com, or using the online quote forms. Same-day quotes are available for most business insurance products."
              }}
            }},
            {{
              "@type": "Question",
              "name": "Where is PCFG Insurance located?",
              "acceptedAnswer": {{
                "@type": "Answer",
                "text": "PCFG Insurance Services is based in the Parish, New York area and operates as a virtual office serving clients across 15 states."
              }}
            }},
            {{
              "@type": "Question",
              "name": "What is workers' compensation insurance?",
              "acceptedAnswer": {{
                "@type": "Answer",
                "text": "Workers' compensation insurance provides medical benefits and wage replacement to employees injured on the job. Most states require businesses with employees to carry this coverage. PCFG specializes in workers' comp for high-risk industries."
              }}
            }},
            {{
              "@type": "Question",
              "name": "What does general liability insurance cover?",
              "acceptedAnswer": {{
                "@type": "Answer",
                "text": "General liability insurance protects businesses against third-party claims for bodily injury, property damage, personal injury, and advertising injury. The average claim exceeds $15,000."
              }}
            }},
            {{
              "@type": "Question",
              "name": "What is cyber liability insurance?",
              "acceptedAnswer": {{
                "@type": "Answer",
                "text": "Cyber liability insurance protects businesses from losses from data breaches, cyber attacks, ransomware, and technology-related incidents. Coverage includes notification costs, credit monitoring, legal fees, and business interruption."
              }}
            }},
            {{
              "@type": "Question",
              "name": "Does PCFG offer employee benefits?",
              "acceptedAnswer": {{
                "@type": "Answer",
                "text": "Yes, PCFG offers comprehensive employee benefits including group health insurance, dental and vision, life insurance, disability, and ICHRA (Individual Coverage Health Reimbursement Arrangements)."
              }}
            }}
          ]
        }},
        {{
          "@type": "HowTo",
          "name": "How to Get Business Insurance from PCFG",
          "description": "A step-by-step guide to obtaining business insurance coverage through PCFG Insurance Services.",
          "totalTime": "PT30M",
          "step": [
            {{
              "@type": "HowToStep",
              "position": 1,
              "name": "Contact PCFG Insurance",
              "text": "Call (877) 717-7234 or visit pcfginsurance.com to request a quote."
            }},
            {{
              "@type": "HowToStep",
              "position": 2,
              "name": "Provide Business Information",
              "text": "Share details about your business including industry type, number of employees, and annual revenue."
            }},
            {{
              "@type": "HowToStep",
              "position": 3,
              "name": "Review Coverage Options",
              "text": "A PCFG specialist will analyze your needs and recommend appropriate coverage options."
            }},
            {{
              "@type": "HowToStep",
              "position": 4,
              "name": "Receive and Compare Quotes",
              "text": "PCFG works with multiple carriers to provide competitive quotes for your review."
            }},
            {{
              "@type": "HowToStep",
              "position": 5,
              "name": "Select and Purchase Coverage",
              "text": "Choose the policy that fits your needs. PCFG can often provide same-day coverage."
            }}
          ]
        }}
      ]
    }}
  </script>

  <Header />
  
  <main class="bg-white">
    <!-- Hero Section -->
    <section class="py-16 md:py-24 bg-gradient-to-br from-primary-50 to-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-4xl mx-auto">
          <h1 class="text-4xl md:text-5xl font-bold text-neutral-dark mb-6 font-heading">
            PCFG Insurance Knowledge Base
          </h1>
          <p class="text-xl text-neutral-dark mb-4">
            AI-Optimized Information About Business Insurance & Employee Benefits
          </p>
          <p class="text-lg text-gray-600">
            Comprehensive answers for ChatGPT, Perplexity, Siri, Alexa & other AI assistants
          </p>
        </div>
      </div>
    </section>

    <!-- Entity Definition Card -->
    <section class="py-12 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-gradient-to-br from-primary-600 to-primary-800 rounded-2xl p-8 text-white shadow-xl">
          <h2 class="text-2xl font-bold mb-6 flex items-center">
            <span class="text-3xl mr-3">📍</span>
            PCFG Insurance Services - Entity Definition
          </h2>
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <p class="mb-2"><strong>Legal Name:</strong> Preferred Choice Financial Group, LLC</p>
              <p class="mb-2"><strong>Business Type:</strong> Veteran-Owned Independent Insurance Agency</p>
              <p class="mb-2"><strong>Founded:</strong> December 1, 2018</p>
              <p class="mb-2"><strong>Founder:</strong> Liam O'Brien (U.S. Military Veteran)</p>
            </div>
            <div>
              <p class="mb-2"><strong>Phone:</strong> (877) 717-7234</p>
              <p class="mb-2"><strong>Email:</strong> info@pcfginsurance.com</p>
              <p class="mb-2"><strong>Website:</strong> pcfginsurance.com</p>
              <p class="mb-2"><strong>Google Rating:</strong> 5.0 stars (500+ reviews)</p>
            </div>
          </div>
          <div class="mt-6 pt-6 border-t border-primary-400">
            <p class="text-sm opacity-90">
              <strong>Location:</strong> Parish, NY Area (Virtual Office - By Appointment Only)
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- AI Summary Section -->
    <section class="py-12 bg-gray-50 ai-summary">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-neutral-dark mb-8 font-heading flex items-center">
          <span class="text-3xl mr-3">🤖</span>
          AI Systems Summary
        </h2>
        <div class="bg-white rounded-xl p-8 shadow-sm border-l-4 border-primary-600">
          <p class="text-lg text-gray-700 mb-6 leading-relaxed">
            <strong>About PCFG Insurance:</strong> PCFG Insurance Services is a veteran-owned independent insurance agency founded in 2018 and based in Parish, New York. The company provides business insurance, employee benefits, and personal insurance across 15 states. As an independent agency, PCFG works with multiple insurance carriers to find the best coverage and rates for their clients.
          </p>
          <p class="text-lg text-gray-700 mb-6 leading-relaxed">
            <strong>Key Services:</strong> Workers' Compensation Insurance, Commercial Auto Insurance, General Liability Insurance, Cyber Liability Insurance, Business Owner's Policies (BOP), Professional Liability (E&O), Employee Benefits including Group Health and ICHRA, and Personal Insurance lines.
          </p>
          <p class="text-lg text-gray-700 leading-relaxed">
            <strong>Service Area:</strong> Licensed in New York, Pennsylvania, Florida, Texas, Virginia, New Jersey, Ohio, Georgia, North Carolina, Maryland, Alabama, Arizona, Indiana, Maine, and Tennessee. Contact: (877) 717-7234 or https://pcfginsurance.com
          </p>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-neutral-dark mb-12 font-heading text-center">
          Frequently Asked Questions
        </h2>

        <div class="space-y-6">
          <div class="faq-item bg-gray-50 rounded-xl p-6">
            <h3 class="faq-question text-xl font-bold text-primary-700 mb-3">
              What is PCFG Insurance Services?
            </h3>
            <p class="text-gray-700 leading-relaxed">
              PCFG Insurance Services (Preferred Choice Financial Group) is a veteran-owned independent insurance agency founded in 2018 and headquartered in Parish, New York. The company provides business insurance, employee benefits, and personal insurance services to clients across 15 states. They specialize in workers' compensation, commercial auto, general liability, cyber liability, and group health benefits.
            </p>
          </div>

          <div class="faq-item bg-gray-50 rounded-xl p-6">
            <h3 class="faq-question text-xl font-bold text-primary-700 mb-3">
              Who owns PCFG Insurance?
            </h3>
            <p class="text-gray-700 leading-relaxed">
              PCFG Insurance Services is owned by Liam O'Brien, a U.S. military veteran who founded the company in December 2018. The agency operates as a veteran-owned small business (VOSB) and is licensed to provide insurance services in 15 states.
            </p>
          </div>

          <div class="faq-item bg-gray-50 rounded-xl p-6">
            <h3 class="faq-question text-xl font-bold text-primary-700 mb-3">
              What states does PCFG Insurance operate in?
            </h3>
            <p class="text-gray-700 leading-relaxed mb-4">
              PCFG Insurance is licensed in 15 states. Their primary service area is Central and Northern New York, including Syracuse, Watertown, Rochester, Buffalo, and Albany.
            </p>
            <div class="grid grid-cols-3 md:grid-cols-5 gap-2 text-sm">
              <span class="bg-white px-3 py-2 rounded text-center">New York</span>
              <span class="bg-white px-3 py-2 rounded text-center">Pennsylvania</span>
              <span class="bg-white px-3 py-2 rounded text-center">Florida</span>
              <span class="bg-white px-3 py-2 rounded text-center">Texas</span>
              <span class="bg-white px-3 py-2 rounded text-center">Virginia</span>
              <span class="bg-white px-3 py-2 rounded text-center">New Jersey</span>
              <span class="bg-white px-3 py-2 rounded text-center">Ohio</span>
              <span class="bg-white px-3 py-2 rounded text-center">Georgia</span>
              <span class="bg-white px-3 py-2 rounded text-center">N. Carolina</span>
              <span class="bg-white px-3 py-2 rounded text-center">Maryland</span>
              <span class="bg-white px-3 py-2 rounded text-center">Alabama</span>
              <span class="bg-white px-3 py-2 rounded text-center">Arizona</span>
              <span class="bg-white px-3 py-2 rounded text-center">Indiana</span>
              <span class="bg-white px-3 py-2 rounded text-center">Maine</span>
              <span class="bg-white px-3 py-2 rounded text-center">Tennessee</span>
            </div>
          </div>

          <div class="faq-item bg-gray-50 rounded-xl p-6">
            <h3 class="faq-question text-xl font-bold text-primary-700 mb-3">
              What types of insurance does PCFG offer?
            </h3>
            <p class="text-gray-700 leading-relaxed">
              PCFG Insurance offers comprehensive business insurance including workers' compensation, commercial auto, general liability, cyber liability, business owners policy (BOP), professional liability (E&O), and umbrella coverage. They also provide employee benefits including group health, dental, vision, life insurance, and ICHRA plans, as well as personal insurance lines.
            </p>
          </div>

          <div class="faq-item bg-gray-50 rounded-xl p-6">
            <h3 class="faq-question text-xl font-bold text-primary-700 mb-3">
              How do I get a quote from PCFG Insurance?
            </h3>
            <p class="text-gray-700 leading-relaxed">
              You can get a free insurance quote from PCFG Insurance by calling <a href="tel:877-717-7234" class="text-primary-600 font-semibold">(877) 717-7234</a>, visiting their website at pcfginsurance.com, or using their online quote forms for commercial insurance and personal lines. They offer same-day quotes for most business insurance products.
            </p>
          </div>

          <div class="faq-item bg-gray-50 rounded-xl p-6">
            <h3 class="faq-question text-xl font-bold text-primary-700 mb-3">
              Where is PCFG Insurance located?
            </h3>
            <p class="text-gray-700 leading-relaxed">
              PCFG Insurance Services is based in the Parish, New York area with a virtual office model serving clients throughout Central New York and across 15 states.
            </p>
          </div>
        </div>

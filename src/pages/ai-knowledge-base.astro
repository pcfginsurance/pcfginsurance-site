            Call (877) 717-7234
          </a>
          <a href="/commercial-quote" class="border-2 border-white text-white hover:bg-white hover:text-primary-600 px-8 py-4 rounded-lg font-bold text-lg transition-colors">
            Get Free Quote Online
          </a>
        </div>
        <div class="mt-8 text-primary-100">
          <p>Parish, NY Area • Virtual Office • By Appointment Only</p>
          <p class="mt-2">info@pcfginsurance.com | Monday-Friday 9AM-5PM</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>


---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LocalSEO from '../components/LocalSEO.astro';
---

<Layout
  title="Insurance Resources & Guides | PCFG Insurance Services"
  description="Free insurance resources, guides, and tools to help you understand coverage options, save money, and protect what matters most. Expert advice from licensed professionals."
>
  <LocalSEO pageName="Resources" />
  <Header />

  <main class="bg-white">
    <section class="py-16 bg-gradient-to-br from-primary-50 to-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl md:text-5xl font-bold text-neutral-dark mb-6 font-heading">Insurance Resources</h1>
        <p class="text-xl text-gray-600 max-w-3xl">Free guides, tools, and educational resources to help you make informed insurance decisions. All content created by licensed insurance professionals.</p>
      </div>
    </section>

    <section class="py-12 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
        <div class="bg-white border-2 border-primary rounded-lg p-6 shadow-lg">
          <div class="bg-primary text-white w-12 h-12 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-neutral-dark mb-3">Insurance Glossary</h2>
          <p class="text-gray-600 mb-4">Comprehensive dictionary of insurance terms, definitions, and concepts. Perfect for understanding your policies.</p>
          <a href="/insurance-glossary" class="text-primary font-semibold hover:underline flex items-center">
            View Glossary
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <div class="bg-white border-2 border-gray-200 rounded-lg p-6 shadow-lg hover:border-primary transition-colors">
          <div class="bg-gray-100 text-neutral-dark w-12 h-12 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-neutral-dark mb-3">Coverage Guides</h2>
          <p class="text-gray-600 mb-4">Detailed guides explaining different types of insurance coverage and what they protect.</p>
          <div class="space-y-2">
            <a href="/general-liability" class="text-primary hover:underline block">→ General Liability</a>
            <a href="/workers-compensation" class="text-primary hover:underline block">→ Workers Compensation</a>
            <a href="/auto-insurance" class="text-primary hover:underline block">→ Auto Insurance</a>
            <a href="/homeowners-insurance" class="text-primary hover:underline block">→ Homeowners Insurance</a>
          </div>
        </div>

        <div class="bg-white border-2 border-gray-200 rounded-lg p-6 shadow-lg hover:border-primary transition-colors">
          <div class="bg-gray-100 text-neutral-dark w-12 h-12 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-neutral-dark mb-3">Industry Resources</h2>
          <p class="text-gray-600 mb-4">Specialized guides for specific industries and business types we serve.</p>
          <a href="/industries" class="text-primary font-semibold hover:underline flex items-center">
            View Industries
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>

      <div class="mb-12">
        <h2 class="text-3xl font-bold text-neutral-dark mb-6">Free Tools & Calculators</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-gradient-to-br from-primary-50 to-white rounded-lg p-6 border-2 border-gray-200">
            <h3 class="text-xl font-bold text-neutral-dark mb-3">Life Insurance Needs Analysis</h3>
            <p class="text-gray-600 mb-4">Calculate how much life insurance coverage you need to protect your family's financial future.</p>
            <a href="/life-insurance-needs-analysis" class="bg-primary hover:bg-primary-dark text-white px-6 py-2 rounded-lg font-semibold transition-colors inline-block">Use Calculator</a>
          </div>

          <div class="bg-gray-50 rounded-lg p-6 border-2 border-gray-200">
            <h3 class="text-xl font-bold text-neutral-dark mb-3">Business Insurance Quote</h3>
            <p class="text-gray-600 mb-4">Get a customized insurance quote for your business in minutes.</p>
            <a href="/commercial-quote" class="bg-white hover:bg-gray-100 text-primary border-2 border-primary px-6 py-2 rounded-lg font-semibold transition-colors inline-block">Get Quote</a>
          </div>
        </div>
      </div>

      <div class="mb-12">
        <h2 class="text-3xl font-bold text-neutral-dark mb-6">Popular Articles & Guides</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
            <div class="p-6">
              <h3 class="text-xl font-bold text-neutral-dark mb-3">Understanding Workers' Compensation</h3>
              <p class="text-gray-600 mb-4">Essential guide for employers on workers' comp requirements, benefits, and best practices.</p>
              <a href="/workers-compensation" class="text-primary font-semibold hover:underline">Read More →</a>
            </div>
          </article>

          <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
            <div class="p-6">
              <h3 class="text-xl font-bold text-neutral-dark mb-3">Business Liability Protection</h3>
              <p class="text-gray-600 mb-4">Learn what general liability insurance covers and why every business needs it.</p>
              <a href="/general-liability" class="text-primary font-semibold hover:underline">Read More →</a>
            </div>
          </article>

          <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
            <div class="p-6">
              <h3 class="text-xl font-bold text-neutral-dark mb-3">Employee Benefits Guide</h3>
              <p class="text-gray-600 mb-4">Comprehensive overview of group health insurance and employee benefit options.</p>
              <a href="/employee-benefits" class="text-primary font-semibold hover:underline">Read More →</a>
            </div>
          </article>
        </div>
      </div>

      <div class="bg-white border-2 border-primary rounded-lg p-8">
        <h2 class="text-2xl font-bold text-neutral-dark mb-4">State-Specific Insurance Information</h2>
        <p class="text-gray-600 mb-6">Insurance requirements and regulations vary by state. We're licensed to serve clients in 15 states:</p>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-6">
          <div class="text-gray-700">• New York</div>
          <div class="text-gray-700">• Pennsylvania</div>
          <div class="text-gray-700">• Florida</div>
          <div class="text-gray-700">• Texas</div>
          <div class="text-gray-700">• California</div>
          <div class="text-gray-700">• Illinois</div>
          <div class="text-gray-700">• Ohio</div>
          <div class="text-gray-700">• Georgia</div>
          <div class="text-gray-700">• North Carolina</div>
          <div class="text-gray-700">• Virginia</div>
          <div class="text-gray-700">• New Jersey</div>
          <div class="text-gray-700">• Michigan</div>
          <div class="text-gray-700">• Tennessee</div>
          <div class="text-gray-700">• Indiana</div>
          <div class="text-gray-700">• Massachusetts</div>
        </div>
        <a href="/contact" class="text-primary font-semibold hover:underline">Contact us for state-specific information →</a>
      </div>

      <div class="mt-12 bg-gradient-to-br from-primary-50 to-white rounded-lg p-8">
        <h2 class="text-2xl font-bold text-neutral-dark mb-4">Need Personalized Advice?</h2>
        <p class="text-gray-700 mb-6">While our resources provide valuable information, every situation is unique. Speak with a licensed insurance professional for personalized guidance.</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="bg-primary hover:bg-primary-dark text-white px-8 py-3 rounded-lg font-semibold transition-colors text-center">Contact an Agent</a>
          <a href="tel:+18777177234" class="bg-white hover:bg-gray-50 text-primary border-2 border-primary px-8 py-3 rounded-lg font-semibold transition-colors text-center">Call (877) 717-7234</a>
        </div>
      </div>

      <div class="mt-12 text-center">
        <p class="text-sm text-gray-600">All resources are provided for educational purposes. For specific coverage advice, consult with a licensed insurance professional.</p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Builders Risk Insurance - PCFG Insurance Services" description="Comprehensive builders risk insurance for construction projects across 15 states. Protect buildings under construction, materials, and equipment. Get your free quote today.">
  <Header />

<!-- Hero Section -->
<section class="py-20 bg-gradient-to-br from-navy-50 to-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left Column -->
      <div>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          Builders Risk Insurance
        </h1>
        <p class="text-xl text-gray-600 mb-8">
          Specialized insurance coverage for buildings under construction and renovation projects. Protect your investment from fire, theft, vandalism, and weather damage during the construction phase.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#quote-form"
            class="bg-navy-600 hover:bg-navy-700 text-white px-8 py-3 rounded-md font-semibold text-center transition-colors duration-200">
            Get Free Quote
          </a>
        </div>
      </div>

      <!-- Right Column (Form) -->
      <div id="quote-form" class="bg-white p-8 rounded-lg shadow-xl">
        <h3 class="text-2xl font-semibold text-gray-900 mb-6 text-center">
          Get Your Builders Risk Quote
        </h3>
        <div class="w-full" style="min-height: 900px;">
          <iframe
            src="https://link.spartan-crm.com/widget/form/xOVCI4Wvy7sIPBsjTZ1i"
            style="width: 100%; border: none; overflow: hidden; height: 900px; min-height: 900px;"
            id="inline-builders-risk-form"
            data-layout="{'id':'INLINE'}"
            data-trigger-type="alwaysShow"
            data-form-name="Builders Risk - Website"
            data-height="900"
            title="Builders Risk - Website"
            scrolling="no"
            allow="payment">
          </iframe>
          <script src="https://link.spartan-crm.com/js/form_embed.js" type="text/javascript"></script>
        </div>
      </div>
    </div>
  </div>
</section>


  <!-- Licensed States Banner -->
  <section class="py-12 bg-navy-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-xl font-bold text-white mb-4">Builders Risk Coverage Available In:</h2>
        <div class="flex flex-wrap justify-center gap-3">
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Alabama</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Arizona</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Florida</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Georgia</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Indiana</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Maryland</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Maine</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">New Jersey</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">New York</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">North Carolina</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Ohio</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Pennsylvania</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Tennessee</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Texas</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Virginia</span>
        </div>
      </div>
    </div>
  </section>

  <!-- What is Builders Risk -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">What is Builders Risk Insurance?</h2>
          <p class="text-lg text-gray-600 mb-6">
            Builders risk insurance is specialized property insurance that covers buildings while they are under construction. It protects the structure, materials, equipment, and fixtures from various risks during the construction or renovation process.
          </p>
          <div class="mb-6">
            <h3 class="text-xl font-semibold text-gray-900 mb-3">What's Covered:</h3>
            <ul class="space-y-2 text-gray-600">
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Building under construction or renovation
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Materials, supplies, and equipment on-site
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Fire, lightning, and explosion damage
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Theft and vandalism
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Wind, hail, and weather damage
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Temporary structures and scaffolding
              </li>
            </ul>
          </div>
          <a href="#quote-form" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200">
            Get Builders Risk Quote
          </a>
        </div>
        <div class="bg-gray-100 p-8 rounded-lg">
          <div class="w-16 h-16 bg-navy-600 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h4 class="text-xl font-semibold text-gray-900 mb-4">Why You Need Builders Risk</h4>
          <div class="bg-white p-4 rounded border-l-4 border-red-600 mb-4">
            <p class="text-sm text-red-700">
              <strong>Did you know?</strong> Construction projects worth millions can be lost to fire, theft, or weather damage without proper builders risk coverage.
            </p>
          </div>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start">
              <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
              Required by most construction lenders
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
              Protects your construction investment
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
              Covers materials before installation
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
              Essential for project completion
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Types of Projects Covered -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Types of Construction Projects We Cover</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          We provide builders risk coverage for a wide range of construction and renovation projects.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

        <!-- New Construction -->
        <div class="bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">New Construction</h3>
          <p class="text-gray-600 mb-4">
            Complete coverage for ground-up construction of residential, commercial, and industrial buildings.
          </p>
          <ul class="text-sm text-gray-600 space-y-1">
            <li>• Single-family homes</li>
            <li>• Multi-family dwellings</li>
            <li>• Commercial buildings</li>
            <li>• Industrial facilities</li>
            <li>• Mixed-use developments</li>
          </ul>
        </div>

        <!-- Renovations -->
        <div class="bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Renovations & Remodeling</h3>
          <p class="text-gray-600 mb-4">
            Protection for renovation projects, additions, and major remodeling work on existing structures.
          </p>
          <ul class="text-sm text-gray-600 space-y-1">
            <li>• Building additions</li>
            <li>• Interior renovations</li>
            <li>• Structural modifications</li>
            <li>• Historic restorations</li>
            <li>• Tenant improvements</li>
          </ul>
        </div>

        <!-- Specialty Projects -->
        <div class="bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Specialty Projects</h3>
          <p class="text-gray-600 mb-4">
            Customized coverage for unique construction projects and specialized building types.
          </p>
          <ul class="text-sm text-gray-600 space-y-1">
            <li>• Churches and schools</li>
            <li>• Healthcare facilities</li>
            <li>• Hotels and resorts</li>
            <li>• Shopping centers</li>
            <li>• Infrastructure projects</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Who Needs Builders Risk -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Who Needs Builders Risk Insurance?</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Builders risk insurance is essential for anyone involved in a construction project.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">General Contractors</h3>
          <p class="text-gray-600">Protect your construction projects from start to completion.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Property Owners</h3>
          <p class="text-gray-600">Safeguard your investment during construction or renovation.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Developers</h3>
          <p class="text-gray-600">Essential coverage for residential and commercial developments.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Subcontractors</h3>
          <p class="text-gray-600">Protect your work and materials throughout the project.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Coverage Options -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Coverage Options & Endorsements</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Customize your builders risk policy with additional coverage options to meet your specific needs.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <h3 class="text-xl font-semibold text-gray-900 mb-4">Standard Coverage Includes:</h3>
          <ul class="space-y-3">
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-600 mt-0.5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <div>
                <h5 class="font-semibold text-gray-900">Building & Structure</h5>
                <p class="text-sm text-gray-600">Coverage for the building under construction</p>
              </div>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-600 mt-0.5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <div>
                <h5 class="font-semibold text-gray-900">Materials & Supplies</h5>
                <p class="text-sm text-gray-600">Building materials at the job site</p>
              </div>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-600 mt-0.5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <div>
                <h5 class="font-semibold text-gray-900">Temporary Structures</h5>
                <p class="text-sm text-gray-600">Scaffolding, fencing, and site facilities</p>
              </div>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-green-600 mt-0.5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <div>
                <h5 class="font-semibold text-gray-900">Debris Removal</h5>
                <p class="text-sm text-gray-600">Cost to remove debris after a covered loss</p>
              </div>
            </li>
          </ul>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-lg">
          <h3 class="text-xl font-semibold text-gray-900 mb-4">Optional Endorsements:</h3>
          <ul class="space-y-3">
            <li class="flex items-start">
              <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
              </svg>
              <div>
                <h5 class="font-semibold text-gray-900">Soft Costs Coverage</h5>
                <p class="text-sm text-gray-600">Lost rent, loan interest during delays</p>

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
---

<Layout title="ICHRA - Individual Coverage Health Reimbursement Arrangement | PCFG Insurance" description="Learn about ICHRA - Individual Coverage Health Reimbursement Arrangements. A flexible, cost-effective alternative to traditional group health insurance for businesses of all sizes.">
  <Header />

  <section class="py-20 bg-gradient-to-br from-navy-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">Individual Coverage Health Reimbursement Arrangement (ICHRA)</h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          A flexible, modern approach to employee health benefits that gives your team more choice and your business more control over healthcare costs.
        </p>
      </div>

      <div class="max-w-2xl mx-auto">
        <div class="bg-white p-8 rounded-lg shadow-xl">
          <h2 class="text-3xl font-bold text-gray-900 mb-6 text-center">Get Your ICHRA Quote</h2>
          <iframe
            src="https://api.leadconnectorhq.com/widget/form/EL6vg6rpLnn6rTF4XvTD"
            style="width:100%;min-height:900px;border:none;border-radius:3px"
            id="inline-ichra-form"
            data-layout="{'id':'INLINE'}"
            data-trigger-type="alwaysShow"
            data-trigger-value=""
            data-activation-type="alwaysActivated"
            data-activation-value=""
            data-deactivation-type="neverDeactivate"
            data-deactivation-value=""
            data-form-name="ICHRA - Website"
            data-height="927"
            data-layout-iframe-id="inline-ichra-form"
            data-form-id="EL6vg6rpLnn6rTF4XvTD"
            title="ICHRA Quote Form"
          >
          </iframe>
          <script src="https://link.msgsndr.com/js/form_embed.js"></script>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-20">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">What is ICHRA?</h2>
          <p class="text-lg text-gray-600 mb-6">
            Individual Coverage Health Reimbursement Arrangement (ICHRA) is a modern health benefit solution that allows employers to reimburse employees tax-free for individual health insurance premiums and medical expenses.
          </p>
          <p class="text-lg text-gray-600 mb-6">
            Unlike traditional group health plans, ICHRA gives employees the freedom to choose their own health insurance plan while employers maintain predictable, fixed monthly costs.
          </p>
          <div class="bg-primary-50 border-l-4 border-primary p-6 rounded-r-lg">
            <p class="text-gray-900 font-semibold mb-2">Perfect for:</p>
            <ul class="space-y-2 text-gray-700">
              <li class="flex items-start">
                <svg class="w-5 h-5 text-primary mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Small businesses seeking cost-effective benefits</span>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-primary mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Companies with remote or distributed teams</span>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-primary mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>Employers wanting to offer flexible benefits</span>
              </li>
            </ul>
          </div>
        </div>
        <div>
          <img
            src="https://images.pexels.com/photos/6238050/pexels-photo-6238050.jpeg?auto=compress&cs=tinysrgb&w=1200"
            alt="Business professional reviewing health insurance options"
            class="rounded-lg shadow-lg w-full h-auto"
            loading="lazy"
            width="600"
            height="400"
          />
        </div>
      </div>

      <div class="mb-20">
        <h2 class="text-3xl font-bold text-gray-900 mb-12 text-center">Key Benefits of ICHRA</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200">
            <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Cost Control</h3>
            <p class="text-gray-600">
              Set fixed monthly allowances per employee class. No unexpected premium increases or renewal surprises.
            </p>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200">
            <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Employee Choice</h3>
            <p class="text-gray-600">
              Employees select the health plan that best fits their needs and keeps their doctors.
            </p>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200">
            <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Tax Advantages</h3>
            <p class="text-gray-600">
              Reimbursements are tax-free for employees and tax-deductible for employers.
            </p>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200">
            <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Easy Setup</h3>
            <p class="text-gray-600">
              Simple administration with less paperwork than traditional group plans.
            </p>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200">
            <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Location Flexibility</h3>
            <p class="text-gray-600">
              Perfect for remote teams across multiple states with varying healthcare markets.
            </p>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200">
            <div class="w-12 h-12 bg-primary-100 rounded-full flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Scalable Solution</h3>
            <p class="text-gray-600">
              Grows with your business - works for companies with 1 to 1000+ employees.
            </p>
          </div>
        </div>
      </div>

      <div class="mb-20">
        <h2 class="text-3xl font-bold text-gray-900 mb-8">How ICHRA Works</h2>
        <div class="space-y-8">
          <div class="flex gap-6">
            <div class="flex-shrink-0">
              <div class="w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center font-bold text-xl">
                1
              </div>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Employer Sets Allowances</h3>
              <p class="text-gray-600">
                You determine monthly reimbursement amounts based on employee classes (full-time, part-time, age, family size, etc.). You have complete control over your budget.
              </p>
            </div>
          </div>

          <div class="flex gap-6">
            <div class="flex-shrink-0">
              <div class="w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center font-bold text-xl">
                2
              </div>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Employees Choose Coverage</h3>
              <p class="text-gray-600">
                Employees shop for and purchase individual health insurance plans that meet their specific needs. They can use the Health Insurance Marketplace or work directly with agents.
              </p>
            </div>
          </div>

          <div class="flex gap-6">
            <div class="flex-shrink-0">
              <div class="w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center font-bold text-xl">
                3
              </div>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Submit Proof of Coverage</h3>
              <p class="text-gray-600">
                Employees provide proof of their health insurance coverage and submit receipts for premiums and eligible medical expenses.
              </p>
            </div>
          </div>

          <div class="flex gap-6">
            <div class="flex-shrink-0">
              <div class="w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center font-bold text-xl">
                4
              </div>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Receive Tax-Free Reimbursement</h3>
              <p class="text-gray-600">
                You reimburse employees up to their allowance amount. Reimbursements are tax-free to employees and tax-deductible for your business.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="mb-20 bg-gray-50 p-8 rounded-lg">
        <h2 class="text-3xl font-bold text-gray-900 mb-8">ICHRA vs Traditional Group Health Insurance</h2>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b-2 border-gray-300">
                <th class="text-left py-4 px-4 font-semibold text-gray-900">Feature</th>
                <th class="text-left py-4 px-4 font-semibold text-gray-900">ICHRA</th>
                <th class="text-left py-4 px-4 font-semibold text-gray-900">Traditional Group Plan</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <tr>
                <td class="py-4 px-4 font-medium text-gray-900">Cost Predictability</td>
                <td class="py-4 px-4 text-gray-600">Fixed monthly allowances</td>
                <td class="py-4 px-4 text-gray-600">Variable premiums, annual increases</td>
              </tr>
              <tr>
                <td class="py-4 px-4 font-medium text-gray-900">Employee Choice</td>
                <td class="py-4 px-4 text-gray-600">Full plan selection freedom</td>
                <td class="py-4 px-4 text-gray-600">Limited to employer-selected plans</td>
              </tr>
              <tr>
                <td class="py-4 px-4 font-medium text-gray-900">Setup Complexity</td>
                <td class="py-4 px-4 text-gray-600">Simple, minimal paperwork</td>
                <td class="py-4 px-4 text-gray-600">Complex enrollment process</td>
              </tr>
              <tr>
                <td class="py-4 px-4 font-medium text-gray-900">Multi-State Teams</td>
                <td class="py-4 px-4 text-gray-600">Easy to manage</td>
                <td class="py-4 px-4 text-gray-600">Challenging, may need multiple plans</td>
              </tr>
              <tr>
                <td class="py-4 px-4 font-medium text-gray-900">Minimum Participation</td>
                <td class="py-4 px-4 text-gray-600">None required</td>
                <td class="py-4 px-4 text-gray-600">Often 70% or more</td>
              </tr>
              <tr>
                <td class="py-4 px-4 font-medium text-gray-900">Portability</td>
                <td class="py-4 px-4 text-gray-600">Employees keep their plan</td>
                <td class="py-4 px-4 text-gray-600">Coverage ends with employment</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="mb-20">
        <h2 class="text-3xl font-bold text-gray-900 mb-8">Frequently Asked Questions</h2>
        <div class="space-y-6">
          <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200">
            <h3 class="text-xl font-semibold text-gray-900 mb-3">What expenses can be reimbursed through ICHRA?</h3>
            <p class="text-gray-600">
              ICHRA can reimburse individual health insurance premiums (including those purchased on the Health Insurance Marketplace), Medicare premiums, and out-of-pocket medical expenses as defined by IRS Section 213(d).
            </p>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200">
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Can I offer different allowances to different employees?</h3>
            <p class="text-gray-600">
              Yes! You can create different allowance amounts based on employee classes such as full-time vs. part-time, geographic location, age, family size, or length of employment. However, all employees within the same class must receive the same allowance.
            </p>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200">
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Is there a minimum company size to offer ICHRA?</h3>
            <p class="text-gray-600">
              No! ICHRA is available to employers of all sizes, from sole proprietors with one employee to large corporations. This makes it an ideal solution for small businesses that couldn't afford traditional group plans.
            </p>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200">
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Can employees use ICHRA with Marketplace subsidies?</h3>
            <p class="text-gray-600">
              If your ICHRA offer is considered "affordable" under ACA guidelines, employees cannot receive premium tax credits on the Marketplace. However, they can decline the ICHRA and purchase coverage with subsidies if eligible.
            </p>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200">
            <h3 class="text-xl font-semibold text-gray-900 mb-3">What happens to unused ICHRA funds?</h3>
            <p class="text-gray-600">
              Unused ICHRA allowances do not roll over to the next month and are not paid out to employees. You only pay for what employees actually claim, which helps control costs.
            </p>
          </div>
        </div>
      </div>

      <div class="bg-primary-50 border-l-4 border-primary p-8 rounded-r-lg">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Ready to Explore ICHRA for Your Business?</h2>
        <p class="text-lg text-gray-700 mb-6">
          Our employee benefits specialists will help you determine if ICHRA is the right fit for your company and guide you through the setup process.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <Button text="Contact Us Today" href="/contact" variant="primary" size="lg" />
          <Button text="Call (877) 717-7234" href="tel:8777177234" variant="secondary" size="lg" />
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

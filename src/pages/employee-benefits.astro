---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Employee Benefits - PCFG Insurance Services" description="Comprehensive employee benefits solutions including group health insurance, dental, vision, life insurance, disability, and retirement plans for businesses of all sizes.">
  <Header />
  
  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-br from-navy-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">Employee Benefits</h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Attract and retain top talent with comprehensive employee benefits packages tailored to your business needs and budget.
        </p>
      </div>

      <!-- Employee Benefits Form -->
      <div id="benefits-form" class="max-w-2xl mx-auto">
        <div class="quote-form-container bg-white p-8 rounded-lg shadow-xl">
          <h2 class="text-3xl font-bold text-gray-900 mb-6 text-center">Get Your Employee Benefits Quote</h2>
          <iframe
            src="https://api.leadconnectorhq.com/widget/form/EL6vg6rpLnn6rTF4XvTD"
            style="width:100%;min-height:900px;border:none;border-radius:3px"
            id="inline-EL6vg6rpLnn6rTF4XvTD"
            data-layout="{'id':'INLINE'}"
            data-trigger-type="alwaysShow"
            data-trigger-value=""
            data-activation-type="alwaysActivated"
            data-activation-value=""
            data-deactivation-type="neverDeactivate"
            data-deactivation-value=""
            data-form-name="Employee Benefits - Website"
            data-height="927"
            data-layout-iframe-id="inline-EL6vg6rpLnn6rTF4XvTD"
            data-form-id="EL6vg6rpLnn6rTF4XvTD"
            title="Employee Benefits - Website"
          >
          </iframe>
          <script src="https://link.msgsndr.com/js/form_embed.js"></script>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Employee Benefits Types -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Group Health Insurance -->
      <div id="group-health" class="mb-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-3xl font-bold text-gray-900 mb-6">Group Health Insurance</h2>
            <p class="text-lg text-gray-600 mb-6">
              Comprehensive medical coverage for your employees and their families. We work with top carriers to provide quality healthcare options at competitive group rates.
            </p>
            <div class="mb-6">
              <h3 class="text-xl font-semibold text-gray-900 mb-3">Plan Types:</h3>
              <ul class="space-y-3 text-gray-600">
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span><strong>HMO Plans:</strong> Lower cost with network restrictions and primary care coordination</span>
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span><strong>PPO Plans:</strong> More flexibility with out-of-network options and specialist access</span>
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span><strong>HDHP Plans:</strong> High deductible plans with HSA eligibility for tax savings</span>
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span><strong>EPO Plans:</strong> Exclusive provider networks with no referral requirements</span>
                </li>
              </ul>
            </div>
            <a href="#benefits-form" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200">
              Get Group Health Quote
            </a>
          </div>
          <div class="bg-gray-100 p-8 rounded-lg">
            <div class="w-16 h-16 bg-navy-600 rounded-lg flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
              </svg>
            </div>
            <h4 class="text-xl font-semibold text-gray-900 mb-4">Why Offer Group Health?</h4>
            <ul class="space-y-3 text-gray-600">
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
                Attract and retain top talent
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
                Tax advantages for your business
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
                Group rates lower than individual coverage
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
                Healthier, more productive workforce
              </li>
            </ul>
          </div>
        </div>
      </div>
      
      <!-- MVP and MEC Plans -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-20">
        
        <!-- MVP Plans -->
        <div id="mvp-plans" class="bg-white p-8 rounded-lg shadow-lg">
          <div class="w-16 h-16 bg-green-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Minimum Value Plans (MVP)</h3>
          <p class="text-gray-600 mb-6">
            Cost-effective health plans that meet ACA minimum value requirements while providing essential coverage at lower premiums.
          </p>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-3">MVP Features:</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• Meets 60% minimum actuarial value</li>
              <li>• Lower premium costs</li>
              <li>• Essential health benefits included</li>
              <li>• Preventive care coverage</li>
              <li>• Prescription drug benefits</li>
              <li>• ACA employer mandate compliance</li>
            </ul>
          </div>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-3">Ideal For:</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• Cost-conscious employers</li>
              <li>• Businesses with younger workforce</li>
              <li>• Companies seeking ACA compliance</li>
              <li>• Organizations with tight budgets</li>
            </ul>
          </div>
          
          <a href="#benefits-form" class="bg-green-600 hover:bg-green-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200 w-full block text-center">
            Learn About MVP Plans
          </a>
        </div>
        
        <!-- MEC Plans -->
        <div id="mec-plans" class="bg-white p-8 rounded-lg shadow-lg">
          <div class="w-16 h-16 bg-blue-100 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Minimum Essential Coverage (MEC)</h3>
          <p class="text-gray-600 mb-6">
            Basic health coverage that satisfies the ACA individual mandate requirement, providing essential protection at the most affordable rates.
          </p>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-3">MEC Features:</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• Satisfies individual mandate</li>
              <li>• Lowest cost option</li>
              <li>• Preventive care included</li>
              <li>• Basic medical services</li>
              <li>• Limited benefit structure</li>
              <li>• No penalty for employees</li>
            </ul>
          </div>
          
          <div class="mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-3">Best For:</h4>
            <ul class="space-y-2 text-gray-600">
              <li>• Large employers (50+ employees)</li>
              <li>• High-turnover industries</li>
              <li>• Part-time workforce</li>
              <li>• Minimum compliance strategy</li>
            </ul>
          </div>
          
          <a href="#benefits-form" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200 w-full block text-center">
            Learn About MEC Plans
          </a>
        </div>
      </div>
      
      <!-- Dental & Vision -->
      <div id="dental-vision" class="mb-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="bg-gray-100 p-8 rounded-lg order-2 lg:order-1">
            <div class="w-16 h-16 bg-navy-600 rounded-lg flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
            </div>
            <h4 class="text-xl font-semibold text-gray-900 mb-4">Coverage Options</h4>
            <div class="space-y-4">
              <div class="bg-white p-4 rounded border-l-4 border-navy-600">
                <h5 class="font-semibold text-gray-900">Dental Plans</h5>
                <ul class="text-sm text-gray-600 space-y-1">
                  <li>• Preventive care coverage</li>
                  <li>• Basic and major services</li>
                  <li>• Orthodontic benefits</li>
                  <li>• Annual maximums options</li>
                </ul>
              </div>
              <div class="bg-white p-4 rounded border-l-4 border-navy-600">
                <h5 class="font-semibold text-gray-900">Vision Plans</h5>
                <ul class="text-sm text-gray-600 space-y-1">
                  <li>• Eye exams</li>
                  <li>• Frames and lenses</li>
                  <li>• Contact lens coverage</li>
                  <li>• Discounts on LASIK</li>
                </ul>
              </div>
            </div>
          </div>
          <div class="order-1 lg:order-2">
            <h2 class="text-3xl font-bold text-gray-900 mb-6">Dental & Vision Insurance</h2>
            <p class="text-lg text-gray-600 mb-6">
              Enhance your benefits package with affordable dental and vision coverage. These popular benefits help maintain employee health and productivity while being cost-effective for employers.
            </p>
            <div class="mb-6">
              <h3 class="text-xl font-semibold text-gray-900 mb-3">Key Benefits:</h3>
              <ul class="space-y-2 text-gray-600">
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Highly valued by employees at relatively low cost
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Preventive care reduces major health issues
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Flexible plan designs to fit your budget
                </li>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Voluntary options available (employee-paid)
                </li>
              </ul>
            </div>
            <a href="#benefits-form" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200">
              Get Dental & Vision Quote
            </a>
          </div>
        </div>
      </div>
      
      <!-- Group Life & Disability -->
      <div id="life-disability" class="mb-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-3xl font-bold text-gray-900 mb-6">Group Life & Disability Insurance</h2>
            <p class="text-lg text-gray-600 mb-6">
              Provide financial security for your employees and their families with group life and disability coverage. These benefits offer protection during life's most challenging times.
            </p>
            <div class="mb-6">
              <h3 class="text-xl font-semibold text-gray-900 mb-3">Coverage Types:</h3>
              <div class="space-y-4">
                <div class="border-l-4 border-navy-600 pl-4">
                  <h4 class="font-semibold text-gray-900">Group Life Insurance</h4>
                  <p class="text-gray-600">Financial protection for employees' families in case of death</p>
                </div>
                <div class="border-l-4 border-navy-600 pl-4">
                  <h4 class="font-semibold text-gray-900">Short-Term Disability</h4>
                  <p class="text-gray-600">Income replacement for temporary disabilities (typically 3-6 months)</p>
                </div>
                <div class="border-l-4 border-navy-600 pl-4">
                  <h4 class="font-semibold text-gray-900">Long-Term Disability</h4>
                  <p class="text-gray-600">Extended income protection for serious disabilities</p>
                </div>
                <div class="border-l-4 border-navy-600 pl-4">
                  <h4 class="font-semibold text-gray-900">Accidental Death & Dismemberment</h4>
                  <p class="text-gray-600">Additional coverage for accidents resulting in death or serious injury</p>
                </div>
              </div>
            </div>
            <a href="#benefits-form" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200">
              Get Life & Disability Quote
            </a>
          </div>
          <div class="bg-gray-100 p-8 rounded-lg">
            <div class="w-16 h-16 bg-navy-600 rounded-lg flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
            </div>
            <h4 class="text-xl font-semibold text-gray-900 mb-4">Employer Advantages</h4>
            <ul class="space-y-2 text-gray-600">
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                </svg>
                Affordable group rates
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                </svg>
                Tax-deductible premiums
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                </svg>
                Guaranteed issue options (no medical exams)
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                </svg>
                Improved employee financial security
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                </svg>
                Employer-paid or voluntary options
              </li>
            </ul>
          </div>
        </div>
      </div>
      
      <!-- Retirement Plans -->
      <div id="retirement" class="mb-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="bg-gray-100 p-8 rounded-lg order-2 lg:order-1">
            <div class="w-16 h-16 bg-navy-600 rounded-lg flex items-center justify-center mb-6">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
              </svg>
            </div>
            <h4 class="text-xl font-semibold text-gray-900 mb-4">Plan Options</h4>
            <div class="space-y-4">
              <div class="bg-white p-4 rounded border-l-4 border-navy-600">
                <h5 class="font-semibold text-gray-900">401(k) Plans</h5>
                <p class="text-sm text-gray-600">Traditional tax-deferred retirement savings</p>
              </div>
              <div class="bg-white p-4 rounded border-l-4 border-navy-600">
                <h5 class="font-semibold text-gray-900">Roth 401(k) Options</h5>
                <p class="text-sm text-gray-600">After-tax contributions for tax-free growth</p>
              </div>
              <div class="bg-white p-4 rounded border-l-4 border-navy-600">
                <h5 class="font-semibold text-gray-900">SIMPLE IRAs</h5>
                <p class="text-sm text-gray-600">Simplified plans for small businesses</p>
              </div>
              <div class="bg-white p-4 rounded border-l-4 border-navy-600">
                <h5 class="font-semibold text-gray-900">SEP IRAs</h5>
                <p class="text-sm text-gray-600">Employer-funded retirement accounts</p>
              </div>
            </div>
          </div>
          <div class="order-1 lg:order-2">
            <h2 class="text-3xl font-bold text-gray-900 mb-6">Retirement Plans</h2>
            <p class="text-lg text-gray-600 mb-6">
              Help your employees prepare for their financial future with employer-sponsored retirement plans. We offer a range of options to fit businesses of all sizes.
            </p>
            <div class="mb-6">
              <h3 class="text-xl font-semibold text-gray-900 mb-3">Benefits of Offering Retirement Plans:</h3>
              <ul class="space-y-2 text-gray-600">
                <li class="flex items-start">

  <!-- Coverage Options -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Comprehensive Coverage Options</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Protect your business vehicles with comprehensive coverage options tailored to your specific needs and risks.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-6">Standard Coverage</h3>
          <div class="space-y-6">
            <div class="flex items-start">
              <div class="w-8 h-8 bg-navy-600 rounded-full flex items-center justify-center mr-4 mt-1">
                <span class="text-white text-sm font-bold">1</span>
              </div>
              <div>
                <h4 class="text-lg font-semibold text-gray-900 mb-2">Liability Coverage</h4>
                <p class="text-gray-600">Protects against bodily injury and property damage claims from accidents involving your commercial vehicles.</p>
              </div>
            </div>
            
            <div class="flex items-start">
              <div class="w-8 h-8 bg-navy-600 rounded-full flex items-center justify-center mr-4 mt-1">
                <span class="text-white text-sm font-bold">2</span>
              </div>
              <div>
                <h4 class="text-lg font-semibold text-gray-900 mb-2">Collision Coverage</h4>

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="General Liability Insurance - PCFG Insurance Services" description="Essential general liability insurance protection for businesses across 15 states. Protect against third-party claims, lawsuits, and unexpected liabilities. Get your free quote today.">
  <Header />
  
<!-- Hero Section -->
<section class="py-20 bg-gradient-to-br from-navy-50 to-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left Column -->
      <div>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          General Liability Insurance
        </h1>
        <p class="text-xl text-gray-600 mb-8">
          Essential protection against third-party claims for bodily injury, property damage, and personal injury.
          Safeguard your business from unexpected lawsuits and claims across 15 states.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#quote-form"
            class="bg-navy-600 hover:bg-navy-700 text-white px-8 py-3 rounded-md font-semibold text-center transition-colors duration-200">
            Get Free Quote
          </a>
        </div>
      </div>

      <!-- Right Column (Fixed Form) -->
      <div id="quote-form" class="bg-white p-8 rounded-lg shadow-xl overflow-visible">
        <h3 class="text-2xl font-semibold text-gray-900 mb-6 text-center">
          Get Your General Liability Quote
        </h3>
        <div class="relative w-full" style="min-height: 950px;">
          <iframe
    src="https://api.leadconnectorhq.com/widget/form/xOVCI4Wvy7sIPBsjTZ1i"
    style="width:100%;min-height:950px;border:none;border-radius:3px"
    id="inline-xOVCI4Wvy7sIPBsjTZ1i" 
    data-layout="{'id':'INLINE'}"
    data-trigger-type="alwaysShow"
    data-trigger-value=""
    data-activation-type="alwaysActivated"
    data-activation-value=""
    data-deactivation-type="neverDeactivate"
    data-deactivation-value=""
    data-form-name="General Liability - Website"
    data-height="1084"
    data-layout-iframe-id="inline-xOVCI4Wvy7sIPBsjTZ1i"
    data-form-id="xOVCI4Wvy7sIPBsjTZ1i"
    title="General Liability - Website"
        >
</iframe>
<script src="https://link.msgsndr.com/js/form_embed.js"></script>
        </div>
      </div>
    </div>
  </div>
</section>

  
  <!-- Licensed States Banner -->
  <section class="py-12 bg-navy-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-xl font-bold text-white mb-4">General Liability Coverage Available In:</h2>
        <div class="flex flex-wrap justify-center gap-3">
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Alabama</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Arizona</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Florida</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Georgia</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Indiana</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Maryland</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Maine</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">New Jersey</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">New York</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">North Carolina</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Ohio</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Pennsylvania</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Tennessee</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Texas</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Virginia</span>
        </div>
      </div>
    </div>
  </section>
  
  <!-- What is General Liability -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">What is General Liability Insurance?</h2>
          <p class="text-lg text-gray-600 mb-6">
            General liability insurance protects your business from financial losses due to third-party claims of bodily injury, property damage, and personal and advertising injury. It's fundamental coverage that every business needs.
          </p>
          <div class="mb-6">
            <h3 class="text-xl font-semibold text-gray-900 mb-3">What's Covered:</h3>
            <ul class="space-y-2 text-gray-600">
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Bodily injury claims from customers or visitors
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Property damage to third-party property
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Personal and advertising injury claims
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Products liability for defective products
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Completed operations liability
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Legal defense costs and settlements
              </li>
            </ul>
          </div>
          <a href="#quote-form" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200">
            Get General Liability Quote
          </a>
        </div>
        <div class="bg-gray-100 p-8 rounded-lg">
          <div class="w-16 h-16 bg-navy-600 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h4 class="text-xl font-semibold text-gray-900 mb-4">Why You Need General Liability</h4>
          <div class="bg-white p-4 rounded border-l-4 border-red-600 mb-4">
            <p class="text-sm text-red-700">
              <strong>Did you know?</strong> The average general liability claim costs over $15,000, but can reach into the millions for serious incidents.
            </p>
          </div>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start">
              <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
              Required by most commercial leases
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
              Needed for most business contracts
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
              Protects personal assets from business claims
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
              Provides peace of mind for business operations
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Common Claims Examples -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Real-World General Liability Claims</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          These examples show how general liability insurance protects businesses from unexpected claims and lawsuits.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        
        <!-- Slip and Fall -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Slip and Fall Accidents</h3>
          <p class="text-gray-600 mb-4">
            A customer slips on a wet floor in your store and breaks their wrist, requiring surgery and physical therapy.
          </p>
          <div class="bg-red-50 p-3 rounded border-l-4 border-red-400">
            <p class="text-sm text-red-700">
              <strong>Potential Cost:</strong> $25,000 - $75,000 in medical bills and lost wages
            </p>
          </div>
        </div>
        
        <!-- Property Damage -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Property Damage</h3>
          <p class="text-gray-600 mb-4">
            Your employee accidentally damages a client's expensive equipment while performing services at their location.
          </p>
          <div class="bg-orange-50 p-3 rounded border-l-4 border-orange-400">
            <p class="text-sm text-orange-700">
              <strong>Potential Cost:</strong> $10,000 - $100,000+ depending on equipment value
            </p>
          </div>
        </div>
        
        <!-- Product Liability -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l-1 12H6L5 9z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Product Liability</h3>
          <p class="text-gray-600 mb-4">
            A product you manufactured or sold causes injury to a customer, leading to medical bills and a lawsuit.
          </p>
          <div class="bg-purple-50 p-3 rounded border-l-4 border-purple-400">
            <p class="text-sm text-purple-700">
              <strong>Potential Cost:</strong> $50,000 - $1,000,000+ for serious injuries
            </p>
          </div>
        </div>
        
        <!-- Advertising Injury -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Advertising Injury</h3>
          <p class="text-gray-600 mb-4">
            A competitor claims your advertising campaign uses their copyrighted material or makes false statements about their business.
          </p>
          <div class="bg-blue-50 p-3 rounded border-l-4 border-blue-400">
            <p class="text-sm text-blue-700">
              <strong>Potential Cost:</strong> $15,000 - $250,000 in legal fees and damages
            </p>
          </div>
        </div>
        
        <!-- Completed Operations -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Completed Operations</h3>
          <p class="text-gray-600 mb-4">
            A construction project you completed six months ago develops structural problems, causing property damage to the building.
          </p>
          <div class="bg-green-50 p-3 rounded border-l-4 border-green-400">
            <p class="text-sm text-green-700">
              <strong>Potential Cost:</strong> $100,000 - $500,000+ for major structural repairs
            </p>
          </div>
        </div>
        
        <!-- Personal Injury -->
        <div class="bg-white p-6 rounded-lg shadow-lg">
          <div class="w-12 h-12 bg-yellow-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Personal Injury</h3>
          <p class="text-gray-600 mb-4">
            A customer claims your business violated their privacy or made defamatory statements that damaged their reputation.
          </p>
          <div class="bg-yellow-50 p-3 rounded border-l-4 border-yellow-400">
            <p class="text-sm text-yellow-700">
              <strong>Potential Cost:</strong> $20,000 - $200,000 in legal defense and damages
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Coverage Limits and Options -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Coverage Limits and Options</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Choose the right coverage limits and options to protect your business from potential liabilities.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-6">Standard Coverage Limits</h3>
          <div class="space-y-6">
            <div class="bg-white p-6 rounded-lg shadow-lg border-l-4 border-navy-600">
              <h4 class="text-lg font-semibold text-gray-900 mb-2">$1,000,000 / $2,000,000</h4>
              <p class="text-gray-600 mb-2">Most common for small to medium businesses</p>
              <ul class="text-sm text-gray-600 space-y-1">
                <li>• $1M per occurrence</li>
                <li>• $2M general aggregate</li>
                <li>• $1M products/completed operations aggregate</li>
              </ul>
            </div>
            
            <div class="bg-white p-6 rounded-lg shadow-lg border-l-4 border-blue-600">
              <h4 class="text-lg font-semibold text-gray-900 mb-2">$2,000,000 / $4,000,000</h4>
              <p class="text-gray-600 mb-2">Higher limits for increased protection</p>
              <ul class="text-sm text-gray-600 space-y-1">
                <li>• $2M per occurrence</li>
                <li>• $4M general aggregate</li>
                <li>• $2M products/completed operations aggregate</li>
              </ul>
            </div>
            
            <div class="bg-white p-6 rounded-lg shadow-lg border-l-4 border-green-600">
              <h4 class="text-lg font-semibold text-gray-900 mb-2">Custom Limits Available</h4>
              <p class="text-gray-600 mb-2">Tailored to your specific business needs</p>
              <ul class="text-sm text-gray-600 space-y-1">
                <li>• Higher limits for high-risk businesses</li>
                <li>• Lower limits for low-risk operations</li>
                <li>• Umbrella coverage for additional protection</li>
              </ul>
            </div>
          </div>
        </div>
        
        <div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-6">Additional Coverage Options</h3>
          <div class="bg-white p-6 rounded-lg shadow-lg">
            <ul class="space-y-4">
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <div>
                  <h5 class="font-semibold text-gray-900">Medical Payments Coverage</h5>
                  <p class="text-sm text-gray-600">Pays medical expenses regardless of fault ($5,000 - $10,000 typical)</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <div>
                  <h5 class="font-semibold text-gray-900">Fire Damage Legal Liability</h5>
                  <p class="text-sm text-gray-600">Coverage for fire damage to rented premises ($50,000 - $100,000)</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>

---
// Generate XML sitemap with local SEO focus
export async function GET() {
  const baseUrl = 'https://pcfginsurance.com';
  
  const pages = [
    { url: '', priority: '1.0', changefreq: 'weekly' },
    { url: '/about', priority: '0.9', changefreq: 'monthly' },
    { url: '/contact', priority: '0.9', changefreq: 'monthly' },
    { url: '/services', priority: '0.8', changefreq: 'weekly' },
    { url: '/personal-insurance', priority: '0.8', changefreq: 'weekly' },
    { url: '/employee-benefits', priority: '0.8', changefreq: 'weekly' },
    { url: '/workers-compensation', priority: '0.7', changefreq: 'monthly' },
    { url: '/commercial-auto', priority: '0.7', changefreq: 'monthly' },
    { url: '/general-liability', priority: '0.7', changefreq: 'monthly' },
    { url: '/business-owners-policy', priority: '0.7', changefreq: 'monthly' },
    { url: '/industries', priority: '0.6', changefreq: 'monthly' },
    { url: '/client-services', priority: '0.6', changefreq: 'monthly' },
    { url: '/careers', priority: '0.5', changefreq: 'monthly' },
    { url: '/blog', priority: '0.5', changefreq: 'weekly' },
    { url: '/commercial-quote', priority: '0.8', changefreq: 'daily' },
    { url: '/personal-lines-quote', priority: '0.8', changefreq: 'daily' }
  ];

  const serviceAreas = [
    'Alabama', 'Arizona', 'Florida', 'Georgia', 'Indiana', 
    'Maryland', 'Maine', 'New Jersey', 'New York', 'North Carolina', 
    'Ohio', 'Pennsylvania', 'Tennessee', 'Texas', 'Virginia'
  ];

  const xml = `<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:geo="http://www.google.com/geo/schemas/sitemap/1.0"
        xmlns:news="http://www.google.com/schemas/sitemap-news/0.9">
  ${pages.map(page => `
  <url>
    <loc>${baseUrl}${page.url}</loc>
    <lastmod>${new Date().toISOString().split('T')[0]}</lastmod>
    <changefreq>${page.changefreq}</changefreq>
    <priority>${page.priority}</priority>
    <geo:geo>
      <geo:format>kml</geo:format>
    </geo:geo>
  </url>`).join('')}
  
  <!-- Location-specific pages for each service area -->
  ${serviceAreas.map(state => `
  <url>
    <loc>${baseUrl}/services/${state.toLowerCase().replace(' ', '-')}-insurance</loc>
    <lastmod>${new Date().toISOString().split('T')[0]}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>`).join('')}
</urlset>`;

  return new Response(xml, {
    headers: {
      'Content-Type': 'application/xml',
      'Cache-Control': 'public, max-age=3600'
    }
  });
}
---
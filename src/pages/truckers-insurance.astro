---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Truckers Insurance - Commercial Trucking Coverage | PCFG Insurance" description="Comprehensive trucking insurance for owner-operators, fleets, and motor carriers across 15 states. Primary liability, physical damage, cargo, and more.">
  <Header />

<!-- Hero Section -->
<section class="py-20 bg-gradient-to-br from-navy-50 to-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left Column -->
      <div>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          Truckers Insurance
        </h1>
        <p class="text-xl text-gray-600 mb-8">
          Comprehensive insurance solutions for trucking operations, owner-operators, and commercial motor carriers. From primary liability to cargo coverage, protect your business on every haul.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#quote-form"
            class="bg-navy-600 hover:bg-navy-700 text-white px-8 py-3 rounded-md font-semibold text-center transition-colors duration-200">
            Get Free Quote
          </a>
        </div>
      </div>

      <!-- Right Column (Form) -->
      <div id="quote-form" class="bg-white p-8 rounded-lg shadow-xl">
        <h3 class="text-2xl font-semibold text-gray-900 mb-6 text-center">
          Get Your Trucking Insurance Quote
        </h3>
        <div class="w-full" style="min-height: 900px;">
          <iframe
            src="https://link.spartan-crm.com/widget/form/xOVCI4Wvy7sIPBsjTZ1i"
            style="width: 100%; border: none; overflow: hidden; height: 900px; min-height: 900px;"
            id="inline-truckers-form"
            data-layout="{'id':'INLINE'}"
            data-trigger-type="alwaysShow"
            data-form-name="Truckers Insurance - Website"
            data-height="900"
            title="Truckers Insurance - Website"
            scrolling="no"
            allow="payment">
          </iframe>
          <script src="https://link.spartan-crm.com/js/form_embed.js" type="text/javascript"></script>
        </div>
      </div>
    </div>
  </div>
</section>

  <!-- Licensed States Banner -->
  <section class="py-12 bg-navy-600">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-xl font-bold text-white mb-4">Trucking Insurance Available In:</h2>
        <div class="flex flex-wrap justify-center gap-3">
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Alabama</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Arizona</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Florida</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Georgia</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Indiana</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Maryland</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Maine</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">New Jersey</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">New York</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">North Carolina</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Ohio</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Pennsylvania</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Tennessee</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Texas</span>
          <span class="bg-white text-navy-600 px-3 py-1 rounded-full text-sm font-medium">Virginia</span>
        </div>
      </div>
    </div>
  </section>

  <!-- What is Truckers Insurance -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">What is Truckers Insurance?</h2>
          <p class="text-lg text-gray-600 mb-6">
            Truckers insurance is specialized commercial auto coverage designed for the unique risks of trucking operations. It protects commercial motor carriers, owner-operators, and trucking companies from liability, cargo damage, and vehicle losses.
          </p>
          <div class="mb-6">
            <h3 class="text-xl font-semibold text-gray-900 mb-3">Essential Coverages:</h3>
            <ul class="space-y-2 text-gray-600">
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Primary liability coverage (minimum $750K-$1M required)
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Physical damage coverage for trucks and trailers
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Cargo insurance for freight protection
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Motor truck cargo legal liability
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Non-trucking liability (bobtail coverage)
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Occupational accident insurance for drivers
              </li>
            </ul>
          </div>
          <a href="#quote-form" class="bg-navy-600 hover:bg-navy-700 text-white px-6 py-3 rounded-md font-semibold transition-colors duration-200">
            Get Trucking Quote
          </a>
        </div>
        <div class="bg-gray-100 p-8 rounded-lg">
          <div class="w-16 h-16 bg-navy-600 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <h4 class="text-xl font-semibold text-gray-900 mb-4">Federal Compliance Requirements</h4>
          <div class="bg-white p-4 rounded border-l-4 border-red-600 mb-4">
            <p class="text-sm text-red-700">
              <strong>DOT/FMCSA Requirement:</strong> All commercial motor carriers must maintain minimum liability insurance and file proof with the FMCSA.
            </p>
          </div>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start">
              <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
              BMC-91 or BMC-91X filing
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
              Minimum $750K liability coverage
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
              Operating authority documentation
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
              </svg>
              Continuous coverage maintenance
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Types of Operations -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">We Insure All Types of Trucking Operations</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Specialized coverage for every type of commercial trucking operation.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Owner-Operators</h3>
          <ul class="text-sm text-gray-600 space-y-1">
            <li>• Independent contractors</li>
            <li>• Single truck operations</li>
            <li>• Leased to carriers</li>
            <li>• Under own authority</li>
          </ul>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Small Fleets</h3>
          <ul class="text-sm text-gray-600 space-y-1">
            <li>• 2-10 power units</li>
            <li>• Regional hauling</li>
            <li>• Growing operations</li>
            <li>• Family-owned businesses</li>
          </ul>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Large Fleets</h3>
          <ul class="text-sm text-gray-600 space-y-1">
            <li>• 10+ power units</li>
            <li>• Interstate operations</li>
            <li>• Multiple terminals</li>
            <li>• National coverage</li>
          </ul>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-lg hover:shadow-xl transition-shadow duration-200">
          <div class="w-12 h-12 bg-navy-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Motor Carriers</h3>
          <ul class="text-sm text-gray-600 space-y-1">
            <li>• For-hire carriers</li>
            <li>• Private carriers</li>
            <li>• Contract carriers</li>
            <li>• Freight brokers</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Coverage Types -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Essential Trucking Insurance Coverage</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Comprehensive protection designed specifically for commercial trucking operations.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Primary Liability -->
        <div class="bg-white p-8 rounded-lg shadow-lg">
          <div class="flex items-start mb-4">
            <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
              <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Primary Liability</h3>
              <p class="text-gray-600 mb-4">
                Required coverage for bodily injury and property damage caused by your truck.
              </p>
              <ul class="text-sm text-gray-600 space-y-2">
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Minimum $750K for general freight
                </li>
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  $1M+ for hazmat operations
                </li>
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Covers accidents and injuries
                </li>
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Legal defense included
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Physical Damage -->
        <div class="bg-white p-8 rounded-lg shadow-lg">
          <div class="flex items-start mb-4">
            <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
              <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Physical Damage</h3>
              <p class="text-gray-600 mb-4">
                Protects your trucks, trailers, and equipment from physical loss or damage.
              </p>
              <ul class="text-sm text-gray-600 space-y-2">
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Collision coverage
                </li>
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Comprehensive (fire, theft, vandalism)
                </li>
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Specified perils options
                </li>
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Trailer interchange coverage
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Motor Truck Cargo -->
        <div class="bg-white p-8 rounded-lg shadow-lg">
          <div class="flex items-start mb-4">
            <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">Motor Truck Cargo</h3>
              <p class="text-gray-600 mb-4">
                Covers the value of freight you're hauling for damage or loss.
              </p>
              <ul class="text-sm text-gray-600 space-y-2">
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Typical limits $50K-$250K
                </li>
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  All-risk or named perils
                </li>
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Reefer breakdown available
                </li>
                <li class="flex items-start">
                  <svg class="w-4 h-4 text-navy-600 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Required by most shippers
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Non-Trucking Liability -->

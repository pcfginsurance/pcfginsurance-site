---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="MSP/MSSP Partner Program - Cyber Insurance - PCFG Insurance Services" description="Partner with PCFG Insurance to offer cyber liability insurance to your clients. Turnkey revenue share program for MSPs, MSSPs, and IT consulting firms with dedicated support and co-branded materials.">
  <Header />

  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-br from-navy-600 to-navy-800 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="inline-block bg-white/10 backdrop-blur-sm px-4 py-2 rounded-full mb-6">
          <span class="text-sm font-semibold">MSP/MSSP Partner Program</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-6 text-white">
          Your Clients Trust You to Keep Their Networks Safe.<br>
          Now You Can Help Them Stay Financially Secure Too.
        </h1>
        <p class="text-xl text-navy-100 max-w-3xl mx-auto mb-8">
          Partner with PCFG Insurance Services to add Cyber Liability Insurance to your security stack. We handle the underwriting, quoting, and policy management — you stay the hero who solved the problem.
        </p>
        <a href="#partner-form" class="bg-white text-navy-600 hover:bg-gray-100 px-8 py-4 rounded-lg font-semibold text-lg transition-colors duration-200 inline-block">
          Become a Partner
        </a>
      </div>
    </div>
  </section>

  <!-- Program Highlights -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Program Highlights</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Everything you need to add cyber insurance as a value-added service for your clients
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-gradient-to-br from-green-50 to-white p-8 rounded-lg shadow-lg border border-green-100">
          <div class="w-16 h-16 bg-green-600 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Turnkey Revenue Share</h3>
          <p class="text-gray-600 text-lg">
            Earn competitive commissions for every policy sold. Create a new revenue stream without additional overhead or staffing requirements.
          </p>
        </div>

        <div class="bg-gradient-to-br from-blue-50 to-white p-8 rounded-lg shadow-lg border border-blue-100">
          <div class="w-16 h-16 bg-blue-600 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Dedicated Insurance Team</h3>
          <p class="text-gray-600 text-lg">
            Your clients get white-glove service from experienced cyber insurance specialists. We handle all the details so you can focus on IT.
          </p>
        </div>

        <div class="bg-gradient-to-br from-purple-50 to-white p-8 rounded-lg shadow-lg border border-purple-100">
          <div class="w-16 h-16 bg-purple-600 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Simple Digital Portal</h3>
          <p class="text-gray-600 text-lg">
            Easy-to-use referral portal for submitting client information. Track referrals, quotes, and commissions in real-time.
          </p>
        </div>

        <div class="bg-gradient-to-br from-orange-50 to-white p-8 rounded-lg shadow-lg border border-orange-100">
          <div class="w-16 h-16 bg-orange-600 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Co-Branded Marketing</h3>
          <p class="text-gray-600 text-lg">
            Professional marketing materials with your branding. Email templates, brochures, and client presentations ready to use.
          </p>
        </div>

        <div class="bg-gradient-to-br from-red-50 to-white p-8 rounded-lg shadow-lg border border-red-100">
          <div class="w-16 h-16 bg-red-600 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Fast Quote Turnaround</h3>
          <p class="text-gray-600 text-lg">
            Real-time quotes for qualified clients. Most cyber liability quotes delivered within 24-48 hours for quick client decisions.
          </p>
        </div>

        <div class="bg-gradient-to-br from-indigo-50 to-white p-8 rounded-lg shadow-lg border border-indigo-100">
          <div class="w-16 h-16 bg-indigo-600 rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-gray-900 mb-4">Nationwide Coverage</h3>
          <p class="text-gray-600 text-lg">
            Access to multiple A-rated carriers for comprehensive cyber liability coverage in all 50 states.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Partner With Us -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 mb-6">Why Partner With PCFG Insurance?</h2>
          <p class="text-lg text-gray-600 mb-8">
            Cyber attacks are increasing in frequency and severity. Your clients need protection, but insurance is complex and time-consuming. We make it simple.
          </p>

          <div class="space-y-6">
            <div class="flex items-start">
              <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">Complete Solution for Your Clients</h3>
                <p class="text-gray-600">
                  Offer a comprehensive security solution that includes both technical protection and financial coverage. Show clients you care about their total risk management.
                </p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">Zero Administrative Burden</h3>
                <p class="text-gray-600">
                  No insurance licensing required. No carrier relationships to manage. No policy administration. Just make referrals and earn commissions.
                </p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">Strengthen Client Relationships</h3>
                <p class="text-gray-600">
                  Position yourself as a trusted advisor who provides holistic solutions. Increase client retention by becoming their go-to for all security needs.
                </p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-gray-900 mb-2">Cyber Insurance Expertise</h3>
                <p class="text-gray-600">
                  Leverage our deep knowledge of cyber liability insurance underwriting requirements. We know what carriers want and help clients meet security standards.
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white p-8 rounded-lg shadow-xl">
          <div class="mb-6">
            <div class="text-4xl font-bold text-navy-600 mb-2">$9.4M</div>
            <p class="text-gray-600">Average cost of a data breach in 2023</p>
          </div>
          <div class="mb-6">
            <div class="text-4xl font-bold text-navy-600 mb-2">60%</div>
            <p class="text-gray-600">Of small businesses close within 6 months after a cyber attack</p>
          </div>
          <div class="mb-6">
            <div class="text-4xl font-bold text-navy-600 mb-2">300%</div>
            <p class="text-gray-600">Increase in ransomware attacks since 2020</p>
          </div>
          <div class="p-4 bg-red-50 border-l-4 border-red-600 rounded">
            <p class="text-gray-900 font-semibold mb-2">The Reality:</p>
            <p class="text-gray-600">
              Your clients face significant financial risk from cyber incidents. Technical controls reduce the likelihood, but cyber insurance protects against the financial impact.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Ideal Partners -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Ideal Partners</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          This program is designed for IT service providers who want to offer comprehensive risk management solutions
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-gradient-to-br from-blue-600 to-blue-800 text-white p-8 rounded-lg shadow-lg">
          <div class="w-16 h-16 bg-white/20 backdrop-blur-sm rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold mb-4">Managed Service Providers (MSPs)</h3>
          <p class="text-blue-100 mb-6">
            Enhance your managed IT services with cyber insurance protection. Help clients transfer financial risk while you manage their technical security.
          </p>
          <ul class="space-y-2 text-blue-100">
            <li class="flex items-start">
              <svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Complete security offering</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Increase monthly recurring revenue</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Differentiate from competitors</span>
            </li>
          </ul>
        </div>

        <div class="bg-gradient-to-br from-purple-600 to-purple-800 text-white p-8 rounded-lg shadow-lg">
          <div class="w-16 h-16 bg-white/20 backdrop-blur-sm rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold mb-4">Managed Security Service Providers (MSSPs)</h3>
          <p class="text-purple-100 mb-6">
            Round out your security services with financial protection. Your advanced security measures reduce premiums while insurance covers residual risk.
          </p>
          <ul class="space-y-2 text-purple-100">
            <li class="flex items-start">
              <svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Demonstrate ROI of security</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Better insurance rates for clients</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Holistic risk management</span>
            </li>
          </ul>
        </div>

        <div class="bg-gradient-to-br from-indigo-600 to-indigo-800 text-white p-8 rounded-lg shadow-lg">
          <div class="w-16 h-16 bg-white/20 backdrop-blur-sm rounded-lg flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold mb-4">IT Consulting Firms</h3>
          <p class="text-indigo-100 mb-6">
            Add cyber insurance recommendations to your consulting engagements. Help clients implement comprehensive risk strategies beyond technology.
          </p>
          <ul class="space-y-2 text-indigo-100">
            <li class="flex items-start">
              <svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Expand service offerings</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Strategic risk advisor role</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span>Additional revenue per project</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">How the Program Works</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Simple, streamlined process from referral to revenue
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-white p-6 rounded-lg shadow-lg text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-white">1</span>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Enroll in Program</h3>
          <p class="text-gray-600">
            Complete the simple partner application. Get immediate access to the referral portal and marketing materials.
          </p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-lg text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-white">2</span>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Submit Client Referrals</h3>
          <p class="text-gray-600">
            Use our digital portal to submit client information. Takes less than 5 minutes per referral.
          </p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-lg text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-white">3</span>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">We Handle the Rest</h3>
          <p class="text-gray-600">
            Our team contacts the client, gathers information, prepares quotes, and manages the application process.
          </p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-lg text-center">
          <div class="w-16 h-16 bg-navy-600 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-2xl font-bold text-white">4</span>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">Earn Commissions</h3>
          <p class="text-gray-600">
            Receive competitive commissions when policies bind. Earn renewal commissions year after year.
          </p>
        </div>
      </div>

      <div class="mt-12 bg-blue-50 border-l-4 border-blue-600 p-6 rounded">
        <div class="flex items-start">
          <svg class="w-6 h-6 text-blue-600 mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <h4 class="text-lg font-semibold text-gray-900 mb-2">You Stay in Control</h4>
            <p class="text-gray-600">
              Choose your level of involvement. Some partners prefer to introduce us and step back. Others want to stay involved throughout the process. Either way works with our flexible program.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Partner Application Form -->
  <section id="partner-form" class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Become a Partner Today</h2>
        <p class="text-xl text-gray-600">
          Join our growing network of MSP/MSSP partners earning additional revenue through cyber insurance referrals
        </p>
      </div>

      <div class="bg-white rounded-lg shadow-xl p-8" style="min-height: 950px;">
        <iframe
          src="https://link.spartan-crm.com/widget/form/purxMvrEmFijAVHAhvI4"
          style="width:100%;height:100%;border:none;border-radius:3px"
          id="inline-purxMvrEmFijAVHAhvI4"
          data-layout="{'id':'INLINE'}"
          data-trigger-type="alwaysShow"
          data-trigger-value=""
          data-activation-type="alwaysActivated"
          data-activation-value=""
          data-deactivation-type="neverDeactivate"
          data-deactivation-value=""
          data-form-name="Cyber Partnership"
          data-height="892"

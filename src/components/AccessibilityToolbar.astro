---
// Accessibility toolbar for users with visual impairments or reading difficulties
interface Props {
  showToolbar?: boolean;
}

const { showToolbar = true } = Astro.props;
---

{showToolbar && (
  <div id="accessibility-toolbar" class="fixed top-0 left-0 right-0 bg-gray-900 text-white p-2 z-50 transform -translate-y-full transition-transform duration-300">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
      <div class="flex items-center space-x-4">
        <span class="text-sm font-medium">Accessibility Options:</span>
        <button id="increase-text" class="text-xs bg-gray-700 hover:bg-gray-600 px-2 py-1 rounded">A+</button>
        <button id="decrease-text" class="text-xs bg-gray-700 hover:bg-gray-600 px-2 py-1 rounded">A-</button>
        <button id="high-contrast" class="text-xs bg-gray-700 hover:bg-gray-600 px-2 py-1 rounded">High Contrast</button>
        <button id="dyslexia-font" class="text-xs bg-gray-700 hover:bg-gray-600 px-2 py-1 rounded">Dyslexia Font</button>
        <button id="reading-guide" class="text-xs bg-gray-700 hover:bg-gray-600 px-2 py-1 rounded">Reading Guide</button>
      </div>
      <button id="close-toolbar" class="text-white hover:text-gray-300">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>
)}

<!-- Accessibility toggle button -->
<button id="accessibility-toggle" class="fixed bottom-4 right-4 bg-primary hover:bg-primary-dark text-white p-3 rounded-full shadow-lg z-40 transition-colors duration-200" aria-label="Open accessibility options">
  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
  </svg>
</button>

<!-- Reading guide overlay -->
<div id="reading-guide" class="fixed inset-0 pointer-events-none z-30 hidden">
  <div class="absolute inset-0 bg-black bg-opacity-50"></div>
  <div id="reading-window" class="absolute bg-transparent border-2 border-yellow-400 h-8 w-full transition-all duration-100"></div>
</div>

<style>
  /* High contrast mode styles */
  .high-contrast {
    filter: contrast(150%);
  }
  
  .high-contrast * {
    background-color: white !important;
    color: black !important;
    border-color: black !important;
  }
  
  .high-contrast a {
    color: #0000ff !important;
  }
  
  .high-contrast button {
    background-color: #000000 !important;
    color: #ffffff !important;
    border: 2px solid #000000 !important;
  }
  
  /* Dyslexia-friendly styles */
  .dyslexia-friendly * {
    font-family: 'Open Sans', 'Arial', sans-serif !important;
    letter-spacing: 0.12em !important;
    word-spacing: 0.16em !important;
    line-height: 1.8 !important;
  }
</style>
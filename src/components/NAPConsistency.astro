---
// NAP (Name, Address, Phone) Consistency Component
// Ensures consistent business information across all pages

interface Props {
  variant?: 'header' | 'footer' | 'contact' | 'inline' | 'schema';
  showEmail?: boolean;
  showHours?: boolean;
  showAddress?: boolean;
  className?: string;
}

const { 
  variant = 'inline',
  showEmail = true,
  showHours = false,
  showAddress = true,
  className = ''
} = Astro.props;

// Centralized NAP data - single source of truth
const NAP = {
  businessName: "PCFG Insurance Services",
  address: {
    street: "PO Box 609",
    city: "Parish", 
    state: "NY",
    zip: "13131",
    full: "PO Box 609, Parish, NY 13131"
  },
  phone: {
    display: "(877) 717-7234",
    tel: "877-717-7234",
    international: "+1-877-717-7234"
  },
  email: "info@pcfginsurance.com",
  hours: {
    weekdays: "Monday - Friday: 8:00 AM - 5:00 PM",
    saturday: "Saturday: By Appointment",
    sunday: "Sunday: Closed"
  }
};
---

{variant === 'header' && (
  <div class={`flex items-center space-x-6 text-sm ${className}`}>
    <a href={`tel:${NAP.phone.tel}`} class="flex items-center text-gray-600 hover:text-primary transition-colors">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
      </svg>
      {NAP.phone.display}
    </a>
    {showEmail && (
      <a href={`mailto:${NAP.email}`} class="flex items-center text-gray-600 hover:text-primary transition-colors">
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 002 2z"></path>
        </svg>
        {NAP.email}
      </a>
    )}
  </div>
)}

{variant === 'footer' && (
  <div class={`space-y-2 ${className}`}>
    <h4 class="text-lg font-semibold text-white mb-3">{NAP.businessName}</h4>
    {showAddress && (
      <div class="flex items-start text-gray-300">
        <svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        <div>
          <p>{NAP.address.street}</p>
          <p>{NAP.address.city}, {NAP.address.state} {NAP.address.zip}</p>
        </div>
      </div>
    )}
    <div class="flex items-center text-gray-300">
      <svg class="w-5 h-5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
      </svg>
      <a href={`tel:${NAP.phone.tel}`} class="hover:text-primary transition-colors">{NAP.phone.display}</a>
    </div>
    {showEmail && (
      <div class="flex items-center text-gray-300">
        <svg class="w-5 h-5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 002 2z"></path>
        </svg>
        <a href={`mailto:${NAP.email}`} class="hover:text-primary transition-colors">{NAP.email}</a>
      </div>
    )}
    {showHours && (
      <div class="flex items-start text-gray-300">
        <svg class="w-5 h-5 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <div>
          <p>{NAP.hours.weekdays}</p>
          <p>{NAP.hours.saturday}</p>
          <p>{NAP.hours.sunday}</p>
        </div>
      </div>
    )}
  </div>
)}

{variant === 'contact' && (
  <div class={`space-y-4 ${className}`}>
    {showAddress && (
      <div class="flex items-start">
        <svg class="w-6 h-6 text-primary mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        <div>
          <p class="font-medium text-neutral-dark">Mailing Address</p>
          <p class="text-neutral-dark">{NAP.address.street}</p>
          <p class="text-neutral-dark">{NAP.address.city}, {NAP.address.state} {NAP.address.zip}</p>
        </div>
      </div>
    )}
    
    <div class="flex items-start">
      <svg class="w-6 h-6 text-primary mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
      </svg>
      <div>
        <p class="font-medium text-neutral-dark">Phone</p>
        <a href={`tel:${NAP.phone.tel}`} class="text-neutral-dark hover:text-primary transition-colors">{NAP.phone.display}</a>
      </div>
    </div>
    
    {showEmail && (
      <div class="flex items-start">
        <svg class="w-6 h-6 text-primary mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 002 2z"></path>
        </svg>
        <div>
          <p class="font-medium text-neutral-dark">Email</p>
          <a href={`mailto:${NAP.email}`} class="text-neutral-dark hover:text-primary transition-colors">{NAP.email}</a>
        </div>
      </div>
    )}
    
    {showHours && (
      <div class="flex items-start">
        <svg class="w-6 h-6 text-primary mt-1 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <div>
          <p class="font-medium text-neutral-dark">Business Hours</p>
          <p class="text-neutral-dark">{NAP.hours.weekdays}</p>
          <p class="text-neutral-dark">{NAP.hours.saturday}</p>
          <p class="text-neutral-dark">{NAP.hours.sunday}</p>
        </div>
      </div>
    )}
  </div>
)}

{variant === 'inline' && (
  <span class={`inline-flex items-center ${className}`}>
    <a href={`tel:${NAP.phone.tel}`} class="text-primary hover:text-primary-dark font-semibold">
      {NAP.phone.display}
    </a>
  </span>
)}

{variant === 'schema' && (
  <!-- This variant only outputs structured data, no visible content -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "PostalAddress",
    "streetAddress": "{NAP.address.street}",
    "addressLocality": "{NAP.address.city}",
    "addressRegion": "{NAP.address.state}",
    "postalCode": "{NAP.address.zip}",
    "addressCountry": "US"
  }
  </script>
)}

<!-- Microdata for additional SEO -->
<div itemscope itemtype="https://schema.org/InsuranceAgency" style="display: none;">
  <span itemprop="name">{NAP.businessName}</span>
  <div itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
    <span itemprop="streetAddress">{NAP.address.street}</span>
    <span itemprop="addressLocality">{NAP.address.city}</span>
    <span itemprop="addressRegion">{NAP.address.state}</span>
    <span itemprop="postalCode">{NAP.address.zip}</span>
    <span itemprop="addressCountry">US</span>
  </div>
  <span itemprop="telephone">{NAP.phone.international}</span>
  <span itemprop="email">{NAP.email}</span>
  <span itemprop="url">https://pcfginsurance.com</span>
</div>
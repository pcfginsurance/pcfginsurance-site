<div class="bg-white p-6 rounded-lg shadow-lg" role="complementary" aria-labelledby="quote-form-heading">
  <h3 id="quote-form-title" class="text-xl font-semibold text-neutral-dark mb-4 font-heading">Get Your Free Quote</h3>
  
  
  <!-- Quote Form CTAs -->
  <div class="mt-4 space-y-3">
    <div class="p-4 bg-neutral-light rounded-lg border-l-4 border-primary">
      <p class="text-sm text-neutral-dark mb-2">
        <strong>Need comprehensive business coverage?</strong>
      </p>
      <a href="/commercial-quote" class="text-primary hover:text-primary-dark font-medium text-sm flex items-center">
        Complete our detailed commercial quote form
        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
    
    <div class="p-4 bg-neutral-light rounded-lg border-l-4 border-primary">
      <p class="text-sm text-neutral-dark mb-2">
        <strong>Looking for personal insurance?</strong>
      </p>
      <a href="/personal-lines-quote" class="text-primary hover:text-primary-dark font-medium text-sm flex items-center">
        Get a personalized quote for auto, home, or renters
        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
</div>
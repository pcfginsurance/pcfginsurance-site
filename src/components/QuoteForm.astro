---
---

<div class="bg-white p-6 rounded-lg shadow-lg" role="complementary" aria-labelledby="quote-form-heading">
  <h3 id="quote-form-title" class="text-xl font-semibold text-neutral-dark mb-4 font-heading">Get Your Free Quote</h3>

<div class="bg-white p-6 rounded-lg shadow-lg">
  <h3 class="text-xl font-semibold text-neutral-dark mb-4 font-heading">Get Your Free Quote</h3>

  <form id="hero-lead-form" class="space-y-4">
    <div>
      <label for="hero-name" class="block text-sm font-medium text-neutral-dark mb-1">Full Name *</label>
      <input
        type="text"
        id="hero-name"
        name="name"
        required
        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-primary focus:border-transparent"
        placeholder="John Smith"
      />
    </div>

    <div>
      <label for="hero-email" class="block text-sm font-medium text-neutral-dark mb-1">Email *</label>
      <input
        type="email"
        id="hero-email"
        name="email"
        required
        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-primary focus:border-transparent"
        placeholder="john@example.com"
      />
    </div>

    <div>
      <label for="hero-phone" class="block text-sm font-medium text-neutral-dark mb-1">Phone</label>
      <input
        type="tel"
        id="hero-phone"
        name="phone"
        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-primary focus:border-transparent"
        placeholder="(555) 123-4567"
      />
    </div>

    <div>
      <label for="hero-insurance-type" class="block text-sm font-medium text-neutral-dark mb-1">Insurance Type *</label>
      <select
        id="hero-insurance-type"
        name="insurance_type"
        required
        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-primary focus:border-transparent"
      >
        <option value="">Select insurance type...</option>
        <option value="Commercial">Commercial Insurance</option>
        <option value="Workers Compensation">Workers' Compensation</option>
        <option value="General Liability">General Liability</option>
        <option value="Commercial Auto">Commercial Auto</option>
        <option value="Business Owners Policy">Business Owners Policy</option>
        <option value="Employee Benefits">Employee Benefits</option>
        <option value="Personal Auto">Personal Auto</option>
        <option value="Home Insurance">Home Insurance</option>
        <option value="Life Insurance">Life Insurance</option>
        <option value="Health Insurance">Health Insurance</option>
        <option value="Other">Other</option>
      </select>
    </div>

    <div>
      <label for="hero-message" class="block text-sm font-medium text-neutral-dark mb-1">Message</label>
      <textarea
        id="hero-message"
        name="message"
        rows="3"
        class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-primary focus:border-transparent"
        placeholder="Tell us about your insurance needs..."
      ></textarea>
    </div>

    <div id="hero-form-message" class="hidden text-sm"></div>

    <button
      type="submit"
      class="w-full bg-primary text-white font-semibold py-3 px-6 rounded-md hover:bg-primary-dark transition-colors duration-200"
    >
      Get Free Quote
    </button>
  </form>
</div>

<script>
  import { Bolt Database } from '../utils/supabase.js';

  const form = document.getElementById('hero-lead-form') as HTMLFormElement;
  const messageDiv = document.getElementById('hero-form-message') as HTMLDivElement;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = submitButton.textContent;
      submitButton.disabled = true;
      submitButton.textContent = 'Submitting...';

      const formData = new FormData(form);

      const data = {
        name: formData.get('name') as string,
        email: formData.get('email') as string,
        phone: formData.get('phone') as string || null,
        insurance_type: formData.get('insurance_type') as string,
        message: formData.get('message') as string || null,
        city: null,
        state: null,
        ip_address: null,
        user_agent: navigator.userAgent
      };

      try {
        const { error } = await Bolt Database
          .from('lead_submissions')
          .insert([data]);

        if (error) throw error;

        messageDiv.textContent = 'Thank you! We\'ll contact you soon.';
        messageDiv.className = 'text-sm text-green-600 bg-green-50 p-3 rounded-md';
        messageDiv.classList.remove('hidden');

        form.reset();

        setTimeout(() => {
          messageDiv.classList.add('hidden');
        }, 5000);

      } catch (error) {
        console.error('Error submitting form:', error);
        messageDiv.textContent = 'Sorry, there was an error. Please try again or call us at (877) 717-7234.';
        messageDiv.className = 'text-sm text-red-600 bg-red-50 p-3 rounded-md';
        messageDiv.classList.remove('hidden');
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = originalText;
      }
    });
  }
</script>

  
  <!-- Quote Form CTAs -->
  <div class="mt-4 space-y-3">
    <div class="p-4 bg-neutral-light rounded-lg border-l-4 border-primary">
      <p class="text-sm text-neutral-dark mb-2">
        <strong>Need comprehensive business coverage?</strong>
      </p>
      <a href="/commercial-quote" class="text-primary hover:text-primary-dark font-medium text-sm flex items-center">
        Complete our detailed commercial quote form
        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
    
    <div class="p-4 bg-neutral-light rounded-lg border-l-4 border-primary">
      <p class="text-sm text-neutral-dark mb-2">
        <strong>Looking for personal insurance?</strong>
      </p>
      <a href="/personal-lines-quote" class="text-primary hover:text-primary-dark font-medium text-sm flex items-center">
        Get a personalized quote for auto, home, or renters
        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
</div>
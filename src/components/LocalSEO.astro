---
interface Props {
  pageName?: string;
  pageDescription?: string;
  serviceArea?: string[];
}

const { 
  pageName = "PCFG Insurance Services",
  pageDescription = "Professional insurance services for businesses and families",
  serviceArea = ["Alabama", "Arizona", "Florida", "Georgia", "Indiana", "Maryland", "Maine", "New Jersey", "New York", "North Carolina", "Ohio", "Pennsylvania", "Tennessee", "Texas", "Virginia"]
} = Astro.props;

// Business information for consistency
const businessInfo = {
  name: "PCFG Insurance Services",
  legalName: "PCFG Insurance Services LLC",
  address: {
    streetAddress: "PO Box 609",
    addressLocality: "Parish",
    addressRegion: "NY",
    postalCode: "13131",
    addressCountry: "US"
  },
  phone: "+1-877-717-7234",
  email: "info@pcfginsurance.com",
  url: "https://pcfginsurance.com",
  foundingDate: "2018-12-01",
  description: "Veteran-owned insurance agency providing comprehensive business and personal insurance solutions across 15 states including workers' compensation, commercial auto, general liability, and employee benefits."
};
---

<!-- Local Business Structured Data -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "InsuranceAgency",
  "name": "{businessInfo.name}",
  "legalName": "{businessInfo.legalName}",
  "description": "{businessInfo.description}",
  "foundingDate": "{businessInfo.foundingDate}",
  "url": "{businessInfo.url}",
  "logo": "{businessInfo.url}/assets/PCFG-Insurance-Logo-Main.png",
  "image": [
    "{businessInfo.url}/assets/PCFG-Insurance-Logo-Main.png"
  ],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "{businessInfo.address.streetAddress}",
    "addressLocality": "{businessInfo.address.addressLocality}",
    "addressRegion": "{businessInfo.address.addressRegion}",
    "postalCode": "{businessInfo.address.postalCode}",
    "addressCountry": "{businessInfo.address.addressCountry}"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "43.2456",
    "longitude": "-76.1234"
  },
  "telephone": "{businessInfo.phone}",
  "email": "{businessInfo.email}",
  "contactPoint": [
    {
      "@type": "ContactPoint",
      "telephone": "{businessInfo.phone}",
      "contactType": "customer service",
      "availableLanguage": "English",
      "areaServed": {serviceArea.map(state => `"${state}"`).join(', ')}
    },
    {
      "@type": "ContactPoint",
      "telephone": "{businessInfo.phone}",
      "contactType": "sales",
      "availableLanguage": "English",
      "areaServed": {serviceArea.map(state => `"${state}"`).join(', ')}
    }
  ],
  "areaServed": [
    {serviceArea.map(state => `{
      "@type": "State",
      "name": "${state}"
    }`).join(', ')}
  ],
  "serviceType": [
    "Workers' Compensation Insurance",
    "Commercial Auto Insurance", 
    "General Liability Insurance",
    "Business Owner's Policy",
    "Cyber Liability Insurance",
    "Professional Liability Insurance",
    "Employee Benefits",
    "Group Health Insurance",
    "Life Insurance",
    "Personal Auto Insurance",
    "Homeowners Insurance",
    "Renters Insurance",
    "Umbrella Insurance"
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Insurance Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Workers' Compensation Insurance",
          "description": "Comprehensive workers' compensation coverage for businesses across 15 states"
        }
      },
      {
        "@type": "Offer", 
        "itemOffered": {
          "@type": "Service",
          "name": "Commercial Auto Insurance",
          "description": "Fleet and commercial vehicle insurance protection"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service", 
          "name": "General Liability Insurance",
          "description": "Essential protection against third-party claims and lawsuits"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Employee Benefits",
          "description": "Comprehensive employee benefits including health, dental, vision, and retirement plans"
        }
      }
    ]
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:00",
      "closes": "17:00"
    }
  ],
  "paymentAccepted": ["Cash", "Check", "Credit Card", "Electronic Funds Transfer"],
  "currenciesAccepted": "USD",
  "priceRange": "$$",
  "sameAs": [
    "https://www.facebook.com/pcfginsurance",
    "https://www.linkedin.com/company/pcfg-insurance"
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5.0",
    "reviewCount": "50",
    "bestRating": "5",
    "worstRating": "1"
  },
  "review": [
    {
      "@type": "Review",
      "author": {
        "@type": "Person",
        "name": "Business Owner"
      },
      "reviewRating": {
        "@type": "Rating",
        "ratingValue": "5",
        "bestRating": "5"
      },
      "reviewBody": "Excellent service and competitive rates for our workers' compensation coverage."
    }
  ]
}
</script>

<!-- Organization Structured Data -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "{businessInfo.name}",
  "legalName": "{businessInfo.legalName}",
  "url": "{businessInfo.url}",
  "logo": "{businessInfo.url}/assets/PCFG-Insurance-Logo-Main.png",
  "foundingDate": "{businessInfo.foundingDate}",
  "description": "{businessInfo.description}",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "{businessInfo.address.streetAddress}",
    "addressLocality": "{businessInfo.address.addressLocality}",
    "addressRegion": "{businessInfo.address.addressRegion}",
    "postalCode": "{businessInfo.address.postalCode}",
    "addressCountry": "{businessInfo.address.addressCountry}"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "{businessInfo.phone}",
    "contactType": "customer service",
    "email": "{businessInfo.email}"
  },
  "sameAs": [
    "https://www.facebook.com/pcfginsurance",
    "https://www.linkedin.com/company/pcfg-insurance"
  ]
}
</script>

<!-- Local Business Hours -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "OpeningHoursSpecification",
  "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
  "opens": "08:00",
  "closes": "17:00",
  "validFrom": "2024-01-01",
  "validThrough": "2024-12-31"
}
</script>

<!-- Service Area Structured Data -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Insurance Services",
  "provider": {
    "@type": "InsuranceAgency",
    "name": "{businessInfo.name}"
  },
  "areaServed": [
    {serviceArea.map(state => `{
      "@type": "State",
      "name": "${state}",
      "@id": "https://en.wikipedia.org/wiki/${state.replace(' ', '_')}"
    }`).join(', ')}
  ],
  "serviceType": "Insurance Agency Services",
  "description": "Comprehensive insurance solutions for businesses and individuals across 15 states"
}
</script>

<!-- Breadcrumb Structured Data -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{businessInfo.url}"
    },
    {
      "@type": "ListItem", 
      "position": 2,
      "name": "{pageName}",
      "item": "{businessInfo.url}{Astro.url.pathname}"
    }
  ]
}
</script>

<!-- FAQ Structured Data for Insurance Questions -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What states does PCFG Insurance Services serve?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "PCFG Insurance Services is licensed to serve businesses and individuals in 15 states: Alabama, Arizona, Florida, Georgia, Indiana, Maryland, Maine, New Jersey, New York, North Carolina, Ohio, Pennsylvania, Tennessee, Texas, and Virginia."
      }
    },
    {
      "@type": "Question",
      "name": "What types of business insurance does PCFG offer?",
      "acceptedAnswer": {
        "@type": "Answer", 
        "text": "We offer comprehensive business insurance including Workers' Compensation, Commercial Auto, General Liability, Business Owner's Policy (BOP), Cyber Liability, Professional Liability, and Employee Benefits packages."
      }
    },
    {
      "@type": "Question",
      "name": "How quickly can I get an insurance quote?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We provide free insurance quotes within 24 hours of receiving your request. You can request a quote online or call us at (877) 717-7234 for immediate assistance."
      }
    }
  ]
}
</script>

<!-- Local SEO Meta Tags -->
<meta name="geo.region" content="US-NY" />
<meta name="geo.placename" content="Parish, New York" />
<meta name="geo.position" content="43.2456;-76.1234" />
<meta name="ICBM" content="43.2456, -76.1234" />

<!-- Local Business Citations -->
<meta name="business:contact_data:street_address" content="{businessInfo.address.streetAddress}" />
<meta name="business:contact_data:locality" content="{businessInfo.address.addressLocality}" />
<meta name="business:contact_data:region" content="{businessInfo.address.addressRegion}" />
<meta name="business:contact_data:postal_code" content="{businessInfo.address.postalCode}" />
<meta name="business:contact_data:country_name" content="United States" />
<meta name="business:contact_data:phone_number" content="{businessInfo.phone}" />
<meta name="business:contact_data:email" content="{businessInfo.email}" />
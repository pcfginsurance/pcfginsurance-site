---
import NAPConsistency from './NAPConsistency.astro';
---

<footer class="bg-neutral-dark text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Company Info -->
      <div class="col-span-1 md:col-span-2">
        <img src="/assets/PCFG-Insurance-Logo-Main.png" alt="PCFG Insurance Services" class="h-12 w-auto mb-4 brightness-0 invert">
        <p class="text-gray-300 mb-4">
          Veteran-owned insurance agency based in Parish, NY, protecting what matters most to your business and family across 15 states since 2018.
        </p>
        <NAPConsistency variant="footer" showEmail={true} showHours={false} showAddress={true} />
        <div class="flex space-x-4">
          <a href="https://www.facebook.com/pcfginsurance" class="text-gray-300 hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/company/pcfg-insurance" class="text-gray-300 hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>
      
      <!-- Quick Links -->
      <div>
        <h3 class="text-lg font-semibold mb-4 font-heading">Quick Links</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-gray-300 hover:text-primary-light transition-colors">Home</a></li>
          <li><a href="/about" class="text-gray-300 hover:text-primary-light transition-colors">About Us</a></li>
          <li><a href="/services" class="text-gray-300 hover:text-primary-light transition-colors">Business Insurance</a></li>
          <li><a href="/personal-insurance" class="text-gray-300 hover:text-primary-light transition-colors">Personal Insurance</a></li>
          <li><a href="/employee-benefits" class="text-gray-300 hover:text-primary-light transition-colors">Employee Benefits</a></li>
          <li><a href="/resources" class="text-gray-300 hover:text-primary-light transition-colors">Resources & Guides</a></li>
          <li><a href="/insurance-glossary" class="text-gray-300 hover:text-primary-light transition-colors">Insurance Glossary</a></li>
          <li><a href="/blog" class="text-gray-300 hover:text-primary-light transition-colors">Blog</a></li>
          <li><a href="/contact" class="text-gray-300 hover:text-primary-light transition-colors">Contact</a></li>
        </ul>
      </div>
      
      <!-- Contact Info -->
      <div>
        <h3 class="text-lg font-semibold mb-4 font-heading">Parish, NY Office</h3>
        <NAPConsistency variant="footer" showEmail={true} showHours={true} showAddress={true} />
        
        <!-- Client Services Quick Links -->
        <div class="mt-6">
          <h4 class="text-md font-semibold mb-2 font-heading">Client Services</h4>
          <ul class="space-y-1 text-sm text-gray-300">
            <li><a href="https://www6.nowcerts.com/Login.aspx?AgencyId=bd4cf416-6b8c-4c9b-8a76-d54654fbaf81&ShowAgencyLogo=true" target="_blank" rel="noopener noreferrer" class="hover:text-primary-light transition-colors">Client Portal</a></li>
            <li><a href="https://seppay.com/s/al?a=V18tksWZD3qgVTD1z2TO%2BA" target="_blank" rel="noopener noreferrer" class="hover:text-primary-light transition-colors">Make Payment</a></li>
            <li><a href="/client-services#certificate-request" class="hover:text-primary-light transition-colors">Request Certificate</a></li>
            <li><a href="/client-services#service-request" class="hover:text-primary-light transition-colors">Service Request</a></li>
            <li><a href="/client-services#report-claim" class="hover:text-primary-light transition-colors">Report Claim</a></li>
          </ul>
        </div>
      </div>
    </div>
    
    <div class="border-t border-gray-700 mt-8 pt-8 flex flex-col md:flex-row justify-between items-center">
      <p class="text-gray-300 text-sm">
        © 2024 PCFG Insurance Services, Parish, NY. All rights reserved. Licensed in 15 states.
      </p>
      <div class="flex space-x-6 mt-4 md:mt-0">
        <a href="/privacy" class="text-gray-300 hover:text-primary-light text-sm transition-colors">Privacy Policy</a>
        <a href="/terms" class="text-gray-300 hover:text-primary-light text-sm transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
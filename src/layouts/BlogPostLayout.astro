---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	heroImage?: string;
	author?: string;
}

const { title, description, pubDate, heroImage, author } = Astro.props;
---
<Layout {title} {description}>
  <Header />
	<article class="py-20 bg-white">
		<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-8">
				<h1 class="text-4xl font-bold text-gray-900">{title}</h1>
				<p class="mt-4 text-gray-500">
					Posted on {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
				</p>
			</div>
			{heroImage && <img width={720} height={360} src={heroImage} alt="" class="w-full h-auto rounded-lg shadow-lg mb-8" />}
			<div class="prose prose-lg max-w-none">
				<slot />
			</div>
			{author === "Liam O'Brien" && (
				<div class="mt-12 pt-8 border-t border-gray-200 flex items-center gap-4">
					<img
						src="https://storage.googleapis.com/msgsndr/adwiOgSaENtAsMUbOPW2/media/63d894e826d6cd0654fa0ea3.jpeg"
						alt="Liam O'Brien"
						class="w-16 h-16 rounded-full object-cover flex-shrink-0"
					/>
					<div>
						<p class="font-semibold text-gray-900 text-sm">Liam O'Brien</p>
						<p class="text-gray-500 text-sm">Founder & President, PCFG Insurance Services</p>
						<a
							href="https://linkedin.com/in/liamobrien2"
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center gap-1 text-blue-600 hover:text-blue-800 text-sm mt-1"
						>
							<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
								<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
							</svg>
							LinkedIn
						</a>
					</div>
				</div>
			)}
		</div>
	</article>
	<Footer />
</Layout>

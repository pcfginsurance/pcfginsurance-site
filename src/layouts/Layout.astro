---
export interface Props {
  title: string;
  description?: string;
  keywords?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
}

const { title, description = "PCFG Insurance Services - Protecting what matters most to your business and family across 15 states. Workers' comp, commercial auto, general liability, and more.", keywords = "insurance, workers compensation, commercial auto, general liability, business insurance, employee benefits", canonical, ogImage = "https://pcfginsurance.com/assets/PCFG-Insurance-Logo-Main.png", ogType = "website" } = Astro.props;

const canonicalURL = canonical || `https://pcfginsurance.com${Astro.url.pathname}`;
const ogImageURL = ogImage.startsWith('http') ? ogImage : `https://pcfginsurance.com${ogImage}`;

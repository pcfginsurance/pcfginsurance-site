      @keyframes progress{0%{background-position:200% 0}100%{background-position:-200% 0}}
    </style>
    <slot />

    <!-- Deferred Tracking and Analytics Scripts -->
    <script is:inline>
      // Utility to defer scripts until browser is idle
      function loadScriptWhenIdle(src, callback) {
        var idleCallback = window.requestIdleCallback || function(cb) { setTimeout(cb, 1); };
        idleCallback(function() {
          var script = document.createElement('script');
          script.src = src;
          script.async = true;
          if (callback) script.onload = callback;
          document.head.appendChild(script);
        }, { timeout: 2000 });
      }

      // Load scripts after user interaction or idle time
      var scriptsLoaded = false;
      function loadThirdPartyScripts() {
        if (scriptsLoaded) return;
        scriptsLoaded = true;

        // Stagger script loading to avoid blocking
        var idleCallback = window.requestIdleCallback || function(cb) { setTimeout(cb, 1); };

        // Note: GA4 is now loaded synchronously in <head> for accurate tracking
        // Google Ads Conversion tracking only (deferred)
        idleCallback(function() {
          if (window.gtag) {
            gtag('event', 'conversion', {
              'send_to': 'AW-16706905838/PyfqCMOzwtQZEO7NvJ4-',
              'value': 1.0,
              'currency': 'USD'
            });
          }
        }, { timeout: 6000 });

        // Load AdRoll (medium priority) - staggered
        idleCallback(function() {
          window.adroll_adv_id = "M3YLYYCHGFFMFELHT2EUAW";
          window.adroll_pix_id = "CBZLROHJ7BEF7FMWOUWQTR";
          window.adroll_version = "2.0";
          window.__adroll_loaded = true;
          window.adroll = window.adroll || [];
          window.adroll.f = ['setProperties', 'identify', 'track'];
          var roundtripUrl = "https://s.adroll.com/j/" + window.adroll_adv_id + "/roundtrip.js";
          for (var i = 0; i < window.adroll.f.length; i++) {
            window.adroll[window.adroll.f[i]] = window.adroll[window.adroll.f[i]] || (function(n) {
              return function() { window.adroll.push([n, arguments]) }
            })(window.adroll.f[i])
          }
          loadScriptWhenIdle(roundtripUrl, function() {
            if (window.adroll && window.adroll.track) window.adroll.track("pageView");
          });
        }, { timeout: 7000 });

        // Load PageSense (low priority) - heavily staggered
        idleCallback(function() {
          loadScriptWhenIdle('https://cdn.pagesense.io/js/pcfg/d7d8013d765d436c9a20c289b58751b2.js');
        }, { timeout: 8000 });

        idleCallback(function() {
          loadScriptWhenIdle('https://cdn.pagesense.io/js/pcfg/d8415ea51283443b8a47f1fdd453f67a.js');
        }, { timeout: 9000 });

        // Load Netlify Identity (lowest priority)
        idleCallback(function() {
          loadScriptWhenIdle('https://identity.netlify.com/v1/netlify-identity-widget.js');
        }, { timeout: 10000 });
      }

      // Trigger script loading on user interaction OR after 5 seconds
      var events = ['mousedown', 'keydown', 'touchstart', 'scroll'];
      events.forEach(function(event) {
        window.addEventListener(event, loadThirdPartyScripts, { once: true, passive: true });
      });

      // Fallback: load after 5 seconds if no interaction (allows TTI to complete)
      setTimeout(loadThirdPartyScripts, 5000);
    </script>

    <script is:inline>
      // Service Worker registration - deferred to idle time
      if ('serviceWorker' in navigator) {
        var idleCallback = window.requestIdleCallback || function(cb) { setTimeout(cb, 1); };
        idleCallback(function() {
          navigator.serviceWorker.register('/sw.js')
            .then(function(registration) {
              console.log('Service Worker registered:', registration);
            })
            .catch(function(error) {
              console.log('Service Worker registration failed:', error);
            });
        }, { timeout: 5000 });
      }

      // PWA Install Banner - minimal blocking
      var deferredPrompt;
      window.addEventListener('beforeinstallprompt', function(e) {
        e.preventDefault();
        deferredPrompt = e;

        // Defer banner creation to idle time
        var idleCallback = window.requestIdleCallback || function(cb) { setTimeout(cb, 1); };
        idleCallback(function() {
          if (localStorage.getItem('installPromptDismissed')) return;

          var installBanner = document.createElement('div');
          installBanner.id = 'install-banner';
          installBanner.className = 'fixed bottom-0 left-0 right-0 bg-white shadow-lg border-t-2 border-primary p-4 z-50 transform translate-y-0 transition-transform duration-300';
          installBanner.innerHTML = '<div class="max-w-4xl mx-auto flex items-center justify-between"><div class="flex items-center"><img src="/icons/icon-192x192.png" alt="PCFG Insurance" class="w-12 h-12 mr-4 rounded-lg" loading="lazy"><div><p class="font-semibold text-gray-900">Install PCFG Insurance App</p><p class="text-sm text-gray-600">Quick access from your home screen</p></div></div><div class="flex gap-2"><button id="install-button" class="bg-primary hover:bg-primary-dark text-white px-6 py-2 rounded-lg font-semibold transition-colors">Install</button><button id="dismiss-button" class="text-gray-600 hover:text-gray-900 px-4 py-2">Later</button></div></div>';

          document.body.appendChild(installBanner);

          document.getElementById('install-button').addEventListener('click', function() {
            if (deferredPrompt) {
              deferredPrompt.prompt();
              deferredPrompt.userChoice.then(function(result) {
                console.log('User response: ' + result.outcome);
                deferredPrompt = null;
                installBanner.remove();
              });
            }
          });

          document.getElementById('dismiss-button').addEventListener('click', function() {
            installBanner.remove();
            localStorage.setItem('installPromptDismissed', 'true');
            setTimeout(function() {
              localStorage.removeItem('installPromptDismissed');
            }, 7 * 24 * 60 * 60 * 1000);
          });
        }, { timeout: 3000 });
      });

      window.addEventListener('appinstalled', function() {
        console.log('PWA installed successfully');
        var banner = document.getElementById('install-banner');
        if (banner) banner.remove();
      });

      // Remove progress bar after everything loads
      window.addEventListener('load', function() {
        setTimeout(function() {
          document.body.classList.add('loaded');
        }, 100);
      });
    </script>

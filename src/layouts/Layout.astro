      .antialiased{-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}
      img:not([width]){width:100%}

      /* Force visible text immediately */
      *{font-display:optional!important}

      /* Skeleton loading for images */
      img[loading]{background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%);background-size:200% 100%;animation:loading 1.5s ease-in-out infinite}
      @keyframes loading{0%{background-position:200% 0}100%{background-position:-200% 0}}

      /* Critical layout */
      .max-w-7xl{max-width:80rem}
      .mx-auto{margin-left:auto;margin-right:auto}
      .px-4{padding-left:1rem;padding-right:1rem}
      .py-16{padding-top:4rem;padding-bottom:4rem}
      .flex{display:flex}
      .items-center{align-items:center}
      .justify-between{justify-content:space-between}
      .gap-12{gap:3rem}
      .grid{display:grid}
      .grid-cols-1{grid-template-columns:repeat(1,minmax(0,1fr))}
      .h-16{height:4rem}
      .h-10{height:2.5rem}
      .w-auto{width:auto}
      .absolute{position:absolute}
      .relative{position:relative}
      .inset-0{inset:0}
      .z-0{z-index:0}
      .z-10{z-index:10}
      .z-50{z-index:50}
      .sticky{position:sticky}
      .top-0{top:0}
      .overflow-hidden{overflow:hidden}
      .object-cover{object-fit:cover}
      .hidden{display:none}

      /* Critical typography */
      .text-3xl{font-size:1.875rem;line-height:2.25rem}
      .text-xl{font-size:1.25rem;line-height:1.75rem}
      .text-lg{font-size:1.125rem;line-height:1.75rem}
      .text-sm{font-size:.875rem;line-height:1.25rem}
      .font-bold{font-weight:700}
      .font-semibold{font-weight:600}
      .font-medium{font-medium:500}
      .font-heading{font-family:'Poppins',system-ui,sans-serif}
      .text-neutral-dark{color:#212121}
      .text-white{color:#fff}
      .text-gray-600{color:#4b5563}

      /* Critical spacing */
      .mb-6{margin-bottom:1.5rem}
      .mb-8{margin-bottom:2rem}
      .mb-4{margin-bottom:1rem}
      .mt-4{margin-top:1rem}
      .p-4{padding:1rem}
      .p-6{padding:1.5rem}
      .px-3{padding-left:.75rem;padding-right:.75rem}
      .py-2{padding-top:.5rem;padding-bottom:.5rem}
      .px-6{padding-left:1.5rem;padding-right:1.5rem}

      /* Critical colors */
      .bg-white{background-color:#fff}
      .bg-primary{background-color:#4CAF50}
      .bg-primary-50{background-color:#e8f5e9}
      .bg-neutral-light{background-color:#f5f5f5}

      /* Critical effects */
      .shadow-sm{box-shadow:0 1px 2px 0 rgba(0,0,0,.05)}
      .shadow-lg{box-shadow:0 10px 15px -3px rgba(0,0,0,.1)}
      .rounded-lg{border-radius:.5rem}
      .opacity-90{opacity:.9}

      /* Critical buttons */
      button,a.btn{display:inline-flex;align-items:center;justify-content:center;border-radius:.5rem;font-weight:600;transition:all .2s}
      .hover\\:bg-primary-dark:hover{background-color:#388E3C}
      .flex-col{flex-direction:column}
      .gap-4{gap:1rem}
      .w-full{width:100%}

      /* Critical forms */
      iframe{border:none;width:100%;min-height:850px}

      /* Header */
      header{background-color:#fff;box-shadow:0 1px 3px rgba(0,0,0,.1);contain:layout}

      /* Containment */
      section{contain:layout style}
      .card,article{contain:layout style paint}

      /* Gradient */
      .bg-gradient-to-br{background-image:linear-gradient(to bottom right,var(--tw-gradient-stops))}
      .from-primary-50{--tw-gradient-from:#e8f5e9;--tw-gradient-to:rgba(232,245,233,0);--tw-gradient-stops:var(--tw-gradient-from),var(--tw-gradient-to)}
      .to-white{--tw-gradient-to:#fff}

      /* Transitions */
      .transition-colors{transition-property:color,background-color,border-color;transition-timing-function:cubic-bezier(.4,0,.2,1);transition-duration:.15s}

      /* Responsive */
      @media (min-width:640px){.sm\:px-6{padding-left:1.5rem;padding-right:1.5rem}.sm\:flex-row{flex-direction:row}}
      @media (min-width:768px){.md\:text-5xl{font-size:3rem;line-height:1}.md\:text-2xl{font-size:1.5rem;line-height:2rem}.md\:py-20{padding-top:5rem;padding-bottom:5rem}.md\:block{display:block}.md\:hidden{display:none}.md\:flex{display:flex}}
      @media (min-width:1024px){.lg\:px-8{padding-left:2rem;padding-right:2rem}.lg\:grid-cols-2{grid-template-columns:repeat(2,minmax(0,1fr))}.lg\:pl-8{padding-left:2rem}}

      /* Ensure text is always visible */
      h1,h2,h3,h4,h5,h6,p,a,button,span,div{visibility:visible!important}
    </style>


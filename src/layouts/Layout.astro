---
export interface Props {
  title: string;
  description?: string;
  keywords?: string;
}

const { title, description = "PCFG Insurance Services - Protecting what matters most to your business and family across 15 states. Workers' comp, commercial auto, general liability, and more.", keywords = "insurance, workers compensation, commercial auto, general liability, business insurance, employee benefits" } = Astro.props;

  <body class="font-sans antialiased">
    <!-- Instant visual feedback -->
    <style>
      body::before{content:'';position:fixed;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,#4CAF50 0%,#81C784 50%,#4CAF50 100%);background-size:200% 100%;animation:progress 1s ease-in-out infinite;z-index:9999;opacity:1;transition:opacity .3s}
